# build output
dist/

# generated optimized images (built from public/images/*-main.jpg)
public/images/opt/
# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables
.env
.env.production
.env.bak*
.env.before-*
scripts/.env
seo/.env
seo/credentials/
.dev.vars

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# local/editor/tooling noise
.claude/settings.local.json
.wrangler/

# local app settings
kilo_settings.json

# Claude Code runtime state (per-session)
.claude/state.json
.claude/logs/
.claude/hooks/__pycache__/
.claude/settings.local.json
.claude/settings.local.json.backup-*

# SQLite databases — runtime data, never tracked
*.sqlite
*.sqlite.backup-*
*.db
!schema.sql
!**/schema.sql

# Python bytecode cache — never tracked
__pycache__/
**/__pycache__/
*.pyc
