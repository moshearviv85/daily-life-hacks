{
  "name": "dlh-fresh",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "verify:routing": "node scripts/verify-routing.mjs",
    "build:checked": "npm run build && npm run verify:routing",
    "audit:recipes": "node scripts/audit-recipes.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name=daily-life-hacks --branch=main",
    "release:prod": "git push && npm run deploy:prod"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/sitemap": "^3.7.0",
    "@tailwindcss/vite": "^4.2.0",
    "astro": "^5.17.1",
    "lunr": "^2.3.9",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "wrangler": "^3.99.0",
    "xlsx": "^0.18.5"
  }
}
