{
  "name": "dlh-fresh",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/optimize-images.mjs",
    "build": "astro build",
    "verify:routing": "node scripts/verify-routing.mjs",
    "verify:internal-links": "node scripts/verify-internal-links.mjs",
    "verify:pin-destinations": "node scripts/verify-pin-destinations.mjs",
    "audit:routing": "node scripts/audit-routing.mjs",
    "migrate:pin-destinations": "node scripts/migrate-pin-destinations.mjs",
    "derive:pin-routing": "node scripts/derive-pin-routing.mjs",
    "sync:pin-destinations": "py -3 scripts/NEW_PIPELINE_2026-05-08/sync_pin_destinations.py",
    "score:pins": "py -3 scripts/NEW_PIPELINE_2026-05-08/score_pin_performance.py",
    "map:clusters": "py -3 scripts/NEW_PIPELINE_2026-05-08/map_content_clusters.py",
    "audit:clusters": "node scripts/audit-content-clusters.mjs",
    "audit:seo-onpage": "py -3 scripts/NEW_PIPELINE_2026-05-08/seo_onpage_audit.py",
    "upgrade:queue": "py -3 scripts/NEW_PIPELINE_2026-05-08/build_upgrade_queue.py",
    "upgrade:links": "py -3 scripts/NEW_PIPELINE_2026-05-08/inject_pillar_links.py",
    "build:checked": "npm run build && npm run verify:routing && npm run verify:internal-links && npm run verify:pin-destinations && npm run audit:recipes",
    "audit:recipes": "node scripts/audit-recipes.mjs",
    "audit:content": "py -3 scripts/audit_content.py",
    "preview": "astro preview",
    "astro": "astro",
    "deploy:prod": "npm run build:checked && wrangler pages deploy dist --project-name=daily-life-hacks --branch=main",
    "release:prod": "git push && npm run deploy:prod"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/sitemap": "^3.7.0",
    "@tailwindcss/vite": "^4.2.0",
    "astro": "^5.17.1",
    "lunr": "^2.3.9",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "sharp": "^0.34.5",
    "wrangler": "^3.99.0",
    "xlsx": "^0.18.5"
  }
}
