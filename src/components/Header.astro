---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/nutrition/1", label: "Nutrition" },
  { href: "/recipes/1", label: "Recipes" },
  { href: "/tips/1", label: "Tips" },
];

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="sticky top-0 z-50"
  style="background-color: var(--header-bg); border-bottom: 1px solid var(--header-border); box-shadow: 0 1px 4px rgba(0,0,0,0.06); transition: background-color 0.3s ease, border-color 0.3s ease;"
>
  <div
    class="max-w-6xl mx-auto px-4 py-1.5 flex items-center justify-between gap-4"
  >
    <!-- Logo -->
    <a href="/" class="shrink-0 flex items-center">
      <img
        src="/logo.png"
        alt="Daily Life Hacks"
        data-pin-nopin="true"
        class="logo-img"
        style="height: auto; vertical-align: middle;"
      />
    </a>

    <style>
      .logo-img {
        width: 175px; /* Fits better on 320px screens with buttons */
      }
      @media (min-width: 400px) {
        .logo-img {
          width: 260px;
        }
      }
      @media (min-width: 1024px) {
        .logo-img {
          width: 322px;
        }
      }
    </style>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-1">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="px-4 py-2 rounded-md font-medium text-base transition-all duration-200"
            style={
              currentPath === link.href
                ? "background-color: #F29B30; color: #ffffff;"
                : "color: var(--text-color);"
            }
            onmouseover={
              currentPath !== link.href
                ? "this.style.backgroundColor='rgba(242,155,48,0.12)'; this.style.color='#F29B30';"
                : ""
            }
            onmouseout={
              currentPath !== link.href
                ? "this.style.backgroundColor=''; this.style.color='var(--text-color)';"
                : ""
            }
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Right: Search + Dark/Light + Mobile -->
    <div class="flex items-center gap-1.5 sm:gap-2 ml-auto">
      <!-- Search bar - hidden on very small mobile -->
      <div class="relative hidden sm:flex items-center gap-1">
        <div class="relative">
          <button
            class="absolute left-3 top-1/2 -translate-y-1/2 cursor-pointer z-10"
            style="color: var(--muted-color);"
            onclick="const el = document.getElementById('desktop-search'); if(el.value.trim()){ window.location.href='/search?q=' + encodeURIComponent(el.value.trim()); }"
            aria-label="Search"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 hover:text-[#F29B30] transition-colors"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </button>
          <input
            type="text"
            id="desktop-search"
            placeholder="Search articles..."
            class="pl-9 pr-4 py-1.5 text-sm rounded-lg outline-none transition-all duration-200 w-44 focus:w-52"
            style="background-color: var(--input-bg); color: var(--text-color); border: 1px solid var(--border-color);"
            onfocus="this.style.borderColor='#F29B30';"
            onblur="this.style.borderColor='var(--border-color)';"
          />
        </div>
      </div>

      <!-- Dark / Light toggle button -->
      <button
        id="theme-toggle"
        class="p-2 rounded-md transition-all duration-200"
        style="color: var(--muted-color);"
        aria-label="Toggle dark/light mode"
        title="Toggle night mode"
        onmouseover="this.style.backgroundColor='rgba(242,155,48,0.12)'; this.style.color='#F29B30';"
        onmouseout="this.style.backgroundColor=''; this.style.color='var(--muted-color)';"
      >
        <!-- Moon (shown in light mode, hidden in dark via CSS) -->
        <svg
          id="icon-moon"
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 theme-icon-moon"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
          ></path>
        </svg>
        <!-- Sun (shown in dark mode, hidden in light via CSS) -->
        <svg
          id="icon-sun"
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 theme-icon-sun"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
          ></path>
        </svg>
      </button>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-1.5 sm:p-2 rounded-md transition-all duration-200"
        style="color: var(--muted-color);"
        aria-label="Open menu"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div
    id="mobile-menu"
    class="hidden md:hidden px-4 pb-4 pt-2"
    style="background-color: var(--card-bg); border-top: 1px solid var(--border-color);"
  >
    <!-- Mobile search -->
    <div class="relative mb-3">
      <button
        class="absolute left-3 top-1/2 -translate-y-1/2 cursor-pointer z-10"
        style="color: var(--muted-color);"
        onclick="const el = document.getElementById('mobile-search'); if(el.value.trim()){ window.location.href='/search?q=' + encodeURIComponent(el.value.trim()); }"
        aria-label="Search"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 hover:text-[#F29B30] transition-colors"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </button>
      <input
        type="text"
        id="mobile-search"
        placeholder="Search articles..."
        class="w-full pl-9 pr-4 py-2 text-sm rounded-lg"
        style="background-color: var(--input-bg); color: var(--text-color); border: 1px solid var(--border-color);"
      />
    </div>
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          class="block px-4 py-2.5 rounded-md font-medium text-sm"
          style="color: var(--text-color);"
        >
          {link.label}
        </a>
      ))
    }
  </div>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    // ── Mobile menu ──
    const menuBtn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");

    if (menuBtn && menu) {
      menuBtn.addEventListener("click", () => {
        menu.classList.toggle("hidden");
      });
    }

    // ── Dark / Light mode ──
    const themeBtn = document.getElementById("theme-toggle");
    if (themeBtn) {
      themeBtn.addEventListener("click", () => {
        const isDark = document.documentElement.classList.toggle("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
      });
    }

    // ── Search functionality ──
    /** @type {HTMLInputElement | null} */
    const desktopSearch = document.getElementById("desktop-search");
    /** @type {HTMLInputElement | null} */
    const mobileSearch = document.getElementById("mobile-search");
    
    /** @param {HTMLInputElement | null} inputEl */
    function attachSearchListener(inputEl) {
      if (inputEl) {
        inputEl.addEventListener("keydown", (/** @type {KeyboardEvent} */ e) => {
          if (e.key === "Enter" && inputEl.value.trim() !== "") {
            window.location.href = `/search?q=${encodeURIComponent(inputEl.value.trim())}`;
          }
        });
      }
    }
    
    attachSearchListener(desktopSearch);
    attachSearchListener(mobileSearch);
  });
</script>
