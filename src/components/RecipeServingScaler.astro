---
interface Props {
  ingredients: string[];
  servings: number;
}

const { ingredients, servings } = Astro.props;
---

<div class="recipe-scaler" data-recipe-scaler data-base-servings={servings}>
  <div class="mb-5 rounded-xl p-4" style="background:rgba(242,155,48,.09);border:1px solid rgba(242,155,48,.35);">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <p class="font-bold" style="color:var(--heading-color);">How many people are you feeding?</p>
        <p class="text-sm" style="color:var(--muted-color);">Change the servings. The ingredient amounts move with you.</p>
      </div>
      <div class="flex items-center gap-2" role="group" aria-label="Adjust recipe servings">
        <button type="button" data-serving-down class="serving-button" aria-label="Decrease servings">−</button>
        <label class="sr-only" for={`recipe-servings-${servings}`}>Recipe servings</label>
        <input id={`recipe-servings-${servings}`} data-serving-input class="serving-input" type="number" min="1" max="50" step="1" inputmode="numeric" value={servings} />
        <button type="button" data-serving-up class="serving-button" aria-label="Increase servings">+</button>
      </div>
    </div>
    <p data-serving-note class="mt-3 text-xs" style="color:var(--muted-color);">Original recipe: {servings} servings. Cooking time may change for a much larger or smaller batch.</p>
  </div>

  <h3 class="text-xl font-bold mb-4 text-[var(--heading-color)] flex items-center gap-2">
    <span class="text-[#F29B30]">●</span> Ingredients
  </h3>
  <ul class="space-y-2">
    {ingredients.map((ingredient) => (
      <li class="flex items-start gap-2 text-[var(--text-color)]">
        <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#F29B30] flex-shrink-0"></span>
        <span data-scaled-ingredient data-original={ingredient}>{ingredient}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .serving-button{display:grid;place-items:center;width:2.55rem;height:2.55rem;border-radius:.75rem;border:1px solid #F29B30;background:var(--card-bg);color:#F29B30;font-size:1.35rem;font-weight:800;line-height:1}.serving-button:hover{background:#F29B30;color:white}.serving-button:focus-visible,.serving-input:focus-visible{outline:3px solid rgba(242,155,48,.35);outline-offset:2px}.serving-input{width:4rem;height:2.55rem;border-radius:.75rem;border:1px solid var(--border-color);background:var(--page-bg);color:var(--heading-color);text-align:center;font-weight:800;font-size:1rem}
</style>

<script is:inline>
  (function(){
    var glyphs={'¼':.25,'½':.5,'¾':.75,'⅓':1/3,'⅔':2/3,'⅛':.125,'⅜':.375,'⅝':.625,'⅞':.875};
    var fractions=[[.125,'⅛'],[.25,'¼'],[1/3,'⅓'],[.375,'⅜'],[.5,'½'],[.625,'⅝'],[2/3,'⅔'],[.75,'¾'],[.875,'⅞']];
    function value(token){token=token.trim();if(glyphs[token]!==undefined)return glyphs[token];var m=token.match(/^(\d+)\s+(\d+)\/(\d+)$/);if(m)return +m[1]+(+m[2]/+m[3]);m=token.match(/^(\d+)\/(\d+)$/);if(m)return +m[1]/+m[2];m=token.match(/^(\d+)([¼½¾⅓⅔⅛⅜⅝⅞])$/);if(m)return +m[1]+glyphs[m[2]];var n=Number(token);return isFinite(n)?n:null}
    function pretty(number){if(!isFinite(number))return '';var whole=Math.floor(number+1e-8),part=number-whole,best=null,diff=Infinity;fractions.forEach(function(entry){var d=Math.abs(part-entry[0]);if(d<diff){diff=d;best=entry}});if(part<.03)return String(whole);if(1-part<.03)return String(whole+1);if(best&&diff<.025)return (whole?whole+' ':'')+best[1];return String(Math.round(number*100)/100)}
    function adjustUnit(rest,amount){var units='cup|tablespoon|teaspoon|ounce|pound|can|clove|fillet|egg|potato|tortilla|slice|sprig';var re=new RegExp('^(\\s*(?:\\([^)]*\\)\\s*)?)('+units+')(s?)(\\b)','i');return rest.replace(re,function(all,prefix,unit,suffix,boundary){return prefix+unit+(amount>1.001?'s':'')+boundary})}
    function scaleIngredient(text,factor){if(Math.abs(factor-1)<.0001)return text;var pattern='(\\d+\\s+\\d+\\/\\d+|\\d+\\/\\d+|\\d+[¼½¾⅓⅔⅛⅜⅝⅞]|[¼½¾⅓⅔⅛⅜⅝⅞]|\\d+(?:\\.\\d+)?)';var lead=text.match(new RegExp('^(\\s*)'+pattern+'(\\s*(?:-|–|to)\\s*)'+pattern+'(.*)$','i'));if(lead){var a=value(lead[2]),b=value(lead[4]);if(a!==null&&b!==null){var scaledB=b*factor;return lead[1]+pretty(a*factor)+lead[3]+pretty(scaledB)+adjustUnit(lead[5],scaledB)}}lead=text.match(new RegExp('^(\\s*)'+pattern+'(.*)$'));if(!lead)return text;var amount=value(lead[2]);if(amount===null)return text;var scaled=amount*factor;return lead[1]+pretty(scaled)+adjustUnit(lead[3],scaled)}
    function render(root){var base=Number(root.dataset.baseServings)||1,input=root.querySelector('[data-serving-input]'),current=Math.max(1,Math.min(50,Math.round(Number(input.value)||base)));input.value=String(current);root.querySelectorAll('[data-scaled-ingredient]').forEach(function(node){node.textContent=scaleIngredient(node.dataset.original,current/base)});document.querySelectorAll('[data-recipe-servings]').forEach(function(node){node.textContent=String(current)});var note=root.querySelector('[data-serving-note]');note.textContent=current===base?'Original recipe: '+base+' servings. Cooking time may change for a much larger or smaller batch.':'Scaled from '+base+' to '+current+' servings. Check pan size and doneness instead of trusting the clock with your life.'}
    function track(root){if(root.dataset.scalerTracked)return;root.dataset.scalerTracked='1';if(typeof window.gtag==='function')window.gtag('event','recipe_scaler_used',{tool_name:'recipe_serving_scaler',interaction_type:'servings_changed'})}
    function boot(){document.querySelectorAll('[data-recipe-scaler]').forEach(function(root){if(root.dataset.scalerBooted)return;root.dataset.scalerBooted='1';var input=root.querySelector('[data-serving-input]');root.querySelector('[data-serving-down]').addEventListener('click',function(){input.value=String(Math.max(1,(Number(input.value)||1)-1));render(root);track(root)});root.querySelector('[data-serving-up]').addEventListener('click',function(){input.value=String(Math.min(50,(Number(input.value)||1)+1));render(root);track(root)});input.addEventListener('input',function(){render(root);track(root)});render(root)})}
    boot();document.addEventListener('astro:page-load',boot);
  })();
</script>
