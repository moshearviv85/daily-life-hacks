---
interface Props {
  /** When embedded on an article page, pass Kit/D1 context (same visible UI as homepage). */
  articleCategory?: string;
  articleBaseSlug?: string;
}

const { articleCategory = "", articleBaseSlug = "" } = Astro.props;
---

<section
  class="py-8 mt-4 mb-0 transition-colors duration-300"
  style="background-color: var(--newsletter-bg); border-top: 1px solid var(--newsletter-border);"
>
  <div class="max-w-2xl mx-auto px-4 text-center">
    <div
      class="inline-block mb-4 px-4 py-1.5 rounded-full text-sm font-bold uppercase tracking-widest text-white"
      style="background-color: #F29B30;"
    >
      Free Newsletter
    </div>

    <h2 class="text-5xl font-bold mb-3" style="color: var(--heading-color);">
      Get Weekly Nutrition, Recipes & Life Hacks
    </h2>
    <p class="text-lg mb-5" style="color: var(--muted-color);">
      Get our best healthy recipes, nutrition advice, and practical life hacks
      delivered to your inbox every week.<br />No spam, only interesting things.
      Unsubscribe anytime.
    </p>

    <!-- Subscribe Form -->
    <form id="footer-newsletter-form" class="max-w-md mx-auto space-y-3">
      <input
        id="footer-email"
        type="email"
        placeholder="Enter your email"
        required
        class="w-full px-5 py-3.5 rounded-xl text-base focus:ring-2 focus:ring-[#F29B30] outline-none transition-all"
        style="color: var(--text-color); background-color: var(--input-bg); border: 1px solid var(--border-color);"
      />
      <label class="flex items-start gap-2 text-left cursor-pointer">
        <input
          id="footer-consent"
          type="checkbox"
          required
          class="mt-1 accent-[#F29B30] shrink-0"
        />
        <span class="text-xs leading-snug" style="color: var(--muted-color);">
          I agree to receive email newsletters and accept the
          <a href="/privacy" class="underline hover:text-[#F29B30]">Privacy Policy</a>.
          You can unsubscribe at any time.
        </span>
      </label>
      <button
        id="footer-submit-btn"
        type="submit"
        class="w-full py-3.5 px-6 font-bold text-white rounded-xl transition-transform hover:scale-[1.02] shadow-md text-base"
        style="background-color: #F29B30;"
      >
        Subscribe Free
      </button>
    </form>

    <!-- Success Message -->
    <div id="footer-success" class="hidden max-w-md mx-auto py-6">
      <div
        class="inline-flex items-center justify-center w-12 h-12 mb-3 rounded-full bg-green-100 text-green-500"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M5 13l4 4L19 7"></path>
        </svg>
      </div>
      <p class="text-xl font-bold" style="color: var(--heading-color);">
        You're in!
      </p>
      <p class="text-sm" style="color: var(--muted-color);">
        You're on the list. Fresh emails are on the way.
      </p>
    </div>
  </div>
</section>

<script define:vars={{ articleCategory, articleBaseSlug }}>
  interface SignupContext {
    category?: string;
    base_slug?: string;
    variant_slug?: string;
    email_segment?: string;
  }

  function getStoredSignupContext() {
    try {
      const raw = sessionStorage.getItem("newsletter_signup_context");
      if (!raw) return {};

      const parsed = JSON.parse(raw);
      if (parsed.page && parsed.page !== window.location.pathname) {
        return {};
      }

      return {
        category: parsed.category || "",
        base_slug: parsed.base_slug || "",
        variant_slug: parsed.variant_slug || "",
        email_segment: parsed.email_segment || "",
      };
    } catch {
      return {};
    }
  }

  function redirectToThankYou(source: string, context: SignupContext) {
    const params = new URLSearchParams({ source });
    if (context.category) params.set("category", context.category);
    if (context.email_segment) params.set("segment", context.email_segment);

    try {
      sessionStorage.removeItem("newsletter_signup_context");
    } catch {
      // Ignore storage cleanup failures.
    }

    window.location.href = `/thank-you?${params.toString()}`;
  }

  function setupFooterForm() {
    const form = document.getElementById("footer-newsletter-form");
    const emailInput = document.getElementById(
      "footer-email",
    ) as HTMLInputElement;
    const submitBtn = document.getElementById(
      "footer-submit-btn",
    ) as HTMLButtonElement;
    const successEl = document.getElementById("footer-success");

    if (!form) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!emailInput || !emailInput.value) return;

      submitBtn.disabled = true;
      submitBtn.innerText = "Subscribing...";

      try {
        fetch("/api/event", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            event_type: "signup_started",
            source: "footer",
            page: window.location.pathname,
            metadata: {
              location: "footer-newsletter",
            },
          }),
        }).catch(() => {});

        const signupContext = getStoredSignupContext();
        const mergedCategory = signupContext.category || articleCategory || "";
        const mergedBaseSlug = signupContext.base_slug || articleBaseSlug || "";
        const res = await fetch("/api/subscribe", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            email: emailInput.value,
            source: "footer",
            page: window.location.pathname,
            ...signupContext,
            category: mergedCategory,
            base_slug: mergedBaseSlug,
          }),
        });

        if (res.ok) {
          form.classList.add("hidden");
          successEl?.classList.remove("hidden");
          const thankYouContext = {
            ...signupContext,
            category: mergedCategory,
            base_slug: mergedBaseSlug,
          };
          setTimeout(() => redirectToThankYou("footer", thankYouContext), 250);
        } else {
          submitBtn.innerText = "Try Again";
          submitBtn.disabled = false;
        }
      } catch {
        submitBtn.innerText = "Try Again";
        submitBtn.disabled = false;
      }
    });
  }

  document.addEventListener("astro:page-load", setupFooterForm);
</script>
