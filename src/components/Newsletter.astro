---
---

<section
  class="py-8 mt-4 mb-0 transition-colors duration-300"
  style="background-color: var(--newsletter-bg); border-top: 1px solid var(--newsletter-border);"
>
  <div class="max-w-2xl mx-auto px-4 text-center">
    <div
      class="inline-block mb-4 px-4 py-1.5 rounded-full text-sm font-bold uppercase tracking-widest text-white"
      style="background-color: #F29B30;"
    >
      Free Newsletter
    </div>

    <h2 class="text-5xl font-bold mb-3" style="color: var(--heading-color);">
      Get Weekly Nutrition Tips & Easy Recipes
    </h2>
    <p class="text-lg mb-5" style="color: var(--muted-color);">
      Get our best healthy recipes and nutrition tips
      delivered to your inbox every week.<br />No spam, only interesting things.
      Unsubscribe anytime.
    </p>

    <!-- Subscribe Form -->
    <form id="footer-newsletter-form" class="max-w-md mx-auto space-y-3">
      <input
        id="footer-email"
        type="email"
        placeholder="Enter your email"
        required
        class="w-full px-5 py-3.5 rounded-xl text-base focus:ring-2 focus:ring-[#F29B30] outline-none transition-all"
        style="color: var(--text-color); background-color: var(--input-bg); border: 1px solid var(--border-color);"
      />
      <button
        id="footer-submit-btn"
        type="submit"
        class="w-full py-3.5 px-6 font-bold text-white rounded-xl transition-transform hover:scale-[1.02] shadow-md text-base"
        style="background-color: #F29B30;"
      >
        Subscribe Free
      </button>
    </form>

    <!-- Success Message -->
    <div id="footer-success" class="hidden max-w-md mx-auto py-6">
      <div class="inline-flex items-center justify-center w-12 h-12 mb-3 rounded-full bg-green-100 text-green-500">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>
      <p class="text-xl font-bold" style="color: var(--heading-color);">You're in!</p>
      <p class="text-sm" style="color: var(--muted-color);">Check your inbox for a welcome surprise.</p>
    </div>

    <!-- Pinterest Follow Button -->
    <div class="flex justify-center pt-5">
      <a
        href="https://pinterest.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-medium transition-colors duration-200 px-6 py-2 rounded-full border"
        style="color: var(--muted-color); border-color: var(--border-color);"
        onmouseover="this.style.color='#E60023'; this.style.borderColor='#E60023'; this.style.backgroundColor='rgba(230,0,35,0.05)';"
        onmouseout="this.style.color='var(--muted-color)'; this.style.borderColor='var(--border-color)'; this.style.backgroundColor='transparent';"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"
          ></path>
        </svg>
        Follow on Pinterest
      </a>
    </div>
  </div>
</section>

<script>
  function setupFooterForm() {
    const form = document.getElementById("footer-newsletter-form");
    const emailInput = document.getElementById("footer-email") as HTMLInputElement;
    const submitBtn = document.getElementById("footer-submit-btn") as HTMLButtonElement;
    const successEl = document.getElementById("footer-success");

    if (!form) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!emailInput || !emailInput.value) return;

      submitBtn.disabled = true;
      submitBtn.innerText = "Subscribing...";

      try {
        const res = await fetch("/api/subscribe", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email: emailInput.value }),
        });

        if (res.ok) {
          form.classList.add("hidden");
          successEl?.classList.remove("hidden");
        } else {
          submitBtn.innerText = "Try Again";
          submitBtn.disabled = false;
        }
      } catch {
        submitBtn.innerText = "Try Again";
        submitBtn.disabled = false;
      }
    });
  }

  document.addEventListener("astro:page-load", setupFooterForm);
</script>
