---
interface Props {
  category: "recipes" | "nutrition" | "tips";
  baseSlug: string;
}

const { category, baseSlug } = Astro.props;
---

<section
  class="article-newsletter-cta mt-10 mx-auto max-w-lg rounded-xl border-2 px-4 py-4 md:px-5 md:py-4 text-center"
  style="background-color: var(--card-bg); border-color: #F29B30;"
  aria-labelledby="article-newsletter-lead"
>
  <p
    id="article-newsletter-lead"
    class="text-base md:text-lg font-bold leading-snug mb-2"
    style="color: var(--heading-color);"
  >
    Subscribe and all that stuff…
  </p>
  <div
    class="space-y-1.5 text-sm leading-snug mb-3 mx-auto max-w-[22rem]"
    style="color: var(--text-color);"
  >
    <p>I'm not here to fix your whole life in one email.</p>
    <p>
      I'm here to make dinner a little easier and your grocery run a little less annoying.
    </p>
    <p class="text-xs leading-snug" style="color: var(--muted-color);">
      No junk mail. Just one useful email a week. And you can unsubscribe whenever you want.
    </p>
  </div>

  <form id="article-newsletter-form" class="mx-auto max-w-[20rem] space-y-2.5 text-center">
    <label for="article-newsletter-email" class="sr-only">Email address</label>
    <input
      id="article-newsletter-email"
      type="email"
      name="email"
      autocomplete="email"
      inputmode="email"
      placeholder="Enter your email"
      required
      class="w-full px-3 py-2 rounded-lg text-sm text-center focus:ring-2 focus:ring-[#F29B30] focus:ring-offset-0 outline-none transition-all"
      style="color: var(--text-color); background-color: var(--input-bg); border: 1px solid var(--border-color);"
    />
    <label class="flex flex-col items-center gap-1.5 cursor-pointer px-0.5">
      <input
        id="article-newsletter-consent"
        type="checkbox"
        name="consent"
        required
        class="accent-[#F29B30] shrink-0"
      />
      <span class="text-[11px] leading-snug text-balance max-w-[19rem]" style="color: var(--muted-color);">
        I agree to receive email newsletters and accept the
        <a href="/privacy" class="underline hover:text-[#F29B30]">Privacy Policy</a>.
        You can unsubscribe at any time.
      </span>
    </label>
    <div class="text-center pt-0.5">
      <button
        id="article-newsletter-submit"
        type="submit"
        class="inline-flex items-center justify-center min-w-[10.5rem] py-2 px-5 text-sm font-semibold text-white rounded-lg transition-colors hover:opacity-95"
        style="background-color: #F29B30;"
      >
        Join the list
      </button>
    </div>
  </form>

  <div id="article-newsletter-success" class="hidden pt-2 space-y-1" role="status">
    <p class="text-base font-bold" style="color: var(--heading-color);">You're in!</p>
    <p class="text-xs leading-snug" style="color: var(--muted-color);">Taking you to the thank you page…</p>
  </div>
</section>

<script define:vars={{ category, baseSlug }}>
  function redirectArticleThankYou() {
    const params = new URLSearchParams({ source: "article" });
    if (category) params.set("category", category);
    window.location.href = `/thank-you?${params.toString()}`;
  }

  function setupArticleNewsletter() {
    const form = document.getElementById("article-newsletter-form");
    const emailInput = document.getElementById("article-newsletter-email");
    const consentInput = document.getElementById("article-newsletter-consent");
    const submitBtn = document.getElementById("article-newsletter-submit");
    const successEl = document.getElementById("article-newsletter-success");

    if (!form || !(emailInput instanceof HTMLInputElement)) return;
    if (!(consentInput instanceof HTMLInputElement)) return;
    if (!(submitBtn instanceof HTMLButtonElement)) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!emailInput.value || !emailInput.value.includes("@")) return;
      if (!consentInput.checked) return;

      submitBtn.disabled = true;
      submitBtn.textContent = "Joining…";

      try {
        fetch("/api/event", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            event_type: "signup_started",
            source: "article",
            page: window.location.pathname,
            metadata: {
              location: "article-newsletter",
              base_slug: baseSlug,
            },
          }),
        }).catch(() => {});

        const res = await fetch("/api/subscribe", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            email: emailInput.value.trim(),
            source: "article",
            page: window.location.pathname,
            category,
            base_slug: baseSlug,
            variant_slug: "",
            email_segment: "",
          }),
        });

        if (res.ok) {
          form.classList.add("hidden");
          successEl?.classList.remove("hidden");
          setTimeout(() => redirectArticleThankYou(), 400);
          return;
        }

        submitBtn.textContent = "Try again";
        submitBtn.disabled = false;
      } catch {
        submitBtn.textContent = "Try again";
        submitBtn.disabled = false;
      }
    });
  }

  document.addEventListener("astro:page-load", setupArticleNewsletter);
</script>
