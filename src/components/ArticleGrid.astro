---
import ArticleCard from "./ArticleCard.astro";

interface Props {
  title: string;
  articles: any[];
  accent?: string;
}

const { title, articles, accent = "#F29B30" } = Astro.props;
---

<section class="w-full max-w-6xl mx-auto px-4 py-8">
  <div class="flex items-center gap-3 mb-6">
    <h2
      class="text-xl font-bold uppercase tracking-wide shrink-0"
      style="color: var(--heading-color);"
    >
      {title}
    </h2>
    <div
      class="flex-1 h-px min-w-0"
      style="background-color: var(--border-color);"
    >
    </div>
    <div class="w-10 h-0.5 shrink-0" style={`background-color: ${accent};`}>
    </div>
  </div>

  <!-- 1 col mobile → 2 col at 640px → 4 col at 1024px -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
    {
      articles.map((article) => (
        <div class="min-w-0">
          <ArticleCard
            title={article.data.title}
            excerpt={article.data.excerpt}
            image={article.data.image}
            imageAlt={article.data.imageAlt}
            category={article.data.category}
            slug={article.id}
            size="md"
            date={article.data.date}
          />
        </div>
      ))
    }
  </div>
</section>
