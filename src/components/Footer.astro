---
const year = new Date().getFullYear();
---

<!-- Minimal Footer - no gap from newsletter -->
<footer
  class="py-2 text-center"
  style="border-top: 1px solid var(--border-color); background-color: var(--newsletter-bg);"
>
  <div class="max-w-6xl mx-auto px-4 space-y-1.5">
    <div
      class="flex flex-col md:flex-row items-center justify-center gap-6 mb-6"
    >
      <div
        class="flex flex-col items-center shrink-0 w-full max-w-[280px] md:max-w-[460px]"
      >
        <a href="/" class="w-full flex justify-center">
          <img
            src="/logo.png"
            alt="Daily Life Hacks"
            data-pin-nopin="true"
            class="w-full h-auto"
          />
        </a>
        <div class="flex justify-center pt-3 w-full">
          <a
            href="https://www.pinterest.com/DavidMiller615/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium transition-colors duration-200 px-6 py-2 rounded-full border"
            style="color: var(--muted-color); border-color: var(--border-color);"
            onmouseover="this.style.color='#E60023'; this.style.borderColor='#E60023'; this.style.backgroundColor='rgba(230,0,35,0.05)';"
            onmouseout="this.style.color='var(--muted-color)'; this.style.borderColor='var(--border-color)'; this.style.backgroundColor='transparent';"
          >
            <svg
              class="h-5 w-5 shrink-0"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"
              ></path>
            </svg>
            Follow on Pinterest
          </a>
        </div>
      </div>
      <p
        class="text-base md:text-lg leading-relaxed text-center md:text-left max-w-md"
        style="color: var(--muted-color);"
      >
        Practical nutrition tips and easy recipes for a healthier, happier
        everyday life.
      </p>
    </div>
    <nav
      class="flex flex-col md:flex-row flex-wrap justify-center items-center gap-4 md:gap-6 text-base"
    >
      <a
        href="/about"
        class="transition-colors duration-200"
        style="color: var(--muted-color);"
        onmouseover="this.style.color='#F29B30';"
        onmouseout="this.style.color='var(--muted-color)';">About</a
      >
      <a
        href="/contact"
        class="transition-colors duration-200"
        style="color: var(--muted-color);"
        onmouseover="this.style.color='#F29B30';"
        onmouseout="this.style.color='var(--muted-color)';">Contact</a
      >
      <a
        href="/terms"
        class="transition-colors duration-200"
        style="color: var(--muted-color);"
        onmouseover="this.style.color='#F29B30';"
        onmouseout="this.style.color='var(--muted-color)';">Terms of Use</a
      >
      <a
        href="/disclaimer"
        class="transition-colors duration-200"
        style="color: var(--muted-color);"
        onmouseover="this.style.color='#F29B30';"
        onmouseout="this.style.color='var(--muted-color)';">Disclaimer</a
      >
      <a
        href="/privacy"
        class="transition-colors duration-200"
        style="color: var(--muted-color);"
        onmouseover="this.style.color='#F29B30';"
        onmouseout="this.style.color='var(--muted-color)';">Privacy Policy</a
      >
    </nav>
    <p
      class="mx-auto opacity-75"
      style="color: var(--label-color); font-size: 13px; line-height: 1.5; max-width: 1152px;"
    >
      Disclaimer: The information on this site is not intended or implied to be
      a substitute for professional financial and/or medical advice. All
      content, including text, graphics, images and information, contained on or
      available through this web site is for general information purposes only.
      The information and materials contained in these pages and the terms,
      conditions and descriptions that appear, are subject to change without
      notice.
    </p>
    <p class="text-sm" style="color: var(--label-color);">
      © {year} Daily Life Hacks. All rights reserved.
    </p>
  </div>
</footer>
