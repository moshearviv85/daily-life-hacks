---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

// 1. Get all published articles to be searchable
const allArticles = await getCollection("articles");
const searchIndexData = allArticles.map((article) => ({
  title: article.data.title,
  slug: article.slug,
  excerpt: article.data.excerpt,
  image: article.data.image,
  category: article.data.category,
}));
---

<BaseLayout
  title="Search Daily Life Hacks"
  description="Search for nutrition tips, recipes, and gut health advice."
>
  <main class="max-w-4xl mx-auto px-4 py-12 md:py-20">
    <div class="text-center mb-10">
      <h1 class="text-3xl md:text-5xl font-bold mb-4" style="color: var(--heading-color);">
        Search
      </h1>
      <p class="text-lg" style="color: var(--muted-color);">
        Find what you're looking for...
      </p>
    </div>

    <!-- The actual search input specific to this page -->
    <div class="relative max-w-2xl mx-auto mb-12">
      <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
        <svg
          class="h-6 w-6"
          style="color: var(--muted-color);"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
          ></path>
        </svg>
      </div>
      <input
        type="search"
        id="search-page-input"
        placeholder="Search recipes, ingredients, or health tips..."
        class="block w-full pl-12 pr-4 py-4 rounded-xl outline-none text-lg transition-all duration-300 focus:ring-2 focus:ring-[#F29B30]"
        style="background-color: var(--card-bg); color: var(--text-color); border: 2px solid var(--border-color); box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);"
        autofocus
      />
    </div>

    <!-- Results Container -->
    <div id="search-results" class="grid grid-cols-1 sm:grid-cols-2 gap-6 min-h-[300px]">
      <div class="col-span-full text-center py-10" id="search-placeholder">
        <p style="color: var(--muted-color);">Type above to start searching...</p>
      </div>
    </div>
  </main>
</BaseLayout>

<!-- Client-side Search Logic -->
<script define:vars={{ searchIndexData }}>
  document.addEventListener("astro:page-load", async () => {
    const inputEL = document.getElementById("search-page-input");
    const resultsContainer = document.getElementById("search-results");
    const placeholder = document.getElementById("search-placeholder");

    // Load URL query param if user came from the header search bar
    const urlParams = new URLSearchParams(window.location.search);
    const query = urlParams.get('q');
    
    // We'll dynamically load lunr ONLY on this search page to keep performance high
    // Use an unpkg CDN for simplicity in Astro components
    if (!window.lunr) {
      const script = document.createElement("script");
      script.src = "https://unpkg.com/lunr/lunr.js";
      document.head.appendChild(script);
      
      script.onload = () => {
        initSearch();
      };
    } else {
      initSearch();
    }

    function initSearch() {
      // 1. Build the index
      const idx = window.lunr(function () {
        this.ref("slug");
        this.field("title", { boost: 10 });
        this.field("excerpt", { boost: 5 });
        this.field("category");

        searchIndexData.forEach(function (doc) {
          this.add(doc);
        }, this);
      });

      // 2. Perform search logic
      function performSearch(searchTerm) {
        if (!searchTerm || searchTerm.trim().length < 2) {
            resultsContainer.innerHTML = '';
            resultsContainer.appendChild(placeholder);
            placeholder.innerHTML = '<p style="color: var(--muted-color);">Type above to start searching...</p>';
            return;
        }

        // Add wildcard for partial matching
        const searchResults = idx.search(searchTerm + '*');

        if (searchResults.length === 0) {
            resultsContainer.innerHTML = `<div class="col-span-full text-center py-10"><p style="color: var(--muted-color); font-size: 1.125rem;">No results found for "<b>${searchTerm}</b>".</p></div>`;
            return;
        }

        // Render results
        resultsContainer.innerHTML = ''; // clear

        searchResults.forEach((result) => {
            const doc = searchIndexData.find((a) => a.slug === result.ref);
            if (!doc) return;

            const categoryBadge = doc.category === 'recipes' 
              ? '<span class="px-2 py-0.5 mt-2 inline-block rounded text-xs font-semibold bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-100">Recipe</span>'
              : '<span class="px-2 py-0.5 mt-2 inline-block rounded text-xs font-semibold bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-100">Nutrition</span>';

            const cardHtml = `
              <a href="/${doc.slug}" class="group flex flex-col md:flex-row rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 border" style="background-color: var(--card-bg); border-color: var(--border-color);">
                <div class="h-48 md:h-auto md:w-1/3 shrink-0 overflow-hidden relative">
                  <img src="${doc.image}" alt="${doc.title}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                </div>
                <div class="p-5 md:p-6 flex flex-col justify-center w-full">
                  <h3 class="text-xl font-bold mb-2 group-hover:text-[#F29B30] transition-colors line-clamp-2" style="color: var(--heading-color);">
                    ${doc.title}
                  </h3>
                  <p class="text-sm line-clamp-2" style="color: var(--muted-color);">
                    ${doc.excerpt}
                  </p>
                  <div>${categoryBadge}</div>
                </div>
              </a>
            `;
            
            // Need a temp container to append raw html string cleanly
            const tempDiv = document.createElement('div');
            // make it span full on mobile, 1 col on desktop
            tempDiv.className = "col-span-full";
            tempDiv.innerHTML = cardHtml;
            resultsContainer.appendChild(tempDiv);
        });
      }

      // Handle immediate search from header
      if (query) {
        inputEL.value = query;
        performSearch(query);
      }

      // Handle live typing
      inputEL.addEventListener("input", (e) => {
        performSearch(e.target.value);
        
        // Update URL cleanly without refreshing
        const newUrl = new URL(window.location);
        if (e.target.value) {
            newUrl.searchParams.set("q", e.target.value);
        } else {
            newUrl.searchParams.delete("q");
        }
        window.history.replaceState({}, "", newUrl);
      });
    }
  });
</script>
