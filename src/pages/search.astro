---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

// 1. Get all published articles to be searchable
const allArticles = await getCollection("articles");
const searchIndexData = allArticles.map((article) => ({
  title: article.data.title,
  slug: article.slug,
  excerpt: article.data.excerpt,
  image: article.data.image,
  category: article.data.category,
}));
---

<BaseLayout
  title="Search Daily Life Hacks"
  description="Search for nutrition tips, recipes, and gut health advice."
>
  <main class="max-w-4xl mx-auto px-4 py-12 md:py-20">
    <div class="text-center mb-10">
      <h1 class="text-3xl md:text-5xl font-bold mb-4" style="color: var(--heading-color);">
        Search
      </h1>
      <p class="text-lg" style="color: var(--muted-color);">
        Find what you're looking for...
      </p>
    </div>

    <!-- Quick Topics (Autocomplete suggestions) -->
    <div class="flex flex-wrap justify-center gap-2 mb-12">
      {["Gut Health", "High Fiber", "Breakfast", "Meal Prep", "Avocado", "Smoothie", "Snacks", "Storage"].map((topic) => (
        <button
          type="button"
          class="topic-btn px-4 py-1.5 rounded-full text-sm font-medium transition-colors border"
          style="background-color: var(--card-bg); color: var(--text-color); border-color: var(--border-color);"
          data-topic={topic}
        >
          {topic}
        </button>
      ))}
    </div>

    <!-- The actual search input specific to this page -->
    <div class="relative max-w-2xl mx-auto mb-10">
      <button
        class="absolute inset-y-0 left-0 pl-4 flex items-center cursor-pointer z-10"
        onclick="const el = document.getElementById('search-page-input'); if(el.value.trim()){ el.dispatchEvent(new Event('input', {bubbles: true})); }"
        aria-label="Search"
      >
        <svg
          class="h-6 w-6 hover:text-[#F29B30] transition-colors"
          style="color: var(--muted-color);"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
          ></path>
        </svg>
      </button>
      <input
        type="search"
        id="search-page-input"
        placeholder="Search recipes, ingredients, or health tips..."
        class="block w-full pl-12 pr-4 py-4 rounded-xl outline-none text-lg transition-all duration-300 focus:ring-2 focus:ring-[#F29B30]"
        style="background-color: var(--card-bg); color: var(--text-color); border: 2px solid var(--border-color); box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);"
        autofocus
      />
    </div>

    <!-- Results Container -->
    <div id="search-results" class="grid grid-cols-1 sm:grid-cols-2 gap-6 min-h-[300px]">
      <div class="col-span-full text-center py-10" id="search-placeholder">
        <p style="color: var(--muted-color);">Type above to start searching...</p>
      </div>
    </div>
    
    <!-- Data bridge to pass Astro data to client securely -->
    <div id="search-data" data-index={JSON.stringify(searchIndexData)} hidden></div>
  </main>
</BaseLayout>

<!-- Client-side Search Logic -->
<script>
  import lunr from "lunr";

  const dataEl = document.getElementById("search-data");
  const inputEL = document.getElementById("search-page-input") as HTMLInputElement;
  const resultsContainer = document.getElementById("search-results");

  if (!dataEl || !inputEL || !resultsContainer) throw new Error("Search elements missing");

  const searchIndexData: { title: string; slug: string; excerpt: string; image: string; category: string }[] =
    JSON.parse(dataEl.dataset.index || "[]");

  const idx = lunr(function () {
    this.ref("slug");
    this.field("title", { boost: 10 });
    this.field("excerpt", { boost: 5 });
    this.field("category");
    searchIndexData.forEach(function (doc) { this.add(doc); }, this);
  });

  function renderResults(searchTerm: string) {
    const term = searchTerm.trim();

    if (term.length < 2) {
      resultsContainer.innerHTML = `<div class="col-span-full text-center py-10"><p style="color: var(--muted-color);">Type above to start searching...</p></div>`;
      return;
    }

    let results: lunr.Index.Result[] = [];
    try {
      results = idx.search(term.split(/\s+/).map(w => w + "*").join(" "));
    } catch {
      try { results = idx.search(term); } catch { results = []; }
    }

    if (results.length === 0) {
      resultsContainer.innerHTML = `<div class="col-span-full text-center py-10"><p style="color: var(--muted-color); font-size: 1.125rem;">No results found for "<b>${term}</b>".</p></div>`;
      return;
    }

    resultsContainer.innerHTML = results.map((r) => {
      const doc = searchIndexData.find(a => a.slug === r.ref);
      if (!doc) return "";
      const badge = doc.category === "recipes"
        ? `<span class="px-2 py-0.5 mt-2 inline-block rounded text-xs font-semibold bg-green-100 text-green-800">Recipe</span>`
        : `<span class="px-2 py-0.5 mt-2 inline-block rounded text-xs font-semibold bg-blue-100 text-blue-800">Nutrition</span>`;
      return `<div class="col-span-full">
        <a href="/${doc.slug}" class="group flex flex-col md:flex-row rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 border" style="background-color: var(--card-bg); border-color: var(--border-color);">
          <div class="h-48 md:h-auto md:w-1/3 shrink-0 overflow-hidden">
            <img src="${doc.image || '/logo.png'}" alt="${doc.title}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-5 md:p-6 flex flex-col justify-center">
            <h3 class="text-xl font-bold mb-2 group-hover:text-[#F29B30] transition-colors line-clamp-2" style="color: var(--heading-color);">${doc.title}</h3>
            <p class="text-sm line-clamp-2 mb-2" style="color: var(--muted-color);">${doc.excerpt || ""}</p>
            ${badge}
          </div>
        </a>
      </div>`;
    }).join("");
  }

  function setQuery(val: string) {
    inputEL.value = val;
    renderResults(val);
    const url = new URL(window.location.href);
    val ? url.searchParams.set("q", val) : url.searchParams.delete("q");
    window.history.replaceState({}, "", url);
  }

  // Run search from URL param on load
  const q = new URLSearchParams(window.location.search).get("q") || "";
  if (q) setQuery(q);

  // Live typing
  inputEL.addEventListener("input", (e) => setQuery((e.target as HTMLInputElement).value));

  // Topic buttons
  document.querySelectorAll<HTMLButtonElement>(".topic-btn").forEach(btn => {
    btn.addEventListener("click", () => setQuery(btn.dataset.topic || ""));
  });
</script>
