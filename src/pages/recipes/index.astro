---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getCollection } from "astro:content";
import { isReleased, getReleaseTimestamp } from "../../content/release";

const allArticles = await getCollection("articles");
const articles = allArticles
    .filter((article: any) => isReleased(article))
    .filter((article: any) => article.data.category === "recipes")
    .sort((a: any, b: any) => getReleaseTimestamp(b) - getReleaseTimestamp(a));

const BATCH_SIZE = 12;
const title = "Easy Recipes With Adjustable Servings | Daily Life Hacks";
const description =
    "Practical recipes with ingredient amounts you can scale for the number of people you're feeding, plus meal prep ideas built for real kitchens.";
const categoryUrl = "https://www.daily-life-hacks.com/recipes/";
const itemListSchema = {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "@id": `${categoryUrl}#item-list`,
    name: "Easy Recipes With Adjustable Servings",
    numberOfItems: articles.length,
    itemListOrder: "https://schema.org/ItemListOrderDescending",
    itemListElement: articles.map((article: any, index: number) => ({
        "@type": "ListItem",
        position: index + 1,
        name: article.data.title,
        url: `https://www.daily-life-hacks.com/${article.id}/`,
    })),
};
const collectionPageSchema = {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Easy Recipes With Adjustable Servings",
    url: categoryUrl,
    description,
    isPartOf: {
        "@type": "WebSite",
        name: "Daily Life Hacks",
        url: "https://www.daily-life-hacks.com/",
    },
    mainEntity: { "@id": `${categoryUrl}#item-list` },
};
---

<BaseLayout
    title={title}
    description={description}
    jsonLd={[collectionPageSchema, itemListSchema]}
>
    <Header />
    <div class="max-w-6xl mx-auto px-4 py-12">
        <header class="mb-12 text-center">
            <h1
                class="text-4xl md:text-5xl font-bold mb-4 text-[var(--heading-color)]"
            >
                Recipes
            </h1>
            <p
                class="text-xl max-w-2xl mx-auto"
                style="color: var(--muted-color);"
            >
                {description}
            </p>
        </header>

        <aside class="mb-10 rounded-2xl p-5 md:p-6 flex flex-col md:flex-row md:items-center md:justify-between gap-3" style="background:rgba(242,155,48,.09);border:1px solid rgba(242,155,48,.35);">
            <div>
                <h2 class="text-xl font-bold mb-1" style="color:var(--heading-color);">Cooking for two instead of six?</h2>
                <p style="color:var(--text-color);">Open any recipe and change the servings inside the ingredient card. The cups, cans, and tablespoons update before dinner turns into a fraction worksheet.</p>
            </div>
            <span class="shrink-0 rounded-full px-4 py-2 text-sm font-bold text-white" style="background:#F29B30;">All {articles.length} recipes scale</span>
        </aside>

        <div
            id="articles-grid"
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12"
        >
            {
                articles.map((article: any, i: number) => (
                    <div
                        class="article-item"
                        data-index={i}
                        style={i >= BATCH_SIZE ? "display:none" : ""}
                    >
                        <ArticleCard
                            title={article.data.title}
                            excerpt={article.data.excerpt}
                            image={article.data.image}
                            imageAlt={article.data.imageAlt}
                            category={article.data.category}
                            slug={article.id}
                            date={article.data.date}
                            fillHeight={true}
                        />
                    </div>
                ))
            }
        </div>

        {
            articles.length === 0 && (
                <div class="text-center py-12">
                    <p class="text-lg" style="color: var(--label-color);">
                        No recipes found yet. Check back soon!
                    </p>
                </div>
            )
        }

        <div id="load-sentinel" class="h-4"></div>
        <div
            id="loading-spinner"
            class="hidden text-center py-6 text-sm"
            style="color: var(--muted-color);"
        >
            Loading more...
        </div>
    </div>
    <Footer />
</BaseLayout>

<!-- Infinite scroll handled by shared script in BaseLayout -->
