---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import DataProvenance from "../../../components/DataProvenance.astro";

const title = "Weekly Fiber and Protein Cost Planner: Build a Real Food Week";
const description = "Build a 7-day fiber or protein plan from 10 published menus. Change people and days to get food quantities, cost, and restaurant savings.";

const faqs = [
  ["What does the weekly food cost planner calculate?", "It scales one of our 10 published daily menus by the number of people and days you choose, then totals the tracked food, grams, and consumed cost."],
  ["Are these complete meal plans?", "No. They price the foods carrying roughly 30 grams of fiber or 50 grams of protein in each study day. Drinks, seasonings, calories, and the rest of your plate may add cost."],
  ["Where do the food prices come from?", "The grocery prices come from our July 2026 published datasets, matched to USDA FoodData Central nutrition values. Restaurant prices are the recorded orders in each study."],
  ["Why is checkout cost different from consumed cost?", "A 60-gram portion of oats costs only part of a bag, but the register charges for the whole bag. This planner shows consumed cost because that is what the study measured."],
  ["Does the planner save my household information?", "No. People, menu choices, and day counts stay in this browser tab. The site records only that the tool was used, not the values you entered."],
];

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "Weekly Fiber and Protein Cost Planner",
    url: "https://www.daily-life-hacks.com/tools/grocery-budget-calculator/",
    description,
    applicationCategory: "LifestyleApplication",
    operatingSystem: "Any",
    browserRequirements: "Requires JavaScript",
    isAccessibleForFree: true,
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    publisher: { "@type": "Organization", name: "Daily Life Hacks", url: "https://www.daily-life-hacks.com" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map(([name, text]) => ({ "@type": "Question", name, acceptedAnswer: { "@type": "Answer", text } })),
  },
];
---

<BaseLayout title={title} description={description} jsonLd={schemas}>
  <Header />
  <main class="max-w-6xl mx-auto px-4 py-10 md:py-16">
    <nav class="text-sm mb-5" aria-label="Breadcrumb">
      <a href="/tools/" class="underline" style="color:#F29B30;">Tools</a>
      <span aria-hidden="true" style="color:var(--muted-color);"> / Weekly food cost planner</span>
    </nav>

    <div class="max-w-4xl mb-8">
      <p class="text-sm font-bold uppercase tracking-widest mb-3" style="color:#F29B30;">10 priced days. Your actual household.</p>
      <h1 class="text-3xl md:text-5xl font-bold mb-4" style="color:var(--heading-color);">Plan the Week Before the Grocery Cart Gets Ideas</h1>
      <p class="text-lg leading-relaxed" style="color:var(--text-color);">
        We already priced five ways to get roughly 30 grams of fiber and five ways to get roughly 50 grams of protein. You shouldn't have to retype every oat and bean like you're applying for a grocery permit. Pick your days, choose how many people are eating, and the planner scales the food, cost, and restaurant comparison.
      </p>
    </div>

    <section id="research-week-planner" class="rounded-2xl p-5 md:p-7 mb-12" style="background:var(--card-bg);border:1px solid var(--border-color);">
      <div class="grid md:grid-cols-[1fr_auto] gap-5 items-end mb-6">
        <div>
          <span class="tool-label mb-2">Which target are we making affordable?</span>
          <div class="inline-flex rounded-xl overflow-hidden" style="border:1px solid var(--border-color);" role="group" aria-label="Choose the tracked food target">
            <button type="button" data-goal="fiber" class="goal-button" aria-pressed="true">About 30g fiber</button>
            <button type="button" data-goal="protein" class="goal-button" aria-pressed="false">About 50g protein</button>
          </div>
        </div>
        <label class="tool-label">Actual people eating<input id="rwp-people" class="tool-input" type="number" min="1" max="20" step="1" value="2" inputmode="numeric" /></label>
      </div>

      <div id="rwp-status" class="rounded-xl p-5 text-center" style="background:var(--page-bg);color:var(--muted-color);">Loading the published menus...</div>

      <div id="rwp-content" class="hidden">
        <div class="flex flex-wrap items-end justify-between gap-3 mb-3">
          <div>
            <h2 class="text-xl md:text-2xl font-bold" style="color:var(--heading-color);">Give each menu a few days to earn its keep</h2>
            <p class="text-sm" style="color:var(--muted-color);">The starter week uses cheap days most often and keeps the restaurant day at zero. Civilization survives.</p>
          </div>
          <p id="rwp-day-count" class="font-bold" style="color:#F29B30;">7 days planned</p>
        </div>

        <div id="rwp-scenarios" class="grid sm:grid-cols-2 lg:grid-cols-5 gap-3 mb-3"></div>
        <p class="text-xs mb-7" style="color:var(--muted-color);">The planner caps the total at seven days. Reduce one menu before adding another. Apparently even a week has a budget.</p>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-7" aria-live="polite">
          <div class="metric highlight"><span>Tracked food cost</span><strong id="rwp-week-cost">$0.00</strong></div>
          <div class="metric"><span>4.33-week estimate</span><strong id="rwp-month-cost">$0.00</strong></div>
          <div class="metric"><span id="rwp-grams-label">Fiber per person / day</span><strong id="rwp-grams">0g</strong></div>
          <div class="metric"><span>Saved vs restaurant days</span><strong id="rwp-savings">$0.00</strong></div>
        </div>

        <div class="grid lg:grid-cols-[1.15fr_.85fr] gap-6 min-w-0">
          <section class="min-w-0">
            <h2 class="text-xl font-bold mb-3" style="color:var(--heading-color);">Your scaled food list</h2>
            <p class="text-sm mb-3" style="color:var(--muted-color);">Quantities are totals for everyone across the days you selected. Package sizes stay package sizes. A 15-ounce can doesn't become a 30-ounce can because four people are hungry.</p>
            <div class="overflow-x-auto rounded-xl" style="border:1px solid var(--border-color);">
              <table class="w-full text-sm" style="min-width:560px;border-collapse:collapse;">
                <thead><tr style="background:var(--page-bg);border-bottom:1px solid var(--border-color);color:var(--heading-color);"><th class="cell text-left">Food</th><th class="cell text-right">Total amount</th><th class="cell text-right">Tracked grams</th><th class="cell text-right">Consumed cost</th></tr></thead>
                <tbody id="rwp-shopping"></tbody>
              </table>
            </div>
          </section>

          <aside class="min-w-0">
            <h2 class="text-xl font-bold mb-3" style="color:var(--heading-color);">What each day contains</h2>
            <div id="rwp-menu-details" class="space-y-3"></div>
          </aside>
        </div>

        <div class="mt-6 rounded-xl p-4 text-sm leading-relaxed" style="background:var(--page-bg);border-left:4px solid #F29B30;color:var(--text-color);">
          <strong>Read this before declaring victory:</strong> this is a cost planner for the foods tracked in our fiber and protein studies, not a complete calorie plan. Oil, sauces, drinks, extra produce, and the food that keeps dinner from looking like a spreadsheet still count.
        </div>
        <p class="mt-4 text-xs" style="color:var(--muted-color);">Your choices stay in this browser tab. Prices are the recorded July 2026 study prices, not a promise about today's shelf in your ZIP code.</p>
      </div>
    </section>

    <div class="mb-12">
      <DataProvenance
        datasets={["fiber-day-cost-2026", "protein-day-cost-2026", "fiber-per-dollar-2026", "protein-per-dollar-2026"]}
        heading="The menus and prices behind this week"
      />
    </div>

    <article class="prose-like max-w-4xl">
      <h2>What can the food-cost planner tell you?</h2>
      <p>It tells you what the tracked part of a week costs when real people replace hypothetical servings. Choose two people and seven days, for example, and every menu row doubles before it gets repeated. The planner then compares that week with the restaurant scenario from the same study. No vague “save more” speech. You get the dollar gap.</p>

      <h2>Why are consumed cost and checkout cost different?</h2>
      <p>Our studies price the amount eaten. If breakfast uses 60 grams from a two-pound bag of oats, only 60 grams count toward consumed cost. The register, being less philosophical, charges for the bag. Use these numbers to compare menu styles and recurring food cost, then leave room in the first week's budget for whole packages.</p>

      <h2>Where do the fiber and protein numbers come from?</h2>
      <p>The menus come directly from our public <a href="/data/fiber-day-cost-2026.csv">fiber day CSV</a> and <a href="/data/protein-day-cost-2026.csv">protein day CSV</a>. The parent rankings use USDA FoodData Central values matched to recorded shelf prices. You can read the full <a href="/what-30-grams-of-fiber-costs-per-day/">30-gram fiber cost study</a>, the <a href="/what-50-grams-of-protein-costs-per-day/">50-gram protein cost study</a>, and our <a href="/methodology/">methodology</a>. The spreadsheet is public because “trust me, I divided correctly” isn't a methodology.</p>

      <h2>How should you use the cheapest days?</h2>
      <p>Use them as a floor, not a personality. The rock-bottom days prove how little the tracked foods can cost. The realistic mixed days are usually easier to repeat. Build a week that fits your stove, schedule, and tolerance for seeing beans again on Thursday. Our <a href="/eat-healthy-on-a-budget-complete-playbook/">budget eating playbook</a> handles the broader grocery strategy.</p>

      <h2>Frequently asked questions</h2>
      <div class="faq-list">
        {faqs.map(([question, answer]) => <details><summary>{question}</summary><p>{answer}</p></details>)}
      </div>
    </article>
  </main>
  <Footer />

  <style>
    .tool-label{display:flex;flex-direction:column;gap:.4rem;font-size:.875rem;font-weight:700;color:var(--text-color)}.tool-input{width:7rem;border-radius:.75rem;padding:.65rem .75rem;background:var(--page-bg);border:1px solid var(--border-color);color:var(--text-color);outline:none}.tool-input:focus{box-shadow:0 0 0 2px #F29B30}.goal-button{padding:.7rem 1rem;font-size:.875rem;font-weight:800;background:var(--card-bg);color:var(--text-color)}.goal-button[aria-pressed="true"]{background:#F29B30;color:white}.scenario{padding:1rem;border-radius:.9rem;background:var(--page-bg);border:1px solid var(--border-color)}.day-input{width:3rem;border-radius:.6rem;padding:.45rem;background:var(--card-bg);border:1px solid var(--border-color);color:var(--heading-color);font-weight:800;text-align:center}.metric{display:flex;flex-direction:column;gap:.25rem;padding:1rem;border-radius:.8rem;background:var(--page-bg);border:1px solid var(--border-color);color:var(--muted-color);font-size:.78rem}.metric strong{font-size:1.35rem;color:var(--heading-color)}.metric.highlight{border:2px solid #F29B30;background:rgba(242,155,48,.09)}.metric.highlight strong{color:#F29B30}.cell{padding:.65rem}.menu-card{padding:1rem;border-radius:.8rem;background:var(--page-bg);border:1px solid var(--border-color)}.prose-like h2{font-size:1.65rem;line-height:1.2;font-weight:800;margin:2.25rem 0 .7rem;color:var(--heading-color)}.prose-like p{line-height:1.75;margin:.7rem 0;color:var(--text-color)}.prose-like a{color:#F29B30;text-decoration:underline;font-weight:700}.faq-list details{margin:.65rem 0;border:1px solid var(--border-color);border-radius:.75rem;background:var(--card-bg);padding:0 1rem}.faq-list summary{cursor:pointer;font-weight:800;padding:1rem 0;color:var(--heading-color)}.faq-list p{margin:0 0 1rem}
  </style>

  <script is:inline>
    (function(){
      var sources={fiber:{url:'/data/fiber-day-cost-2026.csv',grams:'fiber_g',label:'Fiber',target:30},protein:{url:'/data/protein-day-cost-2026.csv',grams:'protein_g',label:'Protein',target:50}};
      var defaults=[2,1,0,0,4];
      function parseCSV(text){var rows=[],row=[],field='',quoted=false;for(var i=0;i<text.length;i++){var c=text[i];if(quoted){if(c==='"'){if(text[i+1]==='"'){field+='"';i++}else quoted=false}else field+=c}else if(c==='"')quoted=true;else if(c===','){row.push(field);field=''}else if(c==='\n'){row.push(field);field='';if(row.join(''))rows.push(row);row=[]}else if(c!=='\r')field+=c}if(field||row.length){row.push(field);if(row.join(''))rows.push(row)}return rows}
      function records(text){var grid=parseCSV(text),headers=grid.shift();return grid.map(function(row){var item={};headers.forEach(function(key,i){item[key]=row[i]||''});return item})}
      function esc(value){return String(value).replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]})}
      function money(value){return '$'+(isFinite(value)?value:0).toFixed(2)}
      function canonical(row){return (row.basis||'').replace(/^parent CSV:\s*/i,'').trim()||row.food.replace(/,.*$/,'')}
      function group(rows,goal){var by={};rows.forEach(function(row){if(!by[row.day])by[row.day]={name:row.day,rows:[],cost:0,grams:0};by[row.day].rows.push(row);by[row.day].cost+=Number(row.cost_usd)||0;by[row.day].grams+=Number(row[sources[goal].grams])||0});return Object.keys(by).map(function(key){return by[key]})}
      function shortName(name){return name.replace(/^Day \d+:\s*/,'')}
      function boot(){var root=document.getElementById('research-week-planner');if(!root||root.dataset.booted)return;root.dataset.booted='1';var state={goal:'fiber',menus:[],days:defaults.slice()};
        function load(){root.querySelector('#rwp-status').classList.remove('hidden');root.querySelector('#rwp-content').classList.add('hidden');fetch(sources[state.goal].url,{cache:'no-cache'}).then(function(res){if(!res.ok)throw new Error('HTTP '+res.status);return res.text()}).then(function(text){state.menus=group(records(text),state.goal);state.days=defaults.slice();root.querySelector('#rwp-status').classList.add('hidden');root.querySelector('#rwp-content').classList.remove('hidden');renderScenarios();render()}).catch(function(){root.querySelector('#rwp-status').textContent='The study file did not load. Refresh the page and the beans will try again.'})}
        function renderScenarios(){root.querySelector('#rwp-scenarios').innerHTML=state.menus.map(function(menu,index){return '<div class="scenario"><p class="text-xs font-bold uppercase tracking-wide mb-1" style="color:#F29B30;">'+esc(shortName(menu.name))+'</p><p class="text-sm mb-3" style="color:var(--muted-color);">'+menu.grams.toFixed(1)+'g '+sources[state.goal].label.toLowerCase()+' for '+money(menu.cost)+'</p><label class="tool-label">Days this week<input class="day-input" data-plan-days="'+index+'" type="number" min="0" max="7" step="1" value="'+state.days[index]+'" inputmode="numeric"></label></div>'}).join('')}
        function render(){var people=Math.max(1,Math.min(20,Math.round(Number(root.querySelector('#rwp-people').value)||1))),planned=0,totalCost=0,totalGrams=0,shopping={},restaurant=state.menus.find(function(menu){return /restaurant/i.test(menu.name)});state.menus.forEach(function(menu,index){var days=Math.max(0,Math.min(7,Math.round(Number(state.days[index])||0)));state.days[index]=days;planned+=days;totalCost+=menu.cost*days*people;totalGrams+=menu.grams*days*people;if(!days)return;menu.rows.forEach(function(row){var key=canonical(row);if(!shopping[key])shopping[key]={food:key,grams:0,nutrient:0,cost:0};shopping[key].grams+=(Number(row.grams_used)||0)*days*people;shopping[key].nutrient+=(Number(row[sources[state.goal].grams])||0)*days*people;shopping[key].cost+=(Number(row.cost_usd)||0)*days*people})});var restaurantCost=restaurant?restaurant.cost*planned*people:0,savings=Math.max(0,restaurantCost-totalCost),average=planned&&people?totalGrams/planned/people:0;root.querySelector('#rwp-day-count').textContent=planned===7?'7 days planned':planned+' day'+(planned===1?'':'s')+' planned, '+(7-planned)+' left';root.querySelector('#rwp-week-cost').textContent=money(totalCost);root.querySelector('#rwp-month-cost').textContent=planned===7?money(totalCost*4.33):'Add '+(7-planned)+' day'+(7-planned===1?'':'s');root.querySelector('#rwp-grams-label').textContent=sources[state.goal].label+' per person / day';root.querySelector('#rwp-grams').textContent=average.toFixed(1)+'g';root.querySelector('#rwp-savings').textContent=money(savings);root.querySelector('#rwp-shopping').innerHTML=Object.keys(shopping).sort(function(a,b){return shopping[b].cost-shopping[a].cost}).map(function(key){var item=shopping[key];return '<tr style="border-bottom:1px solid var(--border-color);"><td class="cell font-semibold" style="color:var(--heading-color);">'+esc(item.food)+'</td><td class="cell text-right" style="color:var(--text-color);">'+Math.round(item.grams)+'g</td><td class="cell text-right" style="color:var(--text-color);">'+item.nutrient.toFixed(1)+'g</td><td class="cell text-right font-bold" style="color:var(--heading-color);">'+money(item.cost)+'</td></tr>'}).join('')||'<tr><td colspan="4" class="cell text-center" style="color:var(--muted-color);">Choose at least one day. Right now the meal plan is fresh air.</td></tr>';root.querySelector('#rwp-menu-details').innerHTML=state.menus.map(function(menu,index){if(!state.days[index])return '';return '<div class="menu-card"><div class="flex justify-between gap-3 mb-2"><strong style="color:var(--heading-color);">'+esc(shortName(menu.name))+'</strong><span class="text-sm" style="color:#F29B30;">'+state.days[index]+' day'+(state.days[index]===1?'':'s')+'</span></div><ul class="text-sm space-y-1" style="color:var(--muted-color);">'+menu.rows.map(function(row){return '<li>'+esc(row.meal)+': '+esc(row.food)+'</li>'}).join('')+'</ul></div>'}).join('')}
        root.addEventListener('input',function(event){var input=event.target.closest('[data-plan-days]');if(input){var index=Number(input.dataset.planDays),others=state.days.reduce(function(sum,value,i){return sum+(i===index?0:(Number(value)||0))},0),allowed=Math.max(0,7-others),next=Math.max(0,Math.min(allowed,Math.round(Number(input.value)||0)));state.days[index]=next;input.value=String(next)}render()});root.querySelectorAll('[data-goal]').forEach(function(button){button.addEventListener('click',function(){if(button.dataset.goal===state.goal)return;state.goal=button.dataset.goal;root.querySelectorAll('[data-goal]').forEach(function(item){item.setAttribute('aria-pressed',item===button?'true':'false')});load()})});load()}
      boot();document.addEventListener('astro:page-load',boot);
    })();
  </script>
</BaseLayout>
