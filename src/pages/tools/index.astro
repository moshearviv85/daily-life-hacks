---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const title = "Free Grocery and Recipe Tools Built From Real Site Data";
const description = "Find recipes from ingredients, combine shopping lists, scale 80 recipes, plan a food-cost week, and check prices. Free and private.";

const tools = [
  { href: "/tools/recipe-finder/", eyebrow: "Searches 80 real recipes", visual: "Use it", title: "You've Got Ingredients. Let's Find Dinner.", text: "Tell us what's in the kitchen. We'll rank the closest recipes and show the groceries you're still missing, because half an onion isn't a plan.", tier: "featured" },
  { href: "/tools/shopping-list-builder/", eyebrow: "Several recipes, one list", visual: "1 list", title: "Make One Shopping List, Not Five", text: "Pick the recipes and set the servings. We'll combine the sensible matches and leave the questionable cilantro arithmetic alone.", tier: "featured" },
  { href: "/tools/grocery-budget-calculator/", eyebrow: "Built from 10 priced menus", visual: "7 days", title: "Plan the Week Before the Cart Gets Ideas", text: "Choose fiber or protein, assign the priced menus across seven days, and see the food, cost, and restaurant gap for your actual household.", tier: "featured" },
  { href: "/tools/fiber-per-dollar-calculator/", eyebrow: "53 fiber + 49 protein rows", visual: "$1 = ?", title: "Make Every Grocery Dollar Show Its Work", text: "Compare the published rankings, set a weekly target, or build a basket. The beans are cheap. Now you can see exactly how cheap.", tier: "featured" },
  { href: "/recipes/", eyebrow: "Built into 80 recipes", visual: "4 → 7", title: "Scale the Recipe Before Dinner Gets Weird", text: "Change the number of people and the ingredient amounts move with you. No dividing 1/3 cup while someone asks when dinner is ready.", tier: "featured" },
  { href: "/tools/grocery-unit-price-calculator/", eyebrow: "79 foods from two studies", visual: "Good?", title: "Check Whether That Sale Tag Is Mostly Theater", text: "Enter the shelf price and package size, then compare it with our July 2026 snapshot. The yellow sticker doesn't get the final word.", tier: "featured" },
  { href: "/tools/grocery-trip-savings-calculator/", eyebrow: "Gas + fees + optional time", visual: "Worth it?", title: "See Whether the Cheaper Store Is Actually Cheaper", text: "Subtract the extra drive, parking, transit, and time from the basket savings. A distant sale doesn't get free transportation.", tier: "featured" },
  { href: "/tools/recipe-cost-calculator/", eyebrow: "Advanced manual utility", visual: "$ / serving", title: "Find Out What Dinner Actually Cost", text: "Price every ingredient by the amount that reached the pot. It's the detailed option, for days when 'pretty cheap' isn't a number.", tier: "basic" },
];

const schemas = [
  { "@context": "https://schema.org", "@type": "CollectionPage", name: title, url: "https://www.daily-life-hacks.com/tools/", description, isPartOf: { "@type": "WebSite", name: "Daily Life Hacks", url: "https://www.daily-life-hacks.com" }, publisher: { "@type": "Organization", name: "Daily Life Hacks", url: "https://www.daily-life-hacks.com" } },
  { "@context": "https://schema.org", "@type": "ItemList", name: "Daily Life Hacks grocery tools", itemListElement: tools.map((tool, index) => ({ "@type": "ListItem", position: index + 1, name: tool.title, url: `https://www.daily-life-hacks.com${tool.href}` })) },
];
---

<BaseLayout title={title} description={description} jsonLd={schemas}>
  <Header />
  <main class="max-w-6xl mx-auto px-4 py-12 md:py-16">
    <div class="max-w-4xl mb-10">
      <p class="text-sm font-bold uppercase tracking-widest mb-3" style="color:#F29B30;">Our research, turned into decisions.</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-4" style="color:var(--heading-color);">Grocery Tools for the Math Nobody Wants to Do</h1>
      <p class="text-lg leading-relaxed" style="color:var(--text-color);">
        You've got a fridge, a budget, and no reason to rebuild a spreadsheet before dinner. These tools start with our recipes and published price data, then handle the matching, scaling, and grocery math. No signup. No motivational speech from a calculator.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
      {tools.filter((tool) => tool.tier === "featured").map((tool) => (
        <a href={tool.href} class="tool-card group">
          <div class="tool-visual">
            <span class="text-4xl font-extrabold tracking-tight group-hover:scale-105 transition-transform duration-300" style="color:#F29B30;">{tool.visual}</span>
            <span class="text-[11px] font-bold uppercase tracking-widest" style="color:var(--muted-color);">{tool.eyebrow}</span>
            <span class="absolute top-3 right-3 px-2 py-1 text-[10px] font-bold rounded-full uppercase tracking-wider text-white" style="background:#F29B30;">Featured</span>
          </div>
          <div class="p-5 flex-1 flex flex-col gap-2">
            <h2 class="font-bold text-xl leading-tight group-hover:text-[#F29B30] transition-colors" style="color:var(--heading-color);">{tool.title}</h2>
            <p class="text-sm leading-relaxed" style="color:var(--muted-color);">{tool.text}</p>
            <span class="mt-auto pt-2 text-sm font-bold" style="color:#F29B30;">Use the tool <span aria-hidden="true">→</span></span>
          </div>
        </a>
      ))}
    </div>

    <section class="mt-12">
      <h2 class="text-2xl font-bold mb-2" style="color:var(--heading-color);">The detailed calculator, when you actually need it</h2>
      <p class="mb-5 max-w-3xl" style="color:var(--muted-color);">These still solve specific math problems. They just don't get to pretend they're the main event anymore.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {tools.filter((tool) => tool.tier === "basic").map((tool) => (
          <a href={tool.href} class="tool-card group">
            <div class="tool-visual">
              <span class="text-4xl font-extrabold tracking-tight group-hover:scale-105 transition-transform duration-300" style="color:#F29B30;">{tool.visual}</span>
              <span class="text-[11px] font-bold uppercase tracking-widest" style="color:var(--muted-color);">{tool.eyebrow}</span>
            </div>
            <div class="p-5 flex-1 flex flex-col gap-2">
              <h3 class="font-bold text-xl leading-tight group-hover:text-[#F29B30] transition-colors" style="color:var(--heading-color);">{tool.title}</h3>
              <p class="text-sm leading-relaxed" style="color:var(--muted-color);">{tool.text}</p>
              <span class="mt-auto pt-2 text-sm font-bold" style="color:#F29B30;">Open tool <span aria-hidden="true">→</span></span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="mt-14 grid md:grid-cols-3 gap-5">
      <div class="promise"><strong>Nothing leaves your browser</strong><p>Household size, recipe servings, prices, and baskets stay on your device. The tools don't need an account because division has managed without one for centuries.</p></div>
      <div class="promise"><strong>The formulas are visible</strong><p>You can see how every answer is calculated and where the study data came from. No mystery score or “trust us” math.</p></div>
      <div class="promise"><strong>The main tools start with real data</strong><p>Ten priced menus, 102 ranked entries across two studies, and 80 recipes are already loaded. You change the decision, not rebuild the dataset.</p></div>
    </section>

    <section class="max-w-4xl mt-14">
      <h2 class="text-2xl md:text-3xl font-bold mb-4" style="color:var(--heading-color);">Start with the decision in front of you</h2>
      <p class="leading-relaxed mb-4" style="color:var(--text-color);">Staring at a fridge with no plan? Start with the recipe finder. Planning several dinners? Build one shopping list and set the servings before you shop. Comparing oats, eggs, beans, or yogurt? Use the value planner or the grocery price checker.</p>
      <p class="leading-relaxed" style="color:var(--text-color);">The tools handle the numbers. Our <a href="/eat-healthy-on-a-budget-complete-playbook/" class="text-link">healthy eating on a budget playbook</a> handles the strategy, and the <a href="/methodology/" class="text-link">methodology page</a> explains how we verify the prices and nutrition data used in published studies.</p>
    </section>
  </main>
  <Footer />

  <style>
    .tool-card{overflow:hidden;border-radius:1rem;display:flex;flex-direction:column;background:var(--card-bg);border:1px solid var(--border-color);transition:transform .2s,box-shadow .2s}.tool-card:hover{transform:translateY(-2px);box-shadow:0 12px 30px rgba(15,23,42,.10)}.tool-visual{position:relative;aspect-ratio:16/8;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.3rem;background:rgba(242,155,48,.08)}.promise{padding:1.25rem;border-radius:.9rem;background:var(--card-bg);border:1px solid var(--border-color)}.promise strong{display:block;margin-bottom:.5rem;color:var(--heading-color)}.promise p{font-size:.9rem;line-height:1.65;color:var(--muted-color)}.text-link{color:#F29B30;text-decoration:underline;font-weight:600}
  </style>
</BaseLayout>
