---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "About | Daily Life Hacks";
const description = "Who's behind Daily Life Hacks. No drama, no miracle stories. Just practical food and a guy who's done with 14-step recipes.";

const aboutSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'About Daily Life Hacks',
    url: 'https://www.daily-life-hacks.com/about',
    description,
    isPartOf: {
      '@type': 'WebSite',
      name: 'Daily Life Hacks',
      url: 'https://www.daily-life-hacks.com',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Daily Life Hacks',
    url: 'https://www.daily-life-hacks.com',
    logo: 'https://www.daily-life-hacks.com/logo.png',
    description: 'Practical nutrition tips, easy healthy recipes, and kitchen hacks for everyday life.',
    sameAs: [
      'https://www.pinterest.com/DavidMiller615/',
    ],
    founder: {
      '@type': 'Person',
      name: 'David Miller',
      url: 'https://www.daily-life-hacks.com/about',
      jobTitle: 'Founder',
      knowsAbout: ['Nutrition', 'Healthy Recipes', 'Meal Prep', 'Kitchen Tips'],
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'David Miller',
    url: 'https://www.daily-life-hacks.com/about',
    jobTitle: 'Founder',
    worksFor: {
      '@type': 'Organization',
      name: 'Daily Life Hacks',
      url: 'https://www.daily-life-hacks.com',
    },
    knowsAbout: ['Nutrition', 'Healthy Recipes', 'Meal Prep', 'Kitchen Tips'],
    description: 'Founder of Daily Life Hacks. Writes about practical nutrition and simple recipes for busy people.',
  },
];
---

<BaseLayout title={title} description={description} jsonLd={aboutSchema}>
  <Header />
  <main class="max-w-3xl mx-auto px-4 py-12 md:py-16">
    <h1 class="text-4xl md:text-5xl font-bold mb-8" style="color: var(--heading-color);">
      About Daily Life Hacks
    </h1>

    <div class="article-content space-y-6 text-lg" style="color: var(--text-color);">
      <p>
        Hi, I'm David Miller.
      </p>
      <p>
        I started Daily Life Hacks because I was hungry, annoyed, and very done with recipes that need three bowls, two appliances, and an ingredient you can only find in aisle 17½.
      </p>
      <p>
        Cooking at home is already a small project. It doesn't also need a spiritual journey. And for the record, I'm not here to change your life with chia pudding.
      </p>

      <h2 class="text-2xl font-bold mt-10 mb-4" style="color: var(--heading-color);">What you'll find here</h2>
      <ul class="list-disc pl-6 space-y-2">
        <li>Simple recipes you can actually repeat on a weekday without bargaining with your sanity.</li>
        <li>Nutrition posts that speak human, not lab report. Just enough info so you know what to toss in the cart without overthinking it.</li>
        <li>Practical fixes for everyday kitchen annoyances: leftovers, storage, "what do I do with this", not avocado swans.</li>
      </ul>

      <h2 class="text-2xl font-bold mt-10 mb-4" style="color: var(--heading-color);">What you won't find</h2>
      <ul class="list-disc pl-6 space-y-2">
        <li>Forty-step recipes that assume you "chill overnight" while you're already starving.</li>
        <li>Perfect meal plans for people who apparently never eat the same thing twice.</li>
        <li>Food guilt, lectures, or "if you really cared…" speeches. Life is busy. You don't need a side of judgment with dinner.</li>
      </ul>

      <h2 class="text-2xl font-bold mt-10 mb-4" style="color: var(--heading-color);">Who this site is for</h2>
      <p>
        If you want real food, minimal drama, and zero spreadsheets, you're my people. You like learning small, useful things that make cooking less annoying, not turning your life into a wellness TED Talk.
      </p>
      <p>
        Come hang out in the <a href="/recipes/1" class="underline" style="color: #A56A22;">recipes</a>, <a href="/nutrition/1" class="underline" style="color: #A56A22;">nutrition</a>, and <a href="/tips/1" class="underline" style="color: #A56A22;">tips</a> sections, or <a href="/#newsletter" class="underline" style="color: #A56A22;">join the newsletter</a> and get the new stuff before it even hits the site.
      </p>

      <p class="mt-10">If you made it this far, you have more patience than I do.</p>
      <p class="font-semibold text-xl" style="color: var(--heading-color);">David Miller</p>
    </div>
  </main>
  <Footer />
</BaseLayout>
