---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "About | Daily Life Hacks";
const description = "Who's behind Daily Life Hacks. No drama, no miracle stories. Just practical food and a guy who's done with 14-step recipes.";

const aboutSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'About Daily Life Hacks',
    url: 'https://www.daily-life-hacks.com/about/',
    description,
    mainEntity: {
      '@id': 'https://www.daily-life-hacks.com/about/#david-miller',
    },
    isPartOf: {
      '@type': 'WebSite',
      name: 'Daily Life Hacks',
      url: 'https://www.daily-life-hacks.com',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': 'https://www.daily-life-hacks.com/#organization',
    name: 'Daily Life Hacks',
    url: 'https://www.daily-life-hacks.com',
    logo: 'https://www.daily-life-hacks.com/logo.png',
    description: 'Audited grocery cost research, practical recipes, and interactive food tools built from public data and real shelf prices.',
    sameAs: [
      'https://www.pinterest.com/DavidMiller615/',
    ],
    founder: {
      '@type': 'Person',
      '@id': 'https://www.daily-life-hacks.com/about/#david-miller',
      name: 'David Miller',
      url: 'https://www.daily-life-hacks.com/about/',
      jobTitle: 'Founder',
      knowsAbout: ['Grocery Cost Research', 'USDA Food Data', 'Budget Cooking', 'Meal Prep'],
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': 'https://www.daily-life-hacks.com/about/#david-miller',
    name: 'David Miller',
    url: 'https://www.daily-life-hacks.com/about/',
    jobTitle: 'Founder',
    worksFor: {
      '@type': 'Organization',
      '@id': 'https://www.daily-life-hacks.com/#organization',
      name: 'Daily Life Hacks',
      url: 'https://www.daily-life-hacks.com',
    },
    knowsAbout: ['Grocery Cost Research', 'USDA Food Data', 'Budget Cooking', 'Meal Prep'],
    description: 'Founder and editor of Daily Life Hacks. Publishes grocery cost studies, practical recipes, and food tools with public source data. He is not a chef, registered dietitian, or medical professional.',
  },
];
---

<BaseLayout title={title} description={description} jsonLd={aboutSchema}>
  <Header />
  <main class="max-w-3xl mx-auto px-4 py-12 md:py-16">
    <h1 class="text-4xl md:text-5xl font-bold mb-8" style="color: var(--heading-color);">
      About Daily Life Hacks
    </h1>

    <div class="article-content space-y-6 text-lg" style="color: var(--text-color);">
      <p>
        Hi, I'm David Miller.
      </p>
      <p>
        I started Daily Life Hacks because I was hungry, annoyed, and very done with recipes that need three bowls, two appliances, and an ingredient you can only find in aisle 17½.
      </p>
      <p>
        Cooking at home is already a small project. It doesn't also need a spiritual journey. And for the record, I'm not here to change your life with chia pudding.
      </p>

      <h2 class="text-2xl font-bold mt-10 mb-4" style="color: var(--heading-color);">What you'll find here</h2>
      <ul class="list-disc pl-6 space-y-2">
        <li>Simple recipes you can actually repeat on a weekday without bargaining with your sanity.</li>
        <li>Grocery cost studies that publish the numbers, the source files, and the part where beans embarrass half the store.</li>
        <li>Nutrition posts that speak human, not lab report. Just enough information to understand the number without adopting a spreadsheet as a pet.</li>
        <li>Practical fixes for everyday kitchen annoyances: leftovers, storage, "what do I do with this", not avocado swans.</li>
      </ul>

      <h2 class="text-2xl font-bold mt-10 mb-4" style="color: var(--heading-color);">What you won't find</h2>
      <ul class="list-disc pl-6 space-y-2">
        <li>Forty-step recipes that assume you "chill overnight" while you're already starving.</li>
        <li>Perfect meal plans for people who apparently never eat the same thing twice.</li>
        <li>Food guilt, lectures, or "if you really cared…" speeches. Life is busy. You don't need a side of judgment with dinner.</li>
      </ul>

      <h2 class="text-2xl font-bold mt-10 mb-4" style="color: var(--heading-color);">Who this site is for</h2>
      <p>
        If you want real food, minimal drama, and spreadsheets you don't have to build yourself, you're my people. You like useful numbers that make shopping and cooking less annoying, not turning your life into a wellness TED Talk.
      </p>

      <h2 class="text-2xl font-bold mt-10 mb-4" style="color: var(--heading-color);">Who writes and checks this</h2>
      <p>
        I write and edit Daily Life Hacks. I'm not a chef, registered dietitian, or medical professional, and I won't borrow one of those titles because it looks good under a headshot. For nutrition numbers, I go back to primary sources such as USDA FoodData Central, FDA guidance, and Bureau of Labor Statistics price data. For original cost studies, I publish the calculation rows and the price basis so you can inspect the work instead of taking my word for it.
      </p>
      <p>
        The <a href="/methodology/" class="underline" style="color: #F29B30;">research methodology</a> explains the source hierarchy, calculation rules, limitations, refresh schedule, and correction policy. If a claim needs clinical interpretation or personal medical advice, this site isn't the final stop. That's a job for a qualified healthcare professional who knows you, not a guy with a grocery spreadsheet.
      </p>

      <h2 class="text-2xl font-bold mt-10 mb-4" style="color: var(--heading-color);">Corrections and source questions</h2>
      <p>
        When a published study changes, the affected article gets a dated correction note. If you spot a bad number, a broken source, or a claim that reaches farther than the evidence, <a href="/contact/" class="underline" style="color: #F29B30;">send it in</a>. Specific complaints are useful. "The internet disagrees" gives the spreadsheet less to work with.
      </p>
      <p>
        Start with the <a href="/research/" class="underline" style="color: #F29B30;">original research</a>, check <a href="/methodology/" class="underline" style="color: #F29B30;">how we verify the math</a>, or head to the <a href="/recipes/" class="underline" style="color: #F29B30;">recipes</a> when dinner is the more urgent problem. You can also <a href="/#newsletter" class="underline" style="color: #F29B30;">join the newsletter</a> and get the new stuff before it hits the site.
      </p>

      <p class="mt-10">If you made it this far, you have more patience than I do.</p>
      <p class="font-semibold text-xl" style="color: var(--heading-color);">David Miller</p>
    </div>
  </main>
  <Footer />
</BaseLayout>
