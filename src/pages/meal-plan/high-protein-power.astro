  {
    day: "Thursday", label: "Day 4",
    meals: [
      { label: "Breakfast", name: "Protein pancakes", detail: "1 scoop vanilla protein powder, 1/2 cup oats, 2 eggs, 1/2 mashed banana — blend and cook as 3 pancakes. Top with 1/2 cup Greek yogurt and berries.", cal: 480, protein: "40g" },
      { label: "Snack", name: "Beef jerky and almonds", detail: "1.5 oz low-sodium beef jerky, 15 almonds", cal: 245, protein: "22g" },
      { label: "Lunch", name: "Grilled chicken Caesar wrap", detail: "5 oz grilled chicken breast, 2 cups romaine lettuce, 1 tbsp light Caesar dressing, 1 tbsp Parmesan — in 1 whole wheat tortilla", cal: 490, protein: "46g" },
