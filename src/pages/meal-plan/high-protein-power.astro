      { label: "Lunch", name: "Tuna and white bean bowl", detail: "2 cans (5 oz each) tuna in water, 1/2 cup white beans, 2 cups arugula, cherry tomatoes, lemon-olive oil dressing, fresh parsley", cal: 510, protein: "60g" },
