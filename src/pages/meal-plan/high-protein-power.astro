      { label: "Lunch", name: "Lean beef and vegetable stir-fry", detail: "5 oz lean ground beef, 2 cups mixed vegetables (broccoli, snap peas, carrots), low-sodium soy sauce, ginger, garlic + 1/2 cup brown rice", cal: 560, protein: "44g" },
      { label: "Snack", name: "Protein smoothie", detail: "1 scoop chocolate protein powder, 1 cup almond milk, 1/2 cup spinach, 1 tbsp peanut butter, ice — blended", cal: 280, protein: "30g" },
      { label: "Dinner", name: "Baked cod with white beans and greens", detail: "7 oz baked cod fillet with herbs and lemon, 1/2 cup white beans, 2 cups sauteed Swiss chard with garlic", cal: 510, protein: "58g" },
    ],
    total: "~2,060", protein: "190g", tip: "Saturday social pressure is real. Choose protein-first at any restaurant and you'll stay on track."
  },
  {
    day: "Sunday", label: "Day 7",
    meals: [
      { label: "Breakfast", name: "Egg and turkey hash", detail: "2 eggs over easy, 2 oz turkey sausage, 1/2 cup diced sweet potato sauteed with onion and bell pepper, paprika and cumin", cal: 450, protein: "32g" },
