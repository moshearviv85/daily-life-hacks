const shoppingList = {
  "Protein": [
    "Chicken breast — 2.5 lbs",
    "Chicken thighs (boneless) — 1 lb",
    "Lean sirloin steak — 6 oz",
    "Turkey tenderloin — 1 lb",
    "Ground turkey (93% lean) — 1.5 lbs",
