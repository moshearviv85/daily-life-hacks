    "Eggs — 2 dozen",
    "Low-fat string cheese — 2 packs",
    "Canned white beans — 2 cans",
    "Black beans — 1 can",
    "Green lentils — 1 lb",
    "Chickpeas — 1 can",
    "Kidney beans — 1 can",
    "Edamame (shelled, frozen) — 1 bag",
    "Low-sodium beef jerky — 2 oz",
  ],
  "Produce & Fresh": [
    "Baby spinach — 1 large bag (10 oz)",
    "Mixed salad greens — 1 bag",
    "Romaine lettuce — 1 head",
    "Kale — 1 bunch", "Swiss chard — 1 bunch",
    "Arugula — 1 bag",
    "2 cups broccoli", "1 head cauliflower",
    "1 cup asparagus", "2 medium zucchini",
    "2 medium bell peppers", "Cherry tomatoes",
    "2 medium sweet potatoes",
    "2 cups mixed vegetables (snap peas, carrots, mushrooms)",
    "1 cup raspberries", "1/2 cup mixed berries",
    "1 frozen banana", "1 medium banana", "1/2 cup blueberries",
    "1/2 cup pineapple",
    "3 lemons", "Fresh garlic", "Fresh dill", "Fresh herbs",
    "1 cucumber", "1 red onion",
  ],
  "Pantry & Extras": [
    "Rolled oats — 1 lb",
    "Quinoa — 1 lb",
    "Brown rice — 1 lb",
    "Whole wheat tortillas — 1 pack",
    "Whole grain bread — 1 loaf",
    "Whole grain crispbreads — 1 pack",
    "High-protein granola — 1 bag",
    "Unsweetened almond milk — 2 quarts",
    "Low-fat milk — 1 quart",
    "Almond butter — 1 jar",
    "Peanut butter — 1 jar",
    "Tahini — 1 small jar",
    "Hummus — 1 container",
    "Almonds — 1 small bag",
    "Walnuts — 1 small bag",
    "Chia seeds", "Cream cheese (low-fat)",
    "Parmesan (shredded)", "Mozzarella (1 oz)",
    "Light Caesar dressing",
    "Low-sodium soy sauce", "Olive oil",
    "Everything bagel seasoning",
    "Spices: cumin, chili powder, turmeric, paprika, Italian herbs",
  ],
};
---

<BaseLayout title={title} description={description}>
  <Header />

  <style>
    .meal-row:nth-child(even) { background-color: var(--input-bg); }
    .day-card {
      border: 1px solid var(--border-color);
      background-color: var(--card-bg);
      border-radius: 1rem;
      overflow: hidden;
      margin-bottom: 2rem;
    }
    .day-header {
      background: linear-gradient(135deg, #3730a3, #1e1b4b);
      color: white;
      padding: 1rem 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .tip-box {
      background-color: #e0e7ff;
      color: #3730a3;
      border-left: 4px solid #4338ca;
      padding: 0.75rem 1rem;
      font-size: 0.85rem;
      line-height: 1.5;
    }
    html.dark .tip-box { background-color: #1e1b4b; color: #a5b4fc; }
    .label-col {
      color: #4338ca; font-weight: 700; font-size: 0.75rem;
      text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap;
    }

    @media print {
      .no-print { display: none !important; }
      body { background: white !important; color: #111 !important; }
      .day-card { break-inside: avoid; border: 1px solid #c7d2fe !important; background: white !important; }
      .tip-box { background: #eef2ff !important; color: #3730a3 !important; }
      header, footer, .Header, .Footer { display: none !important; }
      main { padding: 0 !important; max-width: 100% !important; }
      .print-header { display: block !important; }
      a { text-decoration: none !important; color: inherit !important; }
    }
    .print-header { display: none; }
  </style>

  <main class="max-w-4xl mx-auto px-4 py-10 md:py-14">

    <div class="print-header mb-8 pb-4" style="border-bottom: 2px solid #4338ca;">
      <div style="display:flex; justify-content:space-between; align-items:center;">
        <div>
          <p style="color:#4338ca; font-weight:700; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.1em;">Daily Life Hacks</p>
          <h1 style="font-size:1.5rem; font-weight:900; color:#111;">7-Day High-Protein Power Meal Plan</h1>
        </div>
        <p style="font-size:0.75rem; color:#6b7280;">daily-life-hacks.com/meal-plan/high-protein-power</p>
      </div>
    </div>

    <div class="no-print mb-10">
      <a href="/free-meal-plan" class="inline-flex items-center gap-1.5 text-sm font-medium mb-6" style="color: var(--muted-color);">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        All meal plans
      </a>
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
        <div>
          <span class="inline-block text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-3" style="background-color: #e0e7ff; color: #3730a3;">High Protein</span>
          <h1 class="text-3xl md:text-4xl font-black tracking-tight mb-3" style="color: var(--heading-color);">7-Day High-Protein Power</h1>
          <p class="text-base max-w-xl" style="color: var(--muted-color); line-height: 1.7;">
            150–180g+ protein every day. Built for people who train, maintain muscle, or just want to feel fuller longer.
            Real food, big portions, serious results.
          </p>
        </div>
        <div class="flex flex-col gap-3 flex-shrink-0">
          <button
            onclick="window.print()"
            class="flex items-center justify-center gap-2 rounded-xl px-6 py-3.5 text-sm font-bold text-white"
            style="background-color: #4338ca; box-shadow: 0 4px 14px rgba(67,56,202,0.3);"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            Download PDF
          </button>
          <p class="text-xs text-center" style="color: var(--label-color);">In print dialog, choose "Save as PDF"</p>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8 p-5 rounded-2xl" style="background-color: var(--card-bg); border: 1px solid var(--border-color);">
        {[
          { label: "Daily Calories", value: "~2,000" },
          { label: "Daily Protein", value: "180–210g" },
          { label: "Meals Per Day", value: "5 meals" },
          { label: "Plan Duration", value: "7 days" },
        ].map(stat => (
          <div class="text-center">
            <div class="text-lg font-black" style="color: #4338ca;">{stat.value}</div>
            <div class="text-xs" style="color: var(--muted-color);">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>

    <h2 class="text-xl font-black mb-6" style="color: var(--heading-color);">Your 7-Day Plan</h2>

    {days.map(day => (
      <div class="day-card">
        <div class="day-header">
          <div>
            <span class="text-xs font-bold uppercase tracking-widest opacity-80">{day.label}</span>
            <h3 class="text-lg font-black">{day.day}</h3>
          </div>
          <div class="text-right text-sm">
            <div class="font-bold">{day.total} cal</div>
            <div class="opacity-80 text-xs">Protein: {day.protein}</div>
          </div>
        </div>
        <div class="p-0">
          {day.meals.map((meal, i) => (
            <div class={`meal-row flex gap-4 px-5 py-3.5 ${i < day.meals.length - 1 ? 'border-b' : ''}`} style="border-color: var(--border-color);">
              <div class="label-col w-20 flex-shrink-0 pt-0.5">{meal.label}</div>
              <div class="flex-1">
                <div class="text-sm font-bold" style="color: var(--heading-color);">{meal.name}</div>
                <div class="text-xs mt-0.5" style="color: var(--muted-color);">{meal.detail}</div>
              </div>
              <div class="text-right flex-shrink-0">
                <div class="text-sm font-bold" style="color: var(--heading-color);">{meal.cal}</div>
                <div class="text-xs" style="color: var(--muted-color);">cal</div>
              </div>
            </div>
          ))}
          <div class="tip-box">
            <strong>Tip:</strong> {day.tip}
          </div>
        </div>
      </div>
    ))}

    <!-- Shopping List -->
    <div class="mt-12 mb-10">
      <h2 class="text-xl font-black mb-2" style="color: var(--heading-color);">Weekly Shopping List</h2>
      <p class="text-sm mb-6" style="color: var(--muted-color);">A lot of protein — buy in bulk where possible to save money.</p>

      <div class="grid md:grid-cols-3 gap-6">
        {Object.entries(shoppingList).map(([category, items]) => (
          <div class="rounded-2xl p-5" style="background-color: var(--card-bg); border: 1px solid var(--border-color);">
            <h3 class="text-sm font-bold mb-3 uppercase tracking-wider" style="color: #4338ca;">{category}</h3>
            <ul class="space-y-1.5">
              {items.map(item => (
                <li class="flex items-start gap-2 text-xs" style="color: var(--text-color);">
                  <span class="mt-0.5 w-3 h-3 rounded-sm flex-shrink-0" style="border: 1.5px solid #4338ca;"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="no-print rounded-2xl p-8 text-center" style="background: linear-gradient(135deg, #eef2ff, #e0e7ff); border: 1px solid #c7d2fe;">
      <p class="text-base font-bold mb-2" style="color: #3730a3;">More high-protein content every week.</p>
      <p class="text-sm mb-5" style="color: #4338ca;">Join the Daily Life Hacks newsletter — free.</p>
      <a href="/#newsletter" class="inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-bold text-white" style="background-color: #4338ca;">
        Join free
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>

    <p class="no-print text-xs mt-8 text-center" style="color: var(--label-color);">
      This meal plan is for general informational purposes only. Calorie and protein counts are approximate.
      <a href="/disclaimer" style="text-decoration:underline;">Full disclaimer</a>.
    </p>

  </main>

  <Footer />
</BaseLayout>
