---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const title = "7-Day Gut Health Reset Meal Plan";
const description = "A complete 7-day gut health reset meal plan with high-fiber foods, fermented ingredients, and simple recipes to reduce bloating and improve digestion.";

const days = [
  {
    day: "Monday", label: "Day 1",
    meals: [
      { label: "Breakfast", name: "Greek yogurt parfait", detail: "1 cup low-fat Greek yogurt, 1/2 cup mixed berries, 1 tbsp chia seeds, 1 tbsp honey, 2 tbsp granola", cal: 380, fiber: "8g" },
      { label: "Snack", name: "Apple with almond butter", detail: "1 medium apple, 2 tbsp almond butter", cal: 210, fiber: "5g" },
      { label: "Lunch", name: "Lentil vegetable soup", detail: "1.5 cups red lentil soup with carrots, celery, spinach + 1 slice sourdough bread", cal: 490, fiber: "14g" },
      { label: "Snack", name: "Kefir with banana", detail: "1 cup plain kefir blended with 1 small banana", cal: 200, fiber: "3g" },
      { label: "Dinner", name: "Baked salmon with quinoa", detail: "5 oz baked salmon, 3/4 cup cooked quinoa, 1.5 cups roasted broccoli with olive oil", cal: 580, fiber: "7g" },
    ],
    total: "~1,860", fiber: "37g", tip: "Drink 2 cups of warm water before breakfast to wake up your digestive system."
  },
  {
    day: "Tuesday", label: "Day 2",
    meals: [
      { label: "Breakfast", name: "Overnight oats", detail: "1/2 cup rolled oats, 1 cup kefir, 1 tbsp ground flaxseed, 1/4 cup blueberries, 6 walnut halves", cal: 420, fiber: "9g" },
      { label: "Snack", name: "Celery with hummus", detail: "4 celery stalks, 3 tbsp classic hummus", cal: 130, fiber: "4g" },
      { label: "Lunch", name: "Chickpea spinach wrap", detail: "1 whole wheat tortilla, 1/2 cup roasted chickpeas, 2 cups baby spinach, 2 tbsp tahini, lemon juice", cal: 510, fiber: "12g" },
      { label: "Snack", name: "Mixed nuts", detail: "1 small handful (about 28g) mixed walnuts, almonds, and cashews", cal: 170, fiber: "2g" },
      { label: "Dinner", name: "Turkey meatballs with zucchini noodles", detail: "4 turkey meatballs, 2 medium zucchini spiralized, 1/2 cup marinara sauce with garlic and basil", cal: 540, fiber: "6g" },
    ],
    total: "~1,770", fiber: "33g", tip: "Chew slowly. The gut health journey starts in your mouth."
  },
  {
    day: "Wednesday", label: "Day 3",
    meals: [
      { label: "Breakfast", name: "Chia pudding with mango", detail: "3 tbsp chia seeds soaked overnight in 1 cup almond milk, topped with 1/2 cup diced mango, 2 tbsp coconut flakes", cal: 350, fiber: "11g" },
      { label: "Snack", name: "Walnuts and orange", detail: "12 walnut halves + 1 medium navel orange", cal: 220, fiber: "4g" },
      { label: "Lunch", name: "Quinoa Buddha bowl", detail: "3/4 cup quinoa, 1 cup roasted sweet potato, 1/2 cup chickpeas, 2 cups mixed greens, 2 tbsp tahini dressing", cal: 560, fiber: "13g" },
      { label: "Snack", name: "Cucumber with guacamole", detail: "1 cup sliced cucumbers, 3 tbsp homemade guacamole", cal: 160, fiber: "4g" },
      { label: "Dinner", name: "Grilled chicken with kale", detail: "5 oz grilled chicken thigh, 2 cups sauteed kale with garlic and olive oil, 1 medium baked sweet potato", cal: 590, fiber: "6g" },
    ],
    total: "~1,880", fiber: "38g", tip: "Add a fermented food (kimchi, sauerkraut, or kefir) to at least one meal today."
  },
  {
    day: "Thursday", label: "Day 4",
    meals: [
      { label: "Breakfast", name: "Veggie omelet with toast", detail: "2 eggs scrambled with 1 cup spinach, 1/2 cup mushrooms, 1/4 cup red pepper + 1 slice whole grain toast", cal: 410, fiber: "5g" },
      { label: "Snack", name: "Cottage cheese with pineapple", detail: "3/4 cup low-fat cottage cheese, 1/3 cup fresh pineapple chunks", cal: 200, fiber: "1g" },
      { label: "Lunch", name: "Black bean brown rice bowl", detail: "3/4 cup cooked brown rice, 1/2 cup black beans, 1/4 avocado, 3 tbsp fresh salsa, handful of shredded cabbage", cal: 530, fiber: "14g" },
      { label: "Snack", name: "Carrots with peanut butter", detail: "1 cup baby carrots, 2 tbsp natural peanut butter", cal: 190, fiber: "4g" },
      { label: "Dinner", name: "Shrimp stir-fry with bok choy", detail: "5 oz shrimp, 2 cups bok choy, 1/2 cup snap peas, 3/4 cup cooked brown rice, low-sodium tamari sauce", cal: 510, fiber: "5g" },
    ],
    total: "~1,840", fiber: "29g", tip: "Brown rice is your gut-friendly carb today. The resistant starch feeds good bacteria."
  },
  {
    day: "Friday", label: "Day 5",
    meals: [
      { label: "Breakfast", name: "Whole grain waffle with yogurt", detail: "1 whole grain waffle, 1/2 cup plain Greek yogurt, 1 cup fresh strawberries, drizzle of honey", cal: 390, fiber: "6g" },
      { label: "Snack", name: "Banana with almond butter", detail: "1 small banana, 1 tbsp almond butter", cal: 180, fiber: "3g" },
      { label: "Lunch", name: "Roasted beet and arugula salad", detail: "2 cups arugula, 1/2 cup roasted beets, 1 oz crumbled feta, 2 tbsp balsamic vinaigrette, 2 tbsp pumpkin seeds", cal: 460, fiber: "5g" },
      { label: "Snack", name: "Hard-boiled egg and almonds", detail: "1 hard-boiled egg + 10 raw almonds", cal: 175, fiber: "2g" },
      { label: "Dinner", name: "Baked cod with green beans", detail: "6 oz baked cod with lemon and capers, 2 cups roasted green beans, 1/2 cup cooked farro", cal: 520, fiber: "8g" },
    ],
    total: "~1,725", fiber: "24g", tip: "Lighter fiber day — great after a higher-fiber stretch. Your gut will appreciate the variation."
  },
  {
    day: "Saturday", label: "Day 6",
    meals: [
      { label: "Breakfast", name: "Smoothie bowl", detail: "Blend: 1 frozen banana, 1 cup kefir, 1 cup spinach. Top with 2 tbsp granola, 1 tbsp hemp seeds, 1/4 cup raspberries", cal: 430, fiber: "8g" },
      { label: "Snack", name: "Bell peppers with hummus", detail: "1 cup sliced mixed bell peppers, 3 tbsp hummus", cal: 130, fiber: "4g" },
      { label: "Lunch", name: "Artichoke and white bean salad", detail: "1/2 cup canned artichoke hearts, 1/2 cup white beans, 2 cups mixed greens, cherry tomatoes, lemon-herb dressing", cal: 480, fiber: "13g" },
      { label: "Snack", name: "Kiwi and cashews", detail: "2 kiwi fruits + small handful (20g) raw cashews", cal: 200, fiber: "4g" },
      { label: "Dinner", name: "Lemon herb chicken with cauliflower rice", detail: "5 oz baked lemon-herb chicken thigh, 2 cups cauliflower rice sauteed with garlic, 1 cup steamed asparagus", cal: 550, fiber: "8g" },
    ],
    total: "~1,790", fiber: "37g", tip: "Artichokes are one of the top prebiotic foods. They feed the beneficial bacteria in your gut."
  },
  {
    day: "Sunday", label: "Day 7",
    meals: [
      { label: "Breakfast", name: "Avocado toast with egg", detail: "2 slices whole grain bread, 1/2 medium avocado, 1 fried egg, everything bagel seasoning, red pepper flakes", cal: 420, fiber: "8g" },
      { label: "Snack", name: "Apple and string cheese", detail: "1 small apple + 1 low-fat string cheese", cal: 165, fiber: "4g" },
      { label: "Lunch", name: "Vegetable barley soup", detail: "2 cups barley vegetable soup with carrots, celery, leeks, parsley + 1 slice crusty whole grain bread", cal: 500, fiber: "11g" },
      { label: "Snack", name: "Greek yogurt with honey and seeds", detail: "3/4 cup Greek yogurt, 1 tsp honey, 1 tbsp pumpkin seeds", cal: 185, fiber: "1g" },
      { label: "Dinner", name: "Chicken and lentil stew", detail: "1.5 cups slow-cooked chicken thigh with green lentils, tomatoes, cumin, turmeric, served with 1/2 cup brown rice", cal: 600, fiber: "12g" },
    ],
    total: "~1,870", fiber: "36g", tip: "End the week with meal prep: cook a big batch of lentils and brown rice for next week."
  },
];

const shoppingList = {
  "Produce & Fresh": [
    "Mixed berries (strawberries, blueberries, raspberries) — 2 cups",
    "4 medium apples", "3 bananas", "2 mangoes", "2 kiwis",
    "4 medium avocados", "1 bunch celery", "2 English cucumbers",
    "1 bag baby carrots", "3 cups baby spinach", "1 head kale",
    "2 medium zucchini", "2 cups broccoli", "3 cups bok choy",
    "1 cup snap peas", "1 cup asparagus", "1 cup green beans",
    "1 cup mixed bell peppers", "2 medium beets", "2 cups mushrooms",
    "2 medium sweet potatoes", "1 head cauliflower", "Cherry tomatoes",
    "Fresh garlic (1 bulb)", "2 lemons", "1 navel orange",
    "2 cups arugula", "Mixed salad greens (2 bags)",
  ],
  "Protein": [
    "Plain low-fat Greek yogurt — 32 oz container",
    "Plain kefir — 32 oz container",
    "Low-fat cottage cheese — 1 small container",
    "Ground turkey (93% lean) — 1 lb",
    "Chicken thighs (boneless, skinless) — 2 lbs",
    "Frozen shrimp (peeled) — 1 lb",
    "Cod fillets — 1.5 lbs",
    "Canned chickpeas — 2 cans (15 oz each)",
    "Canned white beans — 1 can (15 oz)",
    "Canned artichoke hearts — 1 can",
    "Canned black beans — 1 can (15 oz)",
    "Red lentils — 1 lb bag",
    "Green lentils — 1 lb bag",
    "Eggs — 1 dozen",
    "Low-fat string cheese — 1 pack",
    "Feta cheese — 1 small block",
  ],
  "Grains & Pantry": [
    "Rolled oats — 1 lb container",
    "Quinoa — 1 lb bag",
    "Brown rice — 2 lb bag",
    "Whole grain bread — 1 loaf",
    "Sourdough bread — 1 loaf",
    "Whole wheat tortillas — 1 pack",
    "Farro — 1 small bag",
    "Barley — 1 small bag",
    "Low-fat granola — 1 bag",
    "Chia seeds — 1 small bag",
    "Ground flaxseed — 1 bag",
    "Hemp seeds — 1 small bag",
    "Pumpkin seeds — 1 small bag",
    "Mixed nuts (almonds, walnuts, cashews)",
    "Natural almond butter — 1 jar",
    "Natural peanut butter — 1 jar",
    "Classic hummus — 1 container",
    "Tahini — 1 jar",
    "Coconut flakes (unsweetened)",
    "Low-sodium tamari or soy sauce",
    "Capers — 1 small jar",
    "Salsa — 1 jar",
    "Balsamic vinegar",
    "Olive oil",
    "Honey",
    "Everything bagel seasoning",
  ],
};
---

<BaseLayout title={title} description={description}>
  <Header />

  <style>
    .meal-row:nth-child(even) {
      background-color: var(--input-bg);
    }
    .day-card {
      border: 1px solid var(--border-color);
      background-color: var(--card-bg);
      border-radius: 1rem;
      overflow: hidden;
      margin-bottom: 2rem;
    }
    .day-header {
      background: linear-gradient(135deg, #059669, #047857);
      color: white;
      padding: 1rem 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .tip-box {
      background-color: #d1fae5;
      color: #065f46;
      border-left: 4px solid #059669;
      padding: 0.75rem 1rem;
      font-size: 0.85rem;
      line-height: 1.5;
    }
    html.dark .tip-box {
      background-color: #064e3b;
      color: #6ee7b7;
    }
    .label-col { color: #059669; font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap; }

    /* ── PRINT STYLES ── */
    @media print {
      .no-print { display: none !important; }
      body { background: white !important; color: #111 !important; }
      .day-card { break-inside: avoid; border: 1px solid #d1fae5 !important; background: white !important; }
      .tip-box { background: #f0fdf4 !important; color: #065f46 !important; }
      header, footer, .Header, .Footer { display: none !important; }
      main { padding: 0 !important; max-width: 100% !important; }
      .print-header { display: block !important; }
      h1 { font-size: 1.8rem !important; }
      a { text-decoration: none !important; color: inherit !important; }
    }
    .print-header { display: none; }
  </style>

  <main class="max-w-4xl mx-auto px-4 py-10 md:py-14">

    <!-- Print-only header -->
    <div class="print-header mb-8 pb-4" style="border-bottom: 2px solid #059669;">
      <div style="display:flex; justify-content:space-between; align-items:center;">
        <div>
          <p style="color:#059669; font-weight:700; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.1em;">Daily Life Hacks</p>
          <h1 style="font-size:1.5rem; font-weight:900; color:#111;">7-Day Gut Health Reset Meal Plan</h1>
        </div>
        <p style="font-size:0.75rem; color:#6b7280;">daily-life-hacks.com/meal-plan/gut-health-reset</p>
      </div>
    </div>

    <!-- ── Page Header ── -->
    <div class="no-print mb-10">
      <a href="/free-meal-plan" class="inline-flex items-center gap-1.5 text-sm font-medium mb-6" style="color: var(--muted-color);">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        All meal plans
      </a>
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
        <div>
          <span class="inline-block text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-3" style="background-color: #d1fae5; color: #065f46;">Gut Health</span>
          <h1 class="text-3xl md:text-4xl font-black tracking-tight mb-3" style="color: var(--heading-color);">7-Day Gut Health Reset</h1>
          <p class="text-base max-w-xl" style="color: var(--muted-color); line-height: 1.7;">
            High-fiber meals, fermented foods, and gut-friendly ingredients — every day for one week.
            Designed to reduce bloating and help you feel your best by Day 4.
          </p>
        </div>
        <div class="flex flex-col gap-3 flex-shrink-0">
          <button
            onclick="window.print()"
            class="flex items-center justify-center gap-2 rounded-xl px-6 py-3.5 text-sm font-bold text-white"
            style="background-color: #059669; box-shadow: 0 4px 14px rgba(5,150,105,0.3);"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            Download PDF
          </button>
          <p class="text-xs text-center" style="color: var(--label-color);">In print dialog, choose "Save as PDF"</p>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8 p-5 rounded-2xl" style="background-color: var(--card-bg); border: 1px solid var(--border-color);">
        {[
          { label: "Daily Calories", value: "~1,800" },
          { label: "Daily Fiber", value: "30–45g" },
          { label: "Meals Per Day", value: "5 meals" },
          { label: "Plan Duration", value: "7 days" },
        ].map(stat => (
          <div class="text-center">
            <div class="text-lg font-black" style="color: #059669;">{stat.value}</div>
            <div class="text-xs" style="color: var(--muted-color);">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- ── 7-Day Meal Plan ── -->
    <h2 class="text-xl font-black mb-6" style="color: var(--heading-color);">Your 7-Day Plan</h2>

    {days.map(day => (
      <div class="day-card">
        <div class="day-header">
          <div>
            <span class="text-xs font-bold uppercase tracking-widest opacity-80">{day.label}</span>
            <h3 class="text-lg font-black">{day.day}</h3>
          </div>
          <div class="text-right text-sm">
            <div class="font-bold">{day.total} cal</div>
            <div class="opacity-80 text-xs">Fiber: {day.fiber}</div>
          </div>
        </div>
        <div class="p-0">
          {day.meals.map((meal, i) => (
            <div class={`meal-row flex gap-4 px-5 py-3.5 ${i < day.meals.length - 1 ? 'border-b' : ''}`} style="border-color: var(--border-color);">
              <div class="label-col w-20 flex-shrink-0 pt-0.5">{meal.label}</div>
              <div class="flex-1">
                <div class="text-sm font-bold" style="color: var(--heading-color);">{meal.name}</div>
                <div class="text-xs mt-0.5" style="color: var(--muted-color);">{meal.detail}</div>
              </div>
              <div class="text-right flex-shrink-0">
                <div class="text-sm font-bold" style="color: var(--heading-color);">{meal.cal}</div>
                <div class="text-xs" style="color: var(--muted-color);">cal</div>
              </div>
            </div>
          ))}
          <div class="tip-box">
            <strong>Tip:</strong> {day.tip}
          </div>
        </div>
      </div>
    ))}

    <!-- ── Shopping List ── -->
    <div class="mt-12 mb-10">
      <h2 class="text-xl font-black mb-2" style="color: var(--heading-color);">Weekly Shopping List</h2>
      <p class="text-sm mb-6" style="color: var(--muted-color);">Everything you need for all 7 days. Buy once, cook all week.</p>

      <div class="grid md:grid-cols-3 gap-6">
        {Object.entries(shoppingList).map(([category, items]) => (
          <div class="rounded-2xl p-5" style="background-color: var(--card-bg); border: 1px solid var(--border-color);">
            <h3 class="text-sm font-bold mb-3 uppercase tracking-wider" style="color: #059669;">{category}</h3>
            <ul class="space-y-1.5">
              {items.map(item => (
                <li class="flex items-start gap-2 text-xs" style="color: var(--text-color);">
                  <span class="mt-0.5 w-3 h-3 rounded-sm flex-shrink-0" style="border: 1.5px solid #059669;"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- ── Footer CTA ── -->
    <div class="no-print rounded-2xl p-8 text-center" style="background: linear-gradient(135deg, #d1fae5, #ecfdf5); border: 1px solid #a7f3d0;">
      <p class="text-base font-bold mb-2" style="color: #065f46;">Want a new plan every week?</p>
      <p class="text-sm mb-5" style="color: #047857;">Join the Daily Life Hacks newsletter — free recipes, guides, and tips in your inbox.</p>
      <a
        href="/#newsletter"
        class="inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-bold text-white"
        style="background-color: #059669;"
      >
        Join free
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>

    <!-- ── Disclaimer ── -->
    <p class="no-print text-xs mt-8 text-center" style="color: var(--label-color);">
      This meal plan is for general informational purposes only and is not a substitute for professional medical or dietary advice.
      Calorie counts are approximate. Individual needs vary. <a href="/disclaimer" style="text-decoration:underline;">Full disclaimer</a>.
    </p>

  </main>

  <Footer />
</BaseLayout>
