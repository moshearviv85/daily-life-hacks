---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const title = "7-Day Energy & Weight Loss Meal Plan";
const description = "A balanced 7-day meal plan for steady energy and natural weight loss. Simple, filling, family-friendly recipes around 1,600 calories per day.";

const days = [
  {
    day: "Monday", label: "Day 1",
    meals: [
      { label: "Breakfast", name: "Protein overnight oats", detail: "1/2 cup rolled oats, 1/2 cup low-fat milk, 1/4 cup Greek yogurt, 1 tsp honey, 1/2 banana, 1 tbsp almond butter", cal: 390, protein: "22g" },
      { label: "Snack", name: "Hard-boiled egg + cucumber", detail: "1 large hard-boiled egg, 1 cup sliced cucumber with a pinch of sea salt", cal: 110, protein: "7g" },
      { label: "Lunch", name: "Grilled chicken salad", detail: "4 oz grilled chicken breast, 3 cups mixed greens, cherry tomatoes, 1/4 avocado, lemon-Dijon vinaigrette", cal: 420, protein: "38g" },
      { label: "Snack", name: "Greek yogurt with honey", detail: "3/4 cup plain low-fat Greek yogurt, 1 tsp honey", cal: 145, protein: "15g" },
      { label: "Dinner", name: "Zucchini noodles with turkey bolognese", detail: "3 oz lean ground turkey sauce with diced tomatoes, garlic, basil + 2 medium zucchini spiralized", cal: 490, protein: "35g" },
    ],
    total: "~1,555", protein: "117g", tip: "Start Monday strong. Prep tomorrow's chicken tonight so lunch takes 5 minutes."
  },
  {
    day: "Tuesday", label: "Day 2",
    meals: [
      { label: "Breakfast", name: "Spinach and feta egg wrap", detail: "2 large eggs scrambled with 1 cup baby spinach, 1 oz crumbled feta, 1 small whole wheat tortilla", cal: 350, protein: "24g" },
      { label: "Snack", name: "Apple with peanut butter", detail: "1 medium apple, 1 tbsp natural peanut butter", cal: 200, protein: "4g" },
      { label: "Lunch", name: "Tuna lettuce wraps", detail: "1 can (5 oz) tuna in water, 1 tbsp light mayo, diced celery and red onion + 4 large romaine lettuce cups, 1/4 avocado", cal: 380, protein: "40g" },
      { label: "Snack", name: "Edamame", detail: "1 cup shelled edamame, lightly salted", cal: 120, protein: "11g" },
      { label: "Dinner", name: "Baked salmon with asparagus", detail: "5 oz baked salmon fillet with lemon and dill, 1 cup roasted asparagus, 1/2 cup cauliflower rice", cal: 510, protein: "42g" },
    ],
    total: "~1,560", protein: "121g", tip: "Tuna wraps are your meal prep secret weapon. Mix the filling on Sunday for the whole week."
  },
  {
    day: "Wednesday", label: "Day 3",
    meals: [
      { label: "Breakfast", name: "Cottage cheese power bowl", detail: "1 cup low-fat cottage cheese, 1/2 cup diced pineapple, 2 tbsp sunflower seeds, drizzle of honey", cal: 300, protein: "30g" },
      { label: "Snack", name: "Sliced bell pepper with hummus", detail: "1 large bell pepper sliced, 3 tbsp hummus", cal: 130, protein: "5g" },
      { label: "Lunch", name: "Turkey and quinoa stuffed pepper", detail: "1 large bell pepper stuffed with 3 oz ground turkey, 1/3 cup cooked quinoa, diced tomatoes, Italian seasoning, baked", cal: 450, protein: "35g" },
      { label: "Snack", name: "Protein shake", detail: "1 scoop vanilla protein powder blended with 1 cup unsweetened almond milk, ice", cal: 160, protein: "24g" },
      { label: "Dinner", name: "Lemon garlic shrimp with broccoli", detail: "5 oz shrimp sauteed in garlic and lemon butter, 2 cups roasted broccoli, 1/2 cup brown rice", cal: 490, protein: "38g" },
    ],
    total: "~1,530", protein: "132g", tip: "Midweek slump? High protein keeps you energized all afternoon. Skip the 3pm coffee."
  },
  {
    day: "Thursday", label: "Day 4",
    meals: [
      { label: "Breakfast", name: "Veggie egg muffins (2)", detail: "2 baked egg muffins with spinach, mushrooms, and mozzarella + 1 slice whole grain toast", cal: 360, protein: "22g" },
      { label: "Snack", name: "String cheese and grapes", detail: "1 low-fat string cheese, 1 cup seedless grapes", cal: 150, protein: "7g" },
      { label: "Lunch", name: "Chicken and vegetable soup", detail: "2 cups homemade or low-sodium chicken vegetable soup with carrots, celery, zucchini + 1 slice whole grain bread", cal: 420, protein: "30g" },
      { label: "Snack", name: "Almonds and a small orange", detail: "15 raw almonds, 1 medium navel orange", cal: 185, protein: "5g" },
      { label: "Dinner", name: "Baked chicken thigh with roasted veg", detail: "5 oz baked skinless chicken thigh, 1 cup roasted Brussels sprouts, 1 medium roasted sweet potato", cal: 540, protein: "40g" },
    ],
    total: "~1,655", protein: "104g", tip: "Thursday is a great day to double your soup batch. Freeze half for next week."
  },
  {
    day: "Friday", label: "Day 5",
    meals: [
      { label: "Breakfast", name: "Banana almond smoothie", detail: "1 frozen banana, 1/2 cup Greek yogurt, 1 cup spinach, 1 cup almond milk, 1 tbsp almond butter — blend smooth", cal: 380, protein: "20g" },
      { label: "Snack", name: "Rice cake with avocado", detail: "2 plain rice cakes, 1/4 mashed avocado, sea salt and chili flakes", cal: 170, protein: "3g" },
      { label: "Lunch", name: "Black bean taco bowls", detail: "1/2 cup black beans, 1/3 cup brown rice, shredded cabbage, 1/4 avocado, fresh salsa, lime, cilantro", cal: 440, protein: "14g" },
      { label: "Snack", name: "Greek yogurt with berries", detail: "3/4 cup plain Greek yogurt, 1/2 cup mixed berries", cal: 145, protein: "15g" },
      { label: "Dinner", name: "Turkey burger with sweet potato fries", detail: "4 oz turkey burger (no bun) on lettuce with tomato, onion, mustard + 1 cup baked sweet potato fries", cal: 510, protein: "36g" },
    ],
    total: "~1,645", protein: "88g", tip: "Friday treat: the turkey burger satisfies the weekend craving without the splurge."
  },
  {
    day: "Saturday", label: "Day 6",
    meals: [
      { label: "Breakfast", name: "Whole grain avocado toast + egg", detail: "2 slices whole grain toast, 1/2 avocado, 2 poached eggs, red pepper flakes, lemon zest", cal: 430, protein: "22g" },
      { label: "Snack", name: "Celery and almond butter", detail: "4 celery stalks, 2 tbsp almond butter", cal: 175, protein: "6g" },
      { label: "Lunch", name: "Grilled salmon salad", detail: "4 oz grilled salmon over 3 cups mixed greens, cucumber, radishes, 2 tbsp sesame-ginger dressing", cal: 450, protein: "35g" },
      { label: "Snack", name: "Cottage cheese and berries", detail: "1/2 cup low-fat cottage cheese, 1/2 cup strawberries", cal: 130, protein: "14g" },
      { label: "Dinner", name: "Chicken stir-fry with brown rice", detail: "4 oz chicken breast strips, 2 cups mixed vegetables (broccoli, bell pepper, snap peas), low-sodium teriyaki, 1/2 cup brown rice", cal: 520, protein: "38g" },
    ],
    total: "~1,705", protein: "115g", tip: "Saturday is lighter — your weekend shouldn't derail the week. Stick to the plan."
  },
  {
    day: "Sunday", label: "Day 7",
    meals: [
      { label: "Breakfast", name: "High-protein pancakes", detail: "2 banana-oat pancakes (1 banana + 2 eggs blended), topped with 1/4 cup fresh blueberries and a drizzle of honey", cal: 320, protein: "16g" },
      { label: "Snack", name: "Handful of mixed nuts", detail: "28g mixed almonds, cashews, and walnuts", cal: 170, protein: "5g" },
      { label: "Lunch", name: "Meal prep Sunday roast chicken bowl", detail: "4 oz roasted chicken breast, 1/2 cup cooked farro, 1 cup roasted root vegetables (carrots, parsnip, sweet potato), tahini drizzle", cal: 510, protein: "38g" },
      { label: "Snack", name: "Apple slices with peanut butter", detail: "1 medium apple, 1 tbsp peanut butter", cal: 195, protein: "4g" },
      { label: "Dinner", name: "Baked cod with lentils and greens", detail: "5 oz baked cod fillet, 1/2 cup cooked green lentils, 2 cups wilted spinach with garlic, lemon wedge", cal: 470, protein: "48g" },
    ],
    total: "~1,665", protein: "111g", tip: "Use tonight to prep for the week: boil eggs, cook a grain batch, chop vegetables."
  },
];

const shoppingList = {
  "Produce & Fresh": [
    "3 bananas", "3 medium apples", "Grapes — 1 small bunch",
    "Mixed berries — 2 cups", "Pineapple — 1 cup diced",
    "1 lemon, 2 limes", "1 navel orange",
    "Baby spinach — 1 large bag (10 oz)",
    "Mixed salad greens — 2 bags",
    "Romaine lettuce — 1 head",
    "3 large bell peppers", "Cherry tomatoes", "1 red onion",
    "Cucumber — 2 medium", "Celery — 1 bunch",
    "2 medium zucchini", "1 head broccoli",
    "1 cup Brussels sprouts", "1 cup asparagus",
    "2 medium sweet potatoes", "1 head cauliflower",
    "Mushrooms — 1 cup", "Radishes", "Fresh garlic",
    "Mixed root vegetables (carrots, parsnip)",
    "2 avocados",
  ],
  "Protein": [
    "Chicken breast — 2 lbs",
    "Chicken thighs (skinless, boneless) — 1 lb",
    "Lean ground turkey (93%) — 1.5 lbs",
    "Canned tuna in water — 2 cans (5 oz)",
    "Shrimp (peeled) — 1 lb",
    "Salmon fillets — 1.5 lbs",
    "Cod fillets — 1 lb",
    "Eggs — 1 dozen",
    "Plain Greek yogurt — 32 oz",
    "Low-fat cottage cheese — 16 oz",
    "Low-fat string cheese — 1 pack",
    "Feta cheese — 1 small block",
    "Canned black beans — 1 can",
    "Green lentils — 1/2 lb",
    "Shelled edamame — 1 bag (frozen)",
    "Vanilla protein powder — 1 small container",
  ],
  "Pantry & Grains": [
    "Rolled oats — 1 lb", "Whole grain bread — 1 loaf",
    "Small whole wheat tortillas — 1 pack",
    "Plain rice cakes — 1 pack",
    "Brown rice — 1 lb", "Quinoa — 1/2 lb", "Farro — 1/2 lb",
    "Unsweetened almond milk — 1 quart",
    "Low-fat milk — 1 pint",
    "Natural almond butter — 1 jar",
    "Natural peanut butter — 1 jar",
    "Classic hummus — 1 container",
    "Tahini — 1 small jar",
    "Mixed nuts — 1 small bag",
    "Almonds — 1 small bag",
    "Sunflower seeds — 1 small bag",
    "Low-sodium soy sauce or tamari",
    "Low-sodium teriyaki sauce",
    "Sesame-ginger dressing",
    "Dijon mustard", "Olive oil", "Honey",
  ],
};
---

<BaseLayout title={title} description={description}>
  <Header />

  <style>
    .meal-row:nth-child(even) { background-color: var(--input-bg); }
    .day-card {
      border: 1px solid var(--border-color);
      background-color: var(--card-bg);
      border-radius: 1rem;
      overflow: hidden;
      margin-bottom: 2rem;
    }
    .day-header {
      background: linear-gradient(135deg, #F29B30, #d4861a);
      color: white;
      padding: 1rem 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .tip-box {
      background-color: #fef3e2;
      color: #92400e;
      border-left: 4px solid #F29B30;
      padding: 0.75rem 1rem;
      font-size: 0.85rem;
      line-height: 1.5;
    }
    html.dark .tip-box { background-color: #451a03; color: #fbbf24; }
    .label-col {
      color: #F29B30; font-weight: 700; font-size: 0.75rem;
      text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap;
    }

    @media print {
      .no-print { display: none !important; }
      body { background: white !important; color: #111 !important; }
      .day-card { break-inside: avoid; border: 1px solid #fed7aa !important; background: white !important; }
      .tip-box { background: #fffbeb !important; color: #92400e !important; }
      header, footer, .Header, .Footer { display: none !important; }
      main { padding: 0 !important; max-width: 100% !important; }
      .print-header { display: block !important; }
      a { text-decoration: none !important; color: inherit !important; }
    }
    .print-header { display: none; }
  </style>

  <main class="max-w-4xl mx-auto px-4 py-10 md:py-14">

    <!-- Print header -->
    <div class="print-header mb-8 pb-4" style="border-bottom: 2px solid #F29B30;">
      <div style="display:flex; justify-content:space-between; align-items:center;">
        <div>
          <p style="color:#F29B30; font-weight:700; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.1em;">Daily Life Hacks</p>
          <h1 style="font-size:1.5rem; font-weight:900; color:#111;">7-Day Energy & Weight Loss Meal Plan</h1>
        </div>
        <p style="font-size:0.75rem; color:#6b7280;">daily-life-hacks.com/meal-plan/energy-and-weight-loss</p>
      </div>
    </div>

    <!-- Page Header -->
    <div class="no-print mb-10">
      <a href="/free-meal-plan" class="inline-flex items-center gap-1.5 text-sm font-medium mb-6" style="color: var(--muted-color);">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        All meal plans
      </a>
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="inline-block text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full" style="background-color: #fef3e2; color: #92400e;">Energy & Weight</span>
            <span class="text-xs font-bold px-2 py-1 rounded-full text-white" style="background-color: #F29B30;">Most Popular</span>
          </div>
          <h1 class="text-3xl md:text-4xl font-black tracking-tight mb-3" style="color: var(--heading-color);">7-Day Energy & Weight Loss</h1>
          <p class="text-base max-w-xl" style="color: var(--muted-color); line-height: 1.7;">
            Balanced meals that keep you full, fuel your workouts, and make the scale move in the right direction.
            No starvation. No obsessive calorie counting. Just real food.
          </p>
        </div>
        <div class="flex flex-col gap-3 flex-shrink-0">
          <button
            onclick="window.print()"
            class="flex items-center justify-center gap-2 rounded-xl px-6 py-3.5 text-sm font-bold text-white"
            style="background-color: #F29B30; box-shadow: 0 4px 14px rgba(242,155,48,0.3);"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            Download PDF
          </button>
          <p class="text-xs text-center" style="color: var(--label-color);">In print dialog, choose "Save as PDF"</p>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8 p-5 rounded-2xl" style="background-color: var(--card-bg); border: 1px solid var(--border-color);">
        {[
          { label: "Daily Calories", value: "~1,600" },
          { label: "Daily Protein", value: "100–130g" },
          { label: "Meals Per Day", value: "5 meals" },
          { label: "Plan Duration", value: "7 days" },
        ].map(stat => (
          <div class="text-center">
            <div class="text-lg font-black" style="color: #F29B30;">{stat.value}</div>
            <div class="text-xs" style="color: var(--muted-color);">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>

    <h2 class="text-xl font-black mb-6" style="color: var(--heading-color);">Your 7-Day Plan</h2>

    {days.map(day => (
      <div class="day-card">
        <div class="day-header">
          <div>
            <span class="text-xs font-bold uppercase tracking-widest opacity-80">{day.label}</span>
            <h3 class="text-lg font-black">{day.day}</h3>
          </div>
          <div class="text-right text-sm">
            <div class="font-bold">{day.total} cal</div>
            <div class="opacity-80 text-xs">Protein: {day.protein}</div>
          </div>
        </div>
        <div class="p-0">
          {day.meals.map((meal, i) => (
            <div class={`meal-row flex gap-4 px-5 py-3.5 ${i < day.meals.length - 1 ? 'border-b' : ''}`} style="border-color: var(--border-color);">
              <div class="label-col w-20 flex-shrink-0 pt-0.5">{meal.label}</div>
              <div class="flex-1">
                <div class="text-sm font-bold" style="color: var(--heading-color);">{meal.name}</div>
                <div class="text-xs mt-0.5" style="color: var(--muted-color);">{meal.detail}</div>
              </div>
              <div class="text-right flex-shrink-0">
                <div class="text-sm font-bold" style="color: var(--heading-color);">{meal.cal}</div>
                <div class="text-xs" style="color: var(--muted-color);">cal</div>
              </div>
            </div>
          ))}
          <div class="tip-box">
            <strong>Tip:</strong> {day.tip}
          </div>
        </div>
      </div>
    ))}

    <!-- Shopping List -->
    <div class="mt-12 mb-10">
      <h2 class="text-xl font-black mb-2" style="color: var(--heading-color);">Weekly Shopping List</h2>
      <p class="text-sm mb-6" style="color: var(--muted-color);">Shop once on Sunday — everything for all 7 days.</p>

      <div class="grid md:grid-cols-3 gap-6">
        {Object.entries(shoppingList).map(([category, items]) => (
          <div class="rounded-2xl p-5" style="background-color: var(--card-bg); border: 1px solid var(--border-color);">
            <h3 class="text-sm font-bold mb-3 uppercase tracking-wider" style="color: #F29B30;">{category}</h3>
            <ul class="space-y-1.5">
              {items.map(item => (
                <li class="flex items-start gap-2 text-xs" style="color: var(--text-color);">
                  <span class="mt-0.5 w-3 h-3 rounded-sm flex-shrink-0" style="border: 1.5px solid #F29B30;"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="no-print rounded-2xl p-8 text-center" style="background: linear-gradient(135deg, #fff8f0, #fef3e2); border: 1px solid #fcd9a0;">
      <p class="text-base font-bold mb-2" style="color: #92400e;">More plans like this, every week.</p>
      <p class="text-sm mb-5" style="color: #d97706;">Join the Daily Life Hacks newsletter — free.</p>
      <a href="/#newsletter" class="inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-bold text-white" style="background-color: #F29B30;">
        Join free
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>

    <p class="no-print text-xs mt-8 text-center" style="color: var(--label-color);">
      This meal plan is for general informational purposes only. Calorie counts are approximate. Individual needs vary.
      <a href="/disclaimer" style="text-decoration:underline;">Full disclaimer</a>.
    </p>

  </main>

  <Footer />
</BaseLayout>
