async function uploadArticlesCSV() {
  if (!IS_PRODUCTION_DASHBOARD) {
    const statusEl = el('art-upload-status');
    statusEl.style.display = 'block';
    statusEl.style.color = '#991b1b';
    statusEl.textContent = 'Upload חסום בסטייג׳ינג עד בידוד DB מלא. הוא לא יכתוב לתור הכתבות של פרודקשן.';
    return;
  }
  const file = document.getElementById('art-csv-input').files[0];
  if (!file) { alert('Choose a CSV file first'); return; }
  const statusEl = el('art-upload-status');
  const btn      = el('art-upload-btn');
  btn.disabled   = true;
  btn.textContent = 'Uploading...';
  statusEl.style.display = 'block';
  statusEl.style.color   = 'var(--muted)';
  statusEl.textContent   = 'Reading file...';

  try {
    const text = await file.text();
    const res  = await fetch(`/api/articles-upload?key=${encodeURIComponent(pw)}`, {
      method: 'POST',
      headers: { 'Content-Type': 'text/plain' },
      body: text,
    });
    const data = await res.json();
    if (!res.ok || !data.ok) {
      statusEl.style.color = '#dc2626';
      statusEl.textContent = `Error: ${data.error || 'Upload failed'}`;
      return;
    }

    const uploadSummary = data.inserted > 0
      ? `${data.inserted} new article${data.inserted > 1 ? 's' : ''}`
      : `${data.updated ?? 0} updated`;
    statusEl.style.color = 'var(--muted)';
    statusEl.textContent = `✓ Uploaded (${uploadSummary}). Publishing first article...`;

    // Auto-publish first article immediately after upload
    const pubRes  = await fetch(`/api/articles-publish?key=${encodeURIComponent(pw)}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({}),
    });
    const pubData = await pubRes.json();

    const dupCount = pubData.skipped_duplicates?.length || 0;
    const dupNote  = dupCount > 0 ? ` (${dupCount} duplicate${dupCount > 1 ? 's' : ''} skipped)` : '';

    if (pubData.ok) {
      statusEl.style.color = '#16a34a';
      statusEl.textContent = `✓ (${uploadSummary}). Published: "${pubData.title || pubData.slug}"${dupNote}`;
    } else {
      statusEl.style.color = dupCount > 0 ? '#dc2626' : '#F29B30';
      statusEl.textContent = `✓ (${uploadSummary}). ${pubData.error || 'Publish failed'}${dupNote}`;
    }

    loadArticles();
  } catch (e) {
    statusEl.style.color = '#dc2626';
    statusEl.textContent = `Error: ${e.message}`;
  } finally {
    btn.disabled    = false;
    btn.textContent = 'Upload';
  }
}

async function loadArticles() {
  if (!pw) return;
  el('art-loading').style.display = '';
  el('art-error').style.display   = 'none';
  el('art-content').style.display = 'none';

  try {
    const res  = await fetch(`/api/articles-list?key=${encodeURIComponent(pw)}`);
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Load failed');

    const stats = data.stats || {};
    el('art-total').textContent     = stats.total     ?? '—';
    el('art-published').textContent = stats.published ?? '—';
    el('art-pending').textContent   = stats.pending   ?? '—';
    el('art-duplicate').textContent = stats.duplicate ?? '0';

    const dupCount = stats.duplicate || 0;
    el('art-duplicate-warn').style.display  = dupCount > 0 ? '' : 'none';
    el('art-duplicate-banner').style.display = dupCount > 0 ? '' : 'none';

    const articles = data.articles || [];
    const today    = new Date().toISOString().slice(0, 10);

    el('art-tbody').innerHTML = articles.map(a => {
      const isDue       = a.publish_at && a.publish_at <= today;
      const isPending   = a.status === 'PENDING';
      const isDup       = a.status === 'DUPLICATE';
      const isPublished = a.status === 'PUBLISHED';
      const statusColor = isPublished ? '#16a34a'
                        : isPending   ? '#F29B30'
                        : isDup       ? '#dc2626'
                        : 'var(--muted)';

      // Date column: published_at for published articles, publish_at for others
      const displayDate = isPublished && a.published_at
        ? a.published_at.slice(0, 10)
        : a.publish_at || '—';
      const dateColor = isDue && isPending ? '#dc2626' : isPublished ? '#16a34a' : 'inherit';

      const actionBtn = isPending && IS_PRODUCTION_DASHBOARD
        ? `<button onclick="publishArticle('${a.slug}')"
             style="font-size:.7rem;padding:.2rem .5rem;border-radius:5px;border:none;background:#2563eb;color:#fff;cursor:pointer">
             Publish Now
           </button>`
        : isPending
          ? `<span class="badge badge-orange" title="חסום בסטייג׳ינג">Staging only</span>`
        : `<span style="color:var(--muted);font-size:.75rem">—</span>`;

      // Notes column
      const siteUrl = `https://www.daily-life-hacks.com/${a.slug}`;
      let notesCell;
      if (isPublished) {
        notesCell = `<td style="font-size:.75rem">
          <a href="${siteUrl}" target="_blank"
             style="color:#16a34a;font-weight:600;text-decoration:none"
             title="${a.title}">↗ View article</a>
        </td>`;
      } else if (isDup && a.duplicate_of) {
        notesCell = `<td style="font-size:.7rem">
          <span style="color:#991b1b">Tried: </span>
          <a href="${siteUrl}" target="_blank" style="color:#2563eb">${a.slug}</a><br>
          <span style="color:#991b1b">Live: </span>
          <a href="${a.duplicate_of}" target="_blank" style="color:#dc2626">${a.duplicate_of.replace('https://www.daily-life-hacks.com/','')}</a>
        </td>`;
      } else {
        notesCell = `<td style="font-size:.75rem;color:var(--muted)">—</td>`;
      }

      const rowBg = isDup ? 'background:#fef2f2' : isPublished ? 'background:#f0fdf4' : '';
      return `<tr style="${rowBg}">
        <td style="font-size:.75rem;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
            title="${a.title}">${a.title}</td>
        <td style="font-size:.75rem">${a.category || '—'}</td>
        <td style="font-size:.75rem;white-space:nowrap;color:${dateColor}">${displayDate}</td>
        <td style="font-size:.75rem;font-weight:700;color:${statusColor}">${a.status}</td>
        ${notesCell}
        <td>${actionBtn}</td>
      </tr>`;
    }).join('');

    el('art-footer').textContent = `${articles.length} articles total`;
    el('art-loading').style.display = 'none';
    el('art-content').style.display = '';
  } catch (e) {
    el('art-loading').style.display = 'none';
    el('art-error').style.display   = '';
    el('art-error').textContent     = `Error: ${e.message}`;
  }
}

async function publishArticle(slug) {
  if (!IS_PRODUCTION_DASHBOARD) {
    el('art-trigger-status').style.display = '';
    el('art-trigger-status').style.background = '#fef2f2';
    el('art-trigger-status').style.borderColor = '#fecaca';
    el('art-trigger-status').style.color = '#991b1b';
    el('art-trigger-status').textContent = 'Publish Now חסום בסטייג׳ינג כי הוא מפרסם כתבה לפרודקשן.';
    return;
  }
  const btn = document.querySelector(`button[onclick="publishArticle('${slug}')"]`);
  if (btn) { btn.disabled = true; btn.textContent = '...'; }
  try {
    const res  = await fetch(`/api/articles-publish?key=${encodeURIComponent(pw)}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug }),
    });
    const data = await res.json();
    if (res.ok && data.ok) {
      const dupNote = data.skipped_duplicates?.length
        ? ` (${data.skipped_duplicates.length} duplicate skipped)`
        : '';
      el('art-trigger-status').style.display = '';
      el('art-trigger-status').style.background = '#f0fdf4';
      el('art-trigger-status').style.color = '#166534';
      el('art-trigger-status').textContent = `✓ Published: "${data.title || data.slug}"${dupNote}`;
      loadArticles();
    } else if (res.status === 409) {
      // Duplicate detected
      el('art-trigger-status').style.display = '';
      el('art-trigger-status').style.background = '#fef2f2';
      el('art-trigger-status').style.color = '#991b1b';
      el('art-trigger-status').innerHTML =
        `⚠ Duplicate: "<strong>${data.title || data.slug}</strong>" already live — ` +
        `<a href="${data.duplicate_of}" target="_blank" style="color:#dc2626">${data.duplicate_of}</a>`;
      loadArticles();
    } else {
      el('art-trigger-status').style.display = '';
      el('art-trigger-status').style.background = '#fef2f2';
      el('art-trigger-status').style.color = '#991b1b';
      el('art-trigger-status').textContent = `Error: ${data.error || 'Publish failed'}`;
      if (btn) { btn.disabled = false; btn.textContent = 'Publish Now'; }
    }
  } catch (e) {
    alert(`Error: ${e.message}`);
    if (btn) { btn.disabled = false; btn.textContent = 'Publish Now'; }
  }
}

function downloadArticlesCSV() {
  if (!pw) { alert('Enter password first'); return; }
