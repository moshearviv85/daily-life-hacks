<script define:vars={{ BUILD }}>
// ═══════════════════════════════════════════════════════════════════════════
//  Client-side dashboard logic
// ═══════════════════════════════════════════════════════════════════════════

let currentPeriod = 30;
let pw = '';
let trafficChart = null;
let subsChart = null;

// ── Login ──────────────────────────────────────────────────────────────────
document.getElementById('pw-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') attemptLogin();
});
document.getElementById('login-btn').addEventListener('click', attemptLogin);

function togglePwVisible() {
  const input = document.getElementById('pw-input');
  input.type = input.type === 'password' ? 'text' : 'password';
}

function attemptLogin() {
  const val = document.getElementById('pw-input').value.trim();
  if (!val) return;
  pw = val;
  loadDashboard();
}

function logout() {
  sessionStorage.removeItem('dlh_pw');
  pw = '';
  document.getElementById('app').style.display = 'none';
  document.getElementById('login-screen').style.display = 'flex';
  document.getElementById('pw-input').value = '';
  document.getElementById('login-error').style.display = 'none';
}

// Check sessionStorage on load
window.addEventListener('DOMContentLoaded', () => {
  const saved = sessionStorage.getItem('dlh_pw');
  if (saved) { pw = saved; loadDashboard(); }
});

// ── Load dashboard ─────────────────────────────────────────────────────────
async function loadDashboard() {
  // Show app shell
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('app').style.display = 'block';

  // Render build-time data immediately
  renderBuildData();

  // Fetch live data
  await fetchLive(currentPeriod);
  loadPinsStatus();
}

// ── Period toggle ──────────────────────────────────────────────────────────
function setPeriod(days) {
  currentPeriod = days;
  document.getElementById('btn-1').classList.toggle('active', days === 1);
  document.getElementById('btn-7').classList.toggle('active', days === 7);
  document.getElementById('btn-30').classList.toggle('active', days === 30);
  document.querySelectorAll('.period-label').forEach(el => el.textContent = days === 1 ? '24h' : days);
  fetchLive(days);
}

function refreshData() {
  const btn = document.getElementById('refresh-btn');
  btn.classList.add('spinning');
  fetchLive(currentPeriod).finally(() => btn.classList.remove('spinning'));
}

// ── Load Chart.js dynamically (Astro strips CDN script tags) ─────────────
async function loadChartJs() {
  if (window.Chart) return;
  await new Promise((resolve, reject) => {
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js';
    s.onload = resolve;
    s.onerror = reject;
    document.head.appendChild(s);
  });
}

// ── Fetch live data ────────────────────────────────────────────────────────
async function fetchLive(days) {
  setRefreshStatus('loading');
  await loadChartJs();
  try {
    const res = await fetch(`/api/dashboard?key=${encodeURIComponent(pw)}&days=${days}&noClarity=1`);
    if (res.status === 401) {
      document.getElementById('login-error').style.display = 'block';
      document.getElementById('app').style.display = 'none';
      document.getElementById('login-screen').style.display = 'flex';
      setRefreshStatus('error', 'Unauthorized');
      return;
    }
    const data = await res.json();
    sessionStorage.setItem('dlh_pw', pw);
    renderLiveData(data, days);
    setRefreshStatus('ok', `Refreshed ${new Date().toLocaleTimeString()}`);
  } catch (e) {
    setRefreshStatus('error', 'Network error: ' + e.message);
  }
}

async function fetchClarity() {
  const btn = document.getElementById('clarity-refresh-btn');
  btn.disabled = true;
  btn.textContent = 'Loading...';
  el('clarity-loading').style.display = 'block';
  el('clarity-loading').textContent = 'Fetching from Clarity API...';
  el('clarity-content').style.display = 'none';
  el('clarity-error').style.display = 'none';
  try {
    const res = await fetch(`/api/dashboard?key=${encodeURIComponent(pw)}&days=1&clarityOnly=1`);
    const data = await res.json();
    if (data.clarity) {
      liveData = { ...liveData, clarity: data.clarity };
      renderClarityData(data.clarity);
    }
    btn.textContent = `↻ Refresh Clarity (last: ${new Date().toLocaleTimeString()})`;
  } catch (e) {
    el('clarity-loading').style.display = 'none';
    el('clarity-error').style.display = 'block';
    el('clarity-error').textContent = 'Error: ' + e.message;
    btn.textContent = '↻ Refresh Clarity';
  } finally {
    btn.disabled = false;
  }
}

function setRefreshStatus(state, msg) {
  const el = document.getElementById('refresh-status');
  el.className = state === 'ok' ? 'ok' : state === 'error' ? 'err' : '';
  if (state === 'loading') {
    el.innerHTML = 'Loading live data<span class="loading-dots"></span>';
  } else {
    el.textContent = msg || '';
  }
}

// ── Render build-time data ─────────────────────────────────────────────────
function renderBuildData() {
  const d = BUILD;

  // Build time
  document.getElementById('build-time').textContent =
    new Date(d.buildTime).toLocaleString('en-US', { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' });

  // Articles top stats
  document.getElementById('s-articles').textContent = d.articles.total;
  document.getElementById('s-articles-sub').textContent =
    `${d.articles.byCategory.nutrition || 0} nut · ${d.articles.byCategory.recipes || 0} rec · ${d.articles.byCategory.tips || 0} tip`;

  document.getElementById('s-published').textContent = d.articles.published;
  if (d.articles.lastPub) {
    document.getElementById('s-last-pub').textContent = `last: ${d.articles.lastPub.date}`;
  }

  document.getElementById('s-scheduled').textContent = d.articles.scheduled;
  if (d.articles.scheduledList.length > 0) {
    document.getElementById('s-next-pub').textContent = `next: ${d.articles.scheduledList[0].publishAt}`;
  } else {
    document.getElementById('s-next-pub').textContent = 'none scheduled';
  }

  document.getElementById('s-pins').textContent = d.pins.total;
  document.getElementById('s-pins-sub').textContent =
    Object.entries(d.pins.byCat).map(([k,v]) => `${v} ${k}`).join(' · ');

  document.getElementById('s-images').textContent = d.images.webCount;
  document.getElementById('s-images-sub').textContent =
    `${d.images.pinCount} pin files · ${d.images.pinSlugsCount} articles`;

  // Category bars
  const total = d.articles.total || 1;
  const cats = ['nutrition','recipes','tips'];
  for (const c of cats) {
    const n = d.articles.byCategory[c] || 0;
    const p = d.articles.pubByCategory[c] || 0;
    el(`bar-${c}`).style.width = pct(n, total) + '%';
    el(`cnt-${c}`).textContent = n;
    el(`pbar-${c}`).style.width = pct(p, n || 1) + '%';
    el(`pcnt-${c}`).textContent = `${p}/${n}`;
  }

  // Pipeline
  const pipelineColors = { PUBLISHED:'var(--green)', IMAGES_READY:'var(--orange)', IDEATED:'var(--blue)', default:'var(--muted)' };
  const trkTotal = d.tracker.total || 1;
  let pHtml = '';
  for (const [s, count] of Object.entries(d.tracker.byStatus)) {
    const color = pipelineColors[s] || pipelineColors.default;
    pHtml += `<div class="cat-row">
      <span class="cat-label" style="font-size:.78rem">${s}</span>
      <div class="cat-bar-wrap"><div class="cat-bar" style="width:${pct(count,trkTotal)}%;background:${color}"></div></div>
      <span class="cat-count">${count}</span>
    </div>`;
  }
  el('pipeline-bars').innerHTML = pHtml || '<div class="empty">No tracker data</div>';

  // Pins by category
  const pinTotal = d.pins.total || 1;
  let pinCatHtml = '';
  for (const [c, count] of Object.entries(d.pins.byCat)) {
    pinCatHtml += `<div class="cat-row">
      <span class="cat-label">${c}</span>
      <div class="cat-bar-wrap"><div class="cat-bar" style="width:${pct(count,pinTotal)}%"></div></div>
      <span class="cat-count">${count}</span>
    </div>`;
  }
  el('pins-cat-bars').innerHTML = pinCatHtml;

  // Pinterest boards
  let boardHtml = '';
  for (const [b, count] of Object.entries(d.pins.byBoard)) {
    boardHtml += `<div style="margin-bottom:.5rem">
      <div style="display:flex;justify-content:space-between;font-size:.82rem">
        <span class="board-short" title="${b}">${b}</span>
        <strong>${count}</strong>
      </div>
    </div>`;
  }
  el('pins-board-list').innerHTML = boardHtml || '<div class="empty">—</div>';

  // Pins by status
  let statusHtml = '';
  for (const [s, count] of Object.entries(d.pins.byStatus)) {
    statusHtml += `<span class="badge badge-gray" style="margin:.15rem">${s}: ${count}</span>`;
  }
  el('pins-status-list').innerHTML = statusHtml || '<div class="empty">—</div>';

  // Images table
  el('img-have-web').textContent = d.images.withWeb;
  el('img-miss-web').innerHTML = badge(d.images.missingWeb.length, d.images.missingWeb.length > 0 ? 'red' : 'green');
  el('img-have-pin').textContent = d.images.withPins;
  el('img-miss-pin').innerHTML = badge(d.images.missingPin.length, d.images.missingPin.length > 0 ? 'orange' : 'green');
  el('img-total-web').textContent = d.images.webCount;
  el('img-total-pin').textContent = d.images.pinCount;

  // Missing web image table
  el('missing-web-tbody').innerHTML = d.images.missingWeb.map(a =>
    `<tr><td><a href="/${a.slug}" target="_blank" style="color:var(--orange);text-decoration:none">${a.slug}</a></td>
     <td>${a.category}</td><td>${a.pub ? '<span class="badge badge-green">LIVE</span>' : '<span class="badge badge-gray">draft</span>'}</td></tr>`
  ).join('') || '<tr><td colspan="3" class="empty">None missing!</td></tr>';

  // Missing pin image table
  el('missing-pin-tbody').innerHTML = d.images.missingPin.map(a =>
    `<tr><td><a href="/${a.slug}" target="_blank" style="color:var(--orange);text-decoration:none">${a.slug}</a></td>
     <td>${a.category}</td><td>${a.pub ? '<span class="badge badge-green">LIVE</span>' : '<span class="badge badge-gray">draft</span>'}</td></tr>`
  ).join('') || '<tr><td colspan="3" class="empty">None missing!</td></tr>';

  // Scheduled articles
  const sl = d.articles.scheduledList;
  if (sl.length === 0) {
    el('scheduled-table').style.display = 'none';
    el('scheduled-empty').style.display = 'block';
  } else {
    const today = new Date(); today.setHours(0,0,0,0);
    el('scheduled-tbody').innerHTML = sl.map(a => {
      const pub = new Date(a.publishAt + 'T00:00:00');
      const daysLeft = Math.round((pub - today) / 86400000);
      return `<tr>
        <td><a href="/${a.slug}?preview=moshiko1985!" target="_blank" style="color:var(--orange);text-decoration:none">${a.title}</a></td>
        <td>${a.category}</td>
        <td><strong>${a.publishAt}</strong></td>
        <td><span class="badge ${daysLeft <= 3 ? 'badge-red' : daysLeft <= 7 ? 'badge-orange' : 'badge-blue'}">${daysLeft}d</span></td>
      </tr>`;
    }).join('');
  }

  // Last published article
  if (d.articles.lastPub) {
    const lp = d.articles.lastPub;
    el('last-pub-info').innerHTML = `
      <strong><a href="/${lp.slug}" target="_blank" style="color:var(--orange);text-decoration:none">${lp.title}</a></strong>
      <span style="margin-left:.75rem" class="badge badge-blue">${lp.category}</span>
      <span style="margin-left:.75rem;color:var(--muted);font-size:.85rem">${lp.date}</span>`;
  }
}

// ── Render live data ───────────────────────────────────────────────────────
function renderLiveData(data, days) {
  liveData = data; // store for modal use
  // Subscriptions
  if (data.subscriptions && !data.subscriptions.error) {
    const s = data.subscriptions;
    const displayTotal = s.kitTotal ?? s.total;
    el('s-subs').textContent = fmt(displayTotal);
    el('s-subs-sub').textContent = s.kitTotal
      ? `Kit total · +${s.today} today via site`
      : `+${s.period} last ${days}d · +${s.today} today`;
    el('nl-total').textContent  = fmt(displayTotal);
    el('nl-period').textContent = fmt(s.period);
    el('nl-today').textContent  = fmt(s.today);

    // By source
    el('nl-by-source').innerHTML = s.bySource.map(r =>
      `<div style="display:flex;justify-content:space-between;padding:.3rem 0;border-bottom:1px solid var(--border);font-size:.85rem">
        <span>${r.source || 'unknown'}</span><strong>${r.count}</strong>
      </div>`
    ).join('') || '<div class="empty">No source data</div>';

    // Subs chart
    renderSubsChart(s.byDay, days);

    // Subscriber list
    renderSubsList(s.list || []);
  } else {
    el('s-subs').textContent = '—';
    el('s-subs-sub').textContent = data.subscriptions?.error || 'DB not connected';
  }

  // Cloudflare Analytics
  if (data.cloudflareAnalytics && !data.cloudflareAnalytics.error) {
    const cf = data.cloudflareAnalytics;
    el('s-pv').textContent = fmt(cf.totals.pageViews);
    el('s-pv-sub').textContent = `last ${days}d`;
    el('s-uv').textContent = fmt(cf.totals.uniques);
    el('s-uv-sub').textContent = `unique visitors`;
    renderTrafficChart(cf.byDay, days);
    el('traffic-error').style.display = 'none';
  } else {
    el('s-pv').textContent = '—';
    el('s-uv').textContent = '—';
    const errMsg = data.cloudflareAnalytics?.error || 'No data';
    el('traffic-error').textContent = 'Cloudflare Analytics: ' + errMsg;
    el('traffic-error').style.display = 'block';
    // Fall back to funnel events chart
    if (data.funnelEvents && data.funnelEvents.byDay?.length > 0) {
      renderTrafficChart(data.funnelEvents.byDay.map(d => ({
        day: d.day, pageViews: d.count, requests: d.count, uniques: 0
      })), days);
      el('traffic-error').textContent += ' — showing D1 events as fallback';
    }
  }

  // Top pages
  const tp = data.funnelEvents?.topPages ?? [];
  if (tp.length === 0) {
    el('top-pages-table').style.display = 'none';
    el('top-pages-empty').style.display = 'block';
  } else {
    el('top-pages-tbody').innerHTML = tp.map(r =>
      `<tr><td><a href="${r.page}" target="_blank" style="color:var(--orange);text-decoration:none;font-size:.8rem">${r.page}</a></td>
       <td><strong>${r.count}</strong></td></tr>`
    ).join('');
  }

  // Pinterest hits
  if (data.pinterestHits) {
    const ph = data.pinterestHits;
    el('pinterest-hits-info').innerHTML = ph.total > 0
      ? `<strong>${fmt(ph.total)}</strong> pin clicks tracked in D1` +
        (ph.topPins.length > 0 ? '<br><small style="color:var(--muted)">' + ph.topPins.slice(0,3).map(p => `${p.base_slug} (${p.count})`).join(', ') + '</small>' : '')
      : '<span class="empty">No Pinterest click data yet</span>';
  }

  // Agent scan log
  const scans = data.agentScans ?? [];
  if (scans.length === 0) {
    el('scan-log-empty').style.display = 'block';
    el('scan-log-list').innerHTML = '';
  } else {
    el('scan-log-empty').style.display = 'none';
    el('scan-log-list').innerHTML = scans.map(s => `
      <div class="scan-item">
        <div class="scan-time">${formatDate(s.scanned_at)} &nbsp;<span class="badge badge-gray">${s.scan_type}</span></div>
        <div class="scan-notes">${s.notes || '(no notes)'}</div>
        <div class="scan-meta">
          <span style="color:var(--red)">Found: ${s.issues_found}</span>
          <span style="color:var(--green)">Fixed: ${s.issues_fixed}</span>
        </div>
      </div>
    `).join('');
  }
}

// ── Clarity render (standalone, called by fetchClarity) ────────────────────
function renderClarityData(cl) {
  if (!cl || cl.error) {
    el('clarity-loading').style.display = 'none';
    el('clarity-error').style.display = 'block';
    el('clarity-error').textContent = 'Clarity: ' + (cl?.error || 'not configured');
    return;
  }
  el('clarity-loading').style.display = 'none';
  el('clarity-content').style.display = 'block';

  // Cache note
  const cacheNote = el('clarity-cache-note');
  if (cl.stale) {
    cacheNote.textContent = `⚠️ Showing stale data from ${cl.cachedAt ? new Date(cl.cachedAt + 'Z').toLocaleString() : 'cache'} — API rate limit reached`;
    cacheNote.style.color = 'var(--red, #e55)';
  } else if (cl.fromCache) {
    cacheNote.textContent = `Cached at ${cl.cachedAt ? new Date(cl.cachedAt + 'Z').toLocaleString() : '—'}`;
  } else {
    cacheNote.textContent = `Live data fetched at ${new Date().toLocaleTimeString()}`;
  }

  el('c-sessions').textContent     = fmt(cl.sessions);
  el('c-sessions-sub').textContent = `${cl.botSessions} bots filtered`;
  el('c-users').textContent        = fmt(cl.users);
  el('c-users-sub').textContent    = `${cl.pagesPerSession} pages/session`;
  el('c-pps').textContent          = cl.pagesPerSession;
  el('c-scroll').textContent       = cl.avgScrollDepth + '%';

  el('c-countries').innerHTML = cl.countries.length === 0
    ? '<div class="empty">No data</div>'
    : cl.countries.slice(0, 8).map(c => `
        <div style="display:flex;justify-content:space-between;align-items:center;padding:.3rem 0;border-bottom:1px solid var(--border);font-size:.85rem">
          <span>${c.country}</span><strong>${c.sessions} sessions</strong>
        </div>`).join('');

  el('c-pages').innerHTML = cl.topPages.length === 0
    ? '<div class="empty">No data</div>'
    : cl.topPages.slice(0, 8).map(p => `
        <div style="display:flex;justify-content:space-between;align-items:center;padding:.3rem 0;border-bottom:1px solid var(--border);font-size:.82rem">
          <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:70%">${p.title}</span>
          <strong style="white-space:nowrap;margin-left:.5rem">${p.sessions}</strong>
        </div>`).join('');

  el('c-devices').innerHTML = cl.devices.map(d => `
    <div style="display:flex;justify-content:space-between;padding:.3rem 0;border-bottom:1px solid var(--border);font-size:.85rem">
      <span>${d.name}</span><strong>${d.sessions}</strong>
    </div>`).join('');

  el('c-browsers').innerHTML = cl.browsers.map(b => `
    <div style="display:flex;justify-content:space-between;padding:.3rem 0;border-bottom:1px solid var(--border);font-size:.85rem">
      <span>${b.name}</span><strong>${b.sessions}</strong>
    </div>`).join('');
}

// ── Charts ─────────────────────────────────────────────────────────────────
function renderTrafficChart(byDay, days) {
  const ctx = document.getElementById('traffic-chart').getContext('2d');
  if (trafficChart) trafficChart.destroy();

  const filledDays = fillDays(byDay, days);
  trafficChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: filledDays.map(d => shortDate(d.day)),
      datasets: [{
        label: 'Page Views',
        data: filledDays.map(d => d.pageViews || 0),
        backgroundColor: 'rgba(242,155,48,0.75)',
        borderColor: '#F29B30',
        borderWidth: 1,
        borderRadius: 3,
      }, {
        label: 'Unique Visitors',
        data: filledDays.map(d => d.uniques || 0),
        backgroundColor: 'rgba(59,130,246,0.5)',
        borderColor: '#3b82f6',
        borderWidth: 1,
        borderRadius: 3,
      }],
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'top', labels: { font: { size: 11 } } } },
      scales: {
        x: { grid: { display: false }, ticks: { font: { size: 10 }, maxTicksLimit: 15 } },
        y: { beginAtZero: true, ticks: { font: { size: 10 } } },
      },
    },
  });
}

function renderSubsChart(byDay, days) {
  const ctx = document.getElementById('subs-chart').getContext('2d');
  if (subsChart) subsChart.destroy();

  const filledDays = fillDays(byDay.map(d => ({ day: d.day, pageViews: d.count, uniques: 0 })), days);
  subsChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: filledDays.map(d => shortDate(d.day)),
      datasets: [{
        label: 'New Subscribers',
        data: filledDays.map(d => d.pageViews || 0),
        backgroundColor: 'rgba(16,185,129,0.7)',
        borderColor: '#10b981',
        borderWidth: 1,
        borderRadius: 3,
      }],
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { display: false }, ticks: { font: { size: 9 }, maxTicksLimit: 10 } },
        y: { beginAtZero: true, ticks: { font: { size: 9 }, stepSize: 1 } },
      },
    },
  });
}

// ── Helpers ────────────────────────────────────────────────────────────────
function el(id) { return document.getElementById(id); }
function fmt(n) { return Number(n).toLocaleString('en-US'); }
function pct(n, total) { return Math.round((n / total) * 100); }
function badge(n, color) { return `<span class="badge badge-${color}">${n}</span>`; }
function shortDate(d) {
  if (!d) return '';
  const dt = new Date(d + 'T00:00:00');
  return dt.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
function formatDate(d) {
  if (!d) return '—';
  return new Date(d).toLocaleString('en-US', { month:'short', day:'numeric', year:'numeric', hour:'2-digit', minute:'2-digit' });
}

function fillDays(data, days) {
  const map = {};
  for (const d of data) map[d.day] = d;
  const result = [];
  const today = new Date(); today.setHours(0,0,0,0);
  for (let i = days - 1; i >= 0; i--) {
    const d = new Date(today);
    d.setDate(d.getDate() - i);
    const key = d.toISOString().split('T')[0];
    result.push(map[key] || { day: key, pageViews: 0, uniques: 0 });
  }
  return result;
}

function toggleCollapse(id) {
  const el = document.getElementById(id);
  el.classList.toggle('open');
}

// ── Subscriber list ────────────────────────────────────────────────────────
let allSubsList = [];

function renderSubsList(list) {
  allSubsList = list;
  el('subs-list-count').textContent = list.length;
  if (list.length === 0) {
    el('subs-list-table').style.display = 'none';
    el('subs-list-empty').style.display = 'block';
    return;
  }
  el('subs-list-table').style.display = '';
  el('subs-list-empty').style.display = 'none';
  renderSubsRows(list);
}

function renderSubsRows(list) {
  el('subs-list-tbody').innerHTML = list.map((s, i) => `
    <tr>
      <td style="color:var(--muted);font-size:.75rem">${i + 1}</td>
      <td><strong style="font-size:.82rem">${s.email}</strong></td>
      <td><span class="badge ${s.source === 'footer' ? 'badge-blue' : 'badge-orange'}">${s.source || '—'}</span></td>
      <td style="font-size:.75rem;color:var(--muted);max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${s.page || '—'}</td>
      <td><span class="badge ${s.status === 'success' ? 'badge-green' : 'badge-red'}">${s.status || '—'}</span></td>
      <td style="font-size:.75rem;color:var(--muted);white-space:nowrap">${formatDate(s.created_at)}</td>
    </tr>`).join('');
}

function filterSubs() {
  const q = el('subs-search').value.trim().toLowerCase();
  const filtered = q ? allSubsList.filter(s => s.email.toLowerCase().includes(q)) : allSubsList;
  el('subs-list-count').textContent = filtered.length;
  renderSubsRows(filtered);
}

function copySubEmails() {
  const q = el('subs-search').value.trim().toLowerCase();
  const list = q ? allSubsList.filter(s => s.email.toLowerCase().includes(q)) : allSubsList;
  const emails = list.filter(s => s.status === 'success').map(s => s.email).join('\n');
  navigator.clipboard.writeText(emails).then(() => {
    const btn = document.querySelector('[onclick="copySubEmails()"]');
    const orig = btn.textContent;
    btn.textContent = `✓ Copied ${list.filter(s=>s.status==='success').length}`;
    setTimeout(() => btn.textContent = orig, 2000);
  });
}

// ── Detail modal ───────────────────────────────────────────────────────────
let liveData = null;
let modalRows = [];
let modalSearchKey = '';

function openModal(type) {
  const overlay = document.getElementById('detail-modal');
  const title   = document.getElementById('modal-title');
  const body    = document.getElementById('modal-body');
  const search  = document.getElementById('modal-search');

  modalRows = [];
  modalSearchKey = type;
  search.style.display = 'none';
  search.value = '';

  switch (type) {
    case 'articles':
      title.innerHTML = `All Articles <span class="modal-count">(${BUILD.articlesList.length})</span>`;
      modalRows = BUILD.articlesList;
      search.style.display = '';
      search.placeholder = 'Search articles...';
      body.innerHTML = renderArticlesTable(BUILD.articlesList);
      break;

    case 'published':
      const pub = BUILD.articlesList.filter(a => a.pub);
      title.innerHTML = `Published Articles <span class="modal-count">(${pub.length})</span>`;
      modalRows = pub;
      search.style.display = '';
      search.placeholder = 'Search articles...';
      body.innerHTML = renderArticlesTable(pub);
      break;

    case 'scheduled':
      const sch = BUILD.articlesList.filter(a => !a.pub && a.publishAt);
      title.innerHTML = `Scheduled Articles <span class="modal-count">(${sch.length})</span>`;
      body.innerHTML = sch.length === 0
        ? '<div class="empty">No scheduled articles.</div>'
        : renderScheduledTable(sch);
      break;

    case 'pins':
      title.innerHTML = `All Pins <span class="modal-count">(${BUILD.pinsList.length})</span>`;
      modalRows = BUILD.pinsList;
      search.style.display = '';
      search.placeholder = 'Search pins...';
      body.innerHTML = renderPinsTable(BUILD.pinsList);
      break;

    case 'images':
      title.innerHTML = `Images Status <span class="modal-count">(${BUILD.imagesList.length} articles)</span>`;
      modalRows = BUILD.imagesList;
      search.style.display = '';
      search.placeholder = 'Search slug...';
      body.innerHTML = renderImagesTable(BUILD.imagesList);
      break;

    case 'subscribers':
      const subs = liveData?.subscriptions?.list ?? [];
      title.innerHTML = `Subscribers <span class="modal-count">(${subs.length})</span>`;
      modalRows = subs;
      search.style.display = '';
      search.placeholder = 'Search email...';
      body.innerHTML = renderSubsTable(subs);
      break;

    case 'pageviews':
    case 'visitors': {
      const countries = liveData?.cloudflareAnalytics?.topCountries ?? [];
      const countryNote = liveData?.cloudflareAnalytics?.countryNote ?? '';
      title.innerHTML = `Requests by Country <span class="modal-count">(${countries.length} countries)</span>`;
      const disclaimer = `<div style="font-size:.75rem;color:var(--muted);margin-bottom:.75rem;line-height:1.5">
        ⚠️ <strong>Note:</strong> This counts all HTTP <em>requests</em> (images, CSS, API) — not PageViews or Unique Visitors.
        For accurate visitor data, see the Clarity section below.
        ${countryNote ? `<br>📅 ${countryNote}` : ''}
      </div>`;
      body.innerHTML = countries.length === 0
        ? '<div class="empty">No country data available yet.</div>'
        : disclaimer + renderCountriesTable(countries);
      break;
    }

    case 'clarity-countries': {
      const cl = liveData?.clarity ?? {};
      const countries = cl.countries ?? [];
      title.innerHTML = `Sessions by Country — Clarity <span class="modal-count">(${countries.length} countries)</span>`;
      const note = `<div style="font-size:.75rem;color:var(--muted);margin-bottom:.75rem">
        ✅ Real human sessions only — bots already filtered by Clarity. Last 24h.
      </div>`;
      body.innerHTML = countries.length === 0
        ? '<div class="empty">No country data.</div>'
        : note + `<table class="data-table">
            <thead><tr><th>#</th><th>Country</th><th>Sessions</th><th style="width:35%"></th></tr></thead>
            <tbody>${countries.map((c, i) => {
              const pct = Math.round(c.sessions / (countries[0]?.sessions || 1) * 100);
              return `<tr>
                <td style="color:var(--muted)">${i+1}</td>
                <td><strong>${c.country}</strong></td>
                <td><strong>${c.sessions}</strong></td>
                <td><div style="background:var(--border);border-radius:99px;height:6px"><div style="background:#0078d4;height:6px;border-radius:99px;width:${pct}%"></div></div></td>
              </tr>`;
            }).join('')}</tbody>
          </table>`;
      break;
    }
  }

  overlay.classList.add('open');
  document.addEventListener('keydown', escClose);
}

function closeModal() {
  document.getElementById('detail-modal').classList.remove('open');
  document.removeEventListener('keydown', escClose);
}

function handleModalClick(e) {
  if (e.target === document.getElementById('detail-modal')) closeModal();
}

function escClose(e) { if (e.key === 'Escape') closeModal(); }

function modalSearch() {
  const q = document.getElementById('modal-search').value.trim().toLowerCase();
  const body = document.getElementById('modal-body');
  switch (modalSearchKey) {
    case 'articles':
    case 'published': {
      const rows = modalRows.filter(a => a.title.toLowerCase().includes(q) || a.slug.toLowerCase().includes(q));
      body.innerHTML = renderArticlesTable(rows);
      break;
    }
    case 'pins': {
      const rows = modalRows.filter(p => p.title.toLowerCase().includes(q) || p.slug.toLowerCase().includes(q));
      body.innerHTML = renderPinsTable(rows);
      break;
    }
    case 'images': {
      const rows = modalRows.filter(i => i.slug.toLowerCase().includes(q) || i.title.toLowerCase().includes(q));
      body.innerHTML = renderImagesTable(rows);
      break;
    }
    case 'subscribers': {
      const rows = modalRows.filter(s => s.email.toLowerCase().includes(q));
      body.innerHTML = renderSubsTable(rows);
      break;
    }
  }
}

// ── Modal table renderers ──────────────────────────────────────────────────
function renderArticlesTable(rows) {
  if (!rows.length) return '<div class="empty">No articles.</div>';
  return `<table class="data-table">
    <thead><tr><th>#</th><th>Title</th><th>Category</th><th>Date</th><th>Status</th></tr></thead>
    <tbody>${rows.map((a, i) => `<tr>
      <td style="color:var(--muted)">${i+1}</td>
      <td><a href="/${a.slug}${a.pub ? '' : '?preview=moshiko1985!'}" target="_blank" style="color:var(--orange);text-decoration:none;font-weight:600">${a.title}</a></td>
      <td><span class="badge badge-gray">${a.category}</span></td>
      <td style="white-space:nowrap;color:var(--muted)">${a.date ?? '—'}</td>
      <td>${a.pub ? '<span class="badge badge-green">LIVE</span>' : a.publishAt ? `<span class="badge badge-orange">📅 ${a.publishAt}</span>` : '<span class="badge badge-gray">draft</span>'}</td>
    </tr>`).join('')}</tbody>
  </table>`;
}

function renderScheduledTable(rows) {
  const today = new Date(); today.setHours(0,0,0,0);
  return `<table class="data-table">
    <thead><tr><th>Title</th><th>Category</th><th>Publish Date</th><th>Days</th></tr></thead>
    <tbody>${rows.map(a => {
      const d = new Date(a.publishAt + 'T00:00:00');
      const dl = Math.round((d - today) / 86400000);
      return `<tr>
        <td><a href="/${a.slug}?preview=moshiko1985!" target="_blank" style="color:var(--orange);text-decoration:none;font-weight:600">${a.title}</a></td>
        <td><span class="badge badge-gray">${a.category}</span></td>
        <td><strong>${a.publishAt}</strong></td>
        <td><span class="badge ${dl<=3?'badge-red':dl<=7?'badge-orange':'badge-blue'}">${dl}d</span></td>
      </tr>`;
    }).join('')}</tbody>
  </table>`;
}

function renderPinsTable(rows) {
  if (!rows.length) return '<div class="empty">No pins.</div>';
  return `<table class="data-table">
    <thead><tr><th>#</th><th>Title</th><th>Category</th><th>Board</th><th>Slug</th><th>Status</th></tr></thead>
    <tbody>${rows.map((p, i) => `<tr>
      <td style="color:var(--muted)">${i+1}</td>
      <td style="font-weight:600;max-width:180px">${p.title}</td>
      <td><span class="badge badge-gray">${p.category}</span></td>
      <td style="font-size:.72rem;color:var(--muted);max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${p.board}">${p.board}</td>
      <td><a href="/${p.slug}" target="_blank" style="color:var(--orange);text-decoration:none;font-size:.75rem">${p.slug}</a></td>
      <td><span class="badge badge-gray">${p.status}</span></td>
    </tr>`).join('')}</tbody>
  </table>`;
}

function renderImagesTable(rows) {
  if (!rows.length) return '<div class="empty">No articles.</div>';
  return `<table class="data-table">
    <thead><tr><th>#</th><th>Article</th><th>Web Image</th><th>Pin Images</th></tr></thead>
    <tbody>${rows.map((img, i) => `<tr>
      <td style="color:var(--muted)">${i+1}</td>
      <td><a href="/${img.slug}" target="_blank" style="color:var(--orange);text-decoration:none;font-weight:600;font-size:.8rem">${img.title}</a>
        <div style="font-size:.7rem;color:var(--muted)">${img.slug}</div></td>
      <td>${img.hasWeb
        ? `<a href="${img.webPath}" target="_blank" style="color:var(--green);font-size:.8rem">✅ view</a>`
        : '<span class="badge badge-red">❌ missing</span>'}</td>
      <td>${img.pinCount > 0
        ? `<span class="badge badge-green">${img.pinCount} files</span>`
        : '<span class="badge badge-red">❌ missing</span>'}</td>
    </tr>`).join('')}</tbody>
  </table>`;
}

function renderSubsTable(rows) {
  if (!rows.length) return '<div class="empty">No subscribers yet.</div>';
  return `<table class="data-table">
    <thead><tr><th>#</th><th>Email</th><th>Source</th><th>Status</th><th>Date</th></tr></thead>
    <tbody>${rows.map((s, i) => `<tr>
      <td style="color:var(--muted)">${i+1}</td>
      <td><strong>${s.email}</strong></td>
      <td><span class="badge ${s.source==='footer'?'badge-blue':'badge-orange'}">${s.source||'—'}</span></td>
      <td><span class="badge ${s.status==='success'?'badge-green':'badge-red'}">${s.status||'—'}</span></td>
      <td style="color:var(--muted);white-space:nowrap;font-size:.75rem">${formatDate(s.created_at)}</td>
    </tr>`).join('')}</tbody>
  </table>`;
}

function renderCountriesTable(rows) {
  const sorted = [...rows].sort((a, b) => b.requests - a.requests);
  const maxVal = sorted[0]?.requests || 1;
  return `<table class="data-table">
    <thead><tr><th>#</th><th>Country</th><th>Requests</th><th style="width:35%"></th></tr></thead>
    <tbody>${sorted.map((c, i) => `<tr>
      <td style="color:var(--muted)">${i+1}</td>
      <td><strong>${c.country}</strong></td>
      <td><strong>${fmt(c.requests)}</strong></td>
      <td><div style="background:var(--border);border-radius:99px;height:6px"><div style="background:var(--orange);height:6px;border-radius:99px;width:${Math.round(c.requests/maxVal*100)}%"></div></div></td>
    </tr>`).join('')}</tbody>
  </table>`;
}

