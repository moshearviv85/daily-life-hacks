function renderPipelineStats() {
  if (!pipelineData) return;
  const rawStages = pipelineData.summary?.by_stage || {};
  const s = pipelineData.summary?.by_display_stage || rawStages;
  const topics = pipelineData.topics || {};

  document.getElementById('pl-topics-approved').textContent = topics.approved || 0;
  document.getElementById('pl-topics-sub').textContent =
    `${topics.pending || 0} pending, ${topics.rejected || 0} rejected`;

  const inProd = Math.max(0, (rawStages.approved || 0) + (rawStages.written || 0) + (rawStages.reviewed || 0) +
    (rawStages.hero_brief || 0) + (rawStages.pins_brief || 0) + (rawStages.hero_image || 0) +
