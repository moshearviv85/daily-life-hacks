async function triggerArticlePublisher() {
  const btn    = el('art-trigger-btn');
  const status = el('art-trigger-status');
  if (!IS_PRODUCTION_DASHBOARD) {
    status.style.display = '';
    status.style.background = '#fef2f2';
    status.style.borderColor = '#fecaca';
    status.style.color = '#991b1b';
    status.textContent = 'Run Publisher חסום בסטייג׳ינג כי הוא יכול לפרסם כתבות לפרודקשן.';
    return;
  }
  btn.disabled = true;
  btn.textContent = 'Publishing...';
  status.style.display = 'none';

  try {
    const res  = await fetch(`/api/articles-publish?key=${encodeURIComponent(pw)}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({}),
    });
    const data = await res.json();
    const dupCount = data.skipped_duplicates?.length || 0;
    const dupNote  = dupCount > 0 ? ` (${dupCount} duplicate${dupCount > 1 ? 's' : ''} skipped)` : '';
    if (data.ok) {
      status.style.background  = '#f0fdf4';
      status.style.borderColor = '#bbf7d0';
      status.style.color       = '#166534';
      status.style.display     = '';
      status.textContent       = `✓ Published: "${data.title || data.slug}"${dupNote}`;
      loadArticles();
    } else {
      status.style.background  = '#fef2f2';
      status.style.borderColor = '#fecaca';
      status.style.color       = '#991b1b';
      status.style.display     = '';
      status.textContent       = `${data.error || 'Publish failed'}${dupNote}`;
    }
  } catch (e) {
    status.style.display = '';
    status.textContent   = `Error: ${e.message}`;
  } finally {
    btn.disabled    = false;
    btn.textContent = '▶ Run Publisher';
  }
}

