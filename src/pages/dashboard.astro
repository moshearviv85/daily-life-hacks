---
/**
 * /dashboard — password-protected site dashboard.
 * Build-time: reads local markdown + JSON for content stats.
 * Runtime:    fetches live data (subs, analytics, agent scans) from /api/dashboard.
 * Password:   DASHBOARD_PASSWORD env var (Cloudflare Pages → Variables and Secrets).
 */
import { getCollection } from 'astro:content';
import { readdirSync } from 'node:fs';
import { join, dirname } from 'node:path';
import { fileURLToPath } from 'node:url';

const __dirname = dirname(fileURLToPath(import.meta.url));
const root = join(__dirname, '../..');
const now = new Date();

// ── Articles ──────────────────────────────────────────────────────────────
const articles = await getCollection('articles');

function isPub(a: any) {
  return !a.data.publishAt || new Date(a.data.publishAt) <= now;
}
const published  = articles.filter(isPub);
const scheduled  = articles.filter(a => !isPub(a));

const sortedPub = [...published].sort((a,b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const lastPub = sortedPub[0];

const cats = ['nutrition','recipes','tips'] as const;
const byCategory: Record<string,number>     = {};
const pubByCategory: Record<string,number>  = {};
for (const c of cats) {
  byCategory[c]   = articles.filter(a => a.data.category === c).length;
  pubByCategory[c]= published.filter(a => a.data.category === c).length;
}

const scheduledList = scheduled
  .map(a => ({
    slug: a.id,
    title: a.data.title,
    category: a.data.category,
    publishAt: a.data.publishAt?.toISOString().split('T')[0] ?? null,
  }))
  .sort((a,b) => new Date(a.publishAt!).getTime() - new Date(b.publishAt!).getTime());

// ── Images ────────────────────────────────────────────────────────────────
const imgDir  = join(root,'public/images');
const pinDir  = join(root,'public/images/pins');

const webFiles = readdirSync(imgDir).filter(f => f.endsWith('-main.jpg'));
const pinFiles = readdirSync(pinDir).filter(f => /\.jpg$/i.test(f));

const webSlugs = new Set(webFiles.map(f => f.replace('-main.jpg','')));
const pinSlugs = new Set(pinFiles.map(f => f.replace(/\.jpg$/i,'')));

const missingWeb = articles
  .filter(a => !webSlugs.has(a.id))
  .map(a => ({ slug: a.id, title: a.data.title, category: a.data.category, pub: isPub(a) }));

const missingPin = articles
  .filter(a => !pinSlugs.has(a.id))
  .map(a => ({ slug: a.id, title: a.data.title, category: a.data.category, pub: isPub(a) }));

// ── Pins (legacy data removed — pipeline data now served from D1 at runtime)
const pins: any[] = [];
const pinByCat: Record<string,number>    = {};
const pinByBoard: Record<string,number>  = {};
const pinByStatus: Record<string,number> = {};

const schedPosted: any[]  = [];
const schedPending: any[] = [];
const nextPin = null;

// ── Content tracker (legacy — replaced by pipeline control center)
const tracker: any[] = [];
const trkByStatus: Record<string,number>   = {};
const trkByCat: Record<string,number>      = {};

// ── Final build-time bundle ───────────────────────────────────────────────
const BUILD = {
  buildTime: now.toISOString(),
  articles: {
    total: articles.length,
    published: published.length,
    scheduled: scheduled.length,
    byCategory,
    pubByCategory,
    lastPub: lastPub ? {
      title:    lastPub.data.title,
      date:     lastPub.data.date?.toISOString().split('T')[0],
      slug:     lastPub.id,
      category: lastPub.data.category,
    } : null,
    scheduledList,
  },
  images: {
    webCount:     webFiles.length,
    pinCount:     pinFiles.length,
    pinSlugsCount: pinSlugs.size,
    webSlugs:      Array.from(webSlugs).sort(),
    pinSlugs:      Array.from(pinSlugs).sort(),
    withWeb:      articles.length - missingWeb.length,
    withPins:     articles.length - missingPin.length,
    missingWeb,
    missingPin,
  },
  pins: {
    total:    pins.length,
    byCat:    pinByCat,
    byBoard:  pinByBoard,
    byStatus: pinByStatus,
  },
  tracker: {
    total:    tracker.length,
    byStatus: trkByStatus,
    byCat:    trkByCat,
  },
  // ── Full lists for detail modals ──────────────────────────────────────
  articlesList: articles
    .map(a => ({
      slug:      a.id,
      title:     a.data.title,
      category:  a.data.category,
      date:      a.data.date?.toISOString().split('T')[0] ?? null,
      publishAt: a.data.publishAt?.toISOString().split('T')[0] ?? null,
      pub:       isPub(a),
    }))
    .sort((a, b) => new Date(b.date ?? 0).getTime() - new Date(a.date ?? 0).getTime()),
  articleSlugs: articles.map(a => a.id).sort(),
  imagesList: articles
    .map(a => ({
      slug:     a.id,
      title:    a.data.title,
      category: a.data.category,
      hasWeb:   webSlugs.has(a.id),
      webPath:  webSlugs.has(a.id) ? `/images/${a.id}-main.jpg` : null,
      pinCount: pinFiles.filter(f => f.startsWith(a.id)).length,
    }))
    .sort((a, b) => a.slug.localeCompare(b.slug)),
  pinsList: pins.map((p: any) => ({
    title:    p.pin_title,
    category: p.category,
    board:    p.board,
    slug:     p.slug,
    status:   p.status,
    variant:  p.variant,
  })),
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard — Daily Life Hacks</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%231e293b'/%3E%3Ctext x='2' y='22' font-size='18'%3E%F0%9F%8D%82%3C/text%3E%3Crect x='18' y='16' width='12' height='10' rx='2' fill='%23F29B30'/%3E%3Ccircle cx='21' cy='16' r='3.5' fill='none' stroke='%23F29B30' stroke-width='2'/%3E%3Crect x='20' y='20' width='2' height='3' rx='1' fill='%231e293b'/%3E%3C/svg%3E" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --orange:   #F29B30;
      --orange-d: #d97706;
      --bg:       #f1f5f9;
      --card:     #ffffff;
      --border:   #e2e8f0;
      --text:     #1e293b;
      --muted:    #64748b;
      --green:    #10b981;
      --red:      #ef4444;
      --blue:     #3b82f6;
      --purple:   #8b5cf6;
      --radius:   10px;
      --shadow:   0 1px 4px rgba(0,0,0,.08);
    }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
           background: var(--bg); color: var(--text); min-height: 100vh; }

    /* ── Login ────────────────────────────────────── */
    #login-screen {
      display: flex; align-items: center; justify-content: center;
      min-height: 100vh; padding: 1rem;
    }
    .login-card {
      background: var(--card); border-radius: var(--radius);
      box-shadow: 0 4px 24px rgba(0,0,0,.12);
      padding: 2.5rem; width: 100%; max-width: 380px; text-align: center;
    }
    .login-logo { font-size: 2.5rem; margin-bottom: .5rem; }
    .login-title { font-size: 1.25rem; font-weight: 700; margin-bottom: .25rem; }
    .login-sub   { color: var(--muted); font-size: .875rem; margin-bottom: 1.75rem; }
    .login-input {
      width: 100%; padding: .75rem 1rem; border: 1.5px solid var(--border);
      border-radius: 8px; font-size: 1rem; outline: none;
      transition: border-color .2s;
    }
    .login-input:focus { border-color: var(--orange); }
    .login-btn {
      width: 100%; padding: .75rem; background: var(--orange); color: #fff;
      border: none; border-radius: 8px; font-size: 1rem; font-weight: 600;
      cursor: pointer; margin-top: .75rem; transition: background .2s;
    }
    .login-btn:hover { background: var(--orange-d); }
    .login-error { color: var(--red); font-size: .85rem; margin-top: .75rem; display: none; }

    /* ── App shell ────────────────────────────────── */
    #app { display: none; }
    .topbar {
      background: var(--card); border-bottom: 1px solid var(--border);
      padding: .75rem 1.5rem; display: flex; align-items: center;
      gap: 1rem; flex-wrap: wrap; position: sticky; top: 0; z-index: 100;
    }
    .topbar-logo { font-size: 1.1rem; font-weight: 800; color: var(--orange); }
    .topbar-meta { color: var(--muted); font-size: .8rem; flex: 1; }
    .env-badge {
      display: inline-flex; align-items: center; gap: .35rem;
      padding: .25rem .55rem; border-radius: 6px; font-size: .72rem;
      font-weight: 800; line-height: 1; border: 1px solid transparent;
      white-space: nowrap;
    }
    .env-badge.staging {
      background: #fff7ed; color: #9a3412; border-color: #fed7aa;
    }
    .env-badge.production {
      background: #fef2f2; color: #991b1b; border-color: #fecaca;
    }
    .btn[disabled], button[disabled] {
      opacity: .55; cursor: not-allowed !important; filter: grayscale(.25);
    }
    .toggle-group { display: flex; gap: .25rem; }
    .toggle-btn {
      padding: .35rem .9rem; border: 1.5px solid var(--border); background: var(--card);
      border-radius: 6px; font-size: .8rem; cursor: pointer; font-weight: 600;
      transition: all .15s; color: var(--muted);
    }
    .toggle-btn.active { background: var(--orange); border-color: var(--orange); color: #fff; }
    .logout-btn {
      padding: .35rem .9rem; border: 1.5px solid var(--border); background: var(--card);
      border-radius: 6px; font-size: .8rem; cursor: pointer; color: var(--muted);
    }
    .logout-btn:hover { border-color: var(--red); color: var(--red); }
    .refresh-btn {
      padding: .35rem .65rem; border: 1.5px solid var(--border); background: var(--card);
      border-radius: 6px; font-size: 1rem; cursor: pointer; color: var(--muted);
      transition: transform .3s, border-color .15s;
      line-height: 1;
    }
    .refresh-btn:hover { border-color: var(--orange); color: var(--orange); }
    .refresh-btn.spinning { animation: spin .6s linear infinite; border-color: var(--orange); color: var(--orange); }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Content ──────────────────────────────────── */
    main { padding: 1.25rem 1.5rem; max-width: 1400px; margin: 0 auto; }
    .section-title {
      font-size: .7rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: .08em; color: var(--muted); margin-bottom: .75rem;
    }

    /* ── Stat cards ───────────────────────────────── */
    .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; margin-bottom: 1.25rem; }
    .stat-card {
      background: var(--card); border-radius: var(--radius); padding: 1.1rem 1.25rem;
      box-shadow: var(--shadow); border-left: 4px solid var(--orange);
    }
    .stat-card.green  { border-left-color: var(--green); }
    .stat-card.blue   { border-left-color: var(--blue); }
    .stat-card.purple { border-left-color: var(--purple); }
    .stat-card.red    { border-left-color: var(--red); }
    .stat-label { font-size: .75rem; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: .05em; }
    .stat-value { font-size: 2rem; font-weight: 800; line-height: 1.1; margin: .2rem 0 .15rem; }
    .stat-sub   { font-size: .78rem; color: var(--muted); }

    .automation-health-head {
      display: flex; align-items: center; justify-content: space-between;
      gap: .75rem; flex-wrap: wrap; margin-bottom: .8rem;
    }
    .automation-health-summary {
      display: flex; align-items: center; gap: .5rem; flex-wrap: wrap;
      font-size: .8rem; color: var(--muted);
    }
    .automation-health-badge {
      display: inline-flex; align-items: center; gap: .35rem;
      padding: .22rem .55rem; border-radius: 999px;
      font-size: .72rem; font-weight: 800; border: 1px solid transparent;
    }
    .automation-health-badge.ok { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
    .automation-health-badge.warn { background: #fef3c7; color: #92400e; border-color: #fde68a; }
    .automation-health-badge.danger { background: #fee2e2; color: #991b1b; border-color: #fecaca; }
    .automation-health-badge.running { background: #dbeafe; color: #1d4ed8; border-color: #bfdbfe; }
    .automation-health-badge.unknown { background: #f1f5f9; color: #475569; border-color: #e2e8f0; }
    :global(.automation-health-badge) {
      display: inline-flex; align-items: center; gap: .35rem;
      padding: .22rem .55rem; border-radius: 999px;
      font-size: .72rem; font-weight: 800; border: 1px solid transparent;
    }
    :global(.automation-health-badge.ok) { background: #dcfce7; color: #166534; border-color: #bbf7d0; }
    :global(.automation-health-badge.warn) { background: #fef3c7; color: #92400e; border-color: #fde68a; }
    :global(.automation-health-badge.danger) { background: #fee2e2; color: #991b1b; border-color: #fecaca; }
    :global(.automation-health-badge.running) { background: #dbeafe; color: #1d4ed8; border-color: #bfdbfe; }
    :global(.automation-health-badge.unknown) { background: #f1f5f9; color: #475569; border-color: #e2e8f0; }
    :global(.automation-health-grid) {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(245px, 1fr));
      gap: .75rem;
    }
    :global(.automation-workflow-card) {
      border: 1px solid #e5e7eb;
      border-left: 4px solid #94a3b8;
      border-radius: 8px;
      padding: .75rem;
      background: #fff;
      min-width: 0;
    }
    :global(.automation-workflow-card.ok) { border-left-color: #10b981; }
    :global(.automation-workflow-card.warn) { border-left-color: #f59e0b; }
    :global(.automation-workflow-card.danger) { border-left-color: #ef4444; }
    :global(.automation-workflow-card.running) { border-left-color: #3b82f6; }
    :global(.automation-workflow-title) {
      display: flex; justify-content: space-between; gap: .5rem; align-items: flex-start;
      font-size: .82rem; font-weight: 800; color: var(--heading);
    }
    :global(.automation-workflow-meta) {
      margin-top: .42rem; display: grid; gap: .16rem;
      font-size: .72rem; line-height: 1.35; color: var(--muted);
    }
    :global(.automation-workflow-problem) {
      margin-top: .45rem; padding: .35rem .45rem;
      border-radius: 6px; background: #fff7ed; color: #9a3412;
      font-size: .72rem; line-height: 1.35;
    }
    :global(.automation-workflow-card.danger .automation-workflow-problem) {
      background: #fef2f2; color: #991b1b;
    }
    :global(.automation-workflow-actions) {
      margin-top: .5rem; display: flex; gap: .45rem; flex-wrap: wrap;
      font-size: .72rem;
    }
    :global(.automation-workflow-actions a) { color: var(--orange); font-weight: 700; text-decoration: none; }

    /* ── Grid layouts ─────────────────────────────── */
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem; }
    .grid-12 { display: grid; grid-template-columns: 1fr 2fr; gap: 1rem; margin-bottom: 1.25rem; }
    .grid-21 { display: grid; grid-template-columns: 2fr 1fr; gap: 1rem; margin-bottom: 1.25rem; }
    @media (max-width: 900px) { .grid-2,.grid-3,.grid-12,.grid-21 { grid-template-columns: 1fr; } }

    /* ── Card ─────────────────────────────────────── */
    .card {
      background: var(--card); border-radius: var(--radius);
      padding: 1.25rem; box-shadow: var(--shadow);
    }
    .card-title { font-size: .8rem; font-weight: 700; text-transform: uppercase;
                  letter-spacing: .07em; color: var(--muted); margin-bottom: 1rem; }

    /* ── Category bars ────────────────────────────── */
    .cat-row { display: flex; align-items: center; gap: .75rem; margin-bottom: .65rem; }
    .cat-label { font-size: .85rem; font-weight: 600; min-width: 80px; }
    .cat-bar-wrap { flex: 1; background: var(--border); border-radius: 99px; height: 8px; }
    .cat-bar { height: 8px; border-radius: 99px; background: var(--orange); }
    .cat-count { font-size: .8rem; font-weight: 700; min-width: 30px; text-align: right; }

    /* ── Table ────────────────────────────────────── */
    .data-table { width: 100%; border-collapse: collapse; font-size: .82rem; }
    .data-table th { text-align: left; padding: .5rem .6rem; font-weight: 700;
                     font-size: .72rem; text-transform: uppercase; letter-spacing: .05em;
                     color: var(--muted); border-bottom: 1.5px solid var(--border); }
    .data-table td { padding: .55rem .6rem; border-bottom: 1px solid var(--border); vertical-align: middle; }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover td { background: #f8fafc; }

    /* ── Badges ───────────────────────────────────── */
    .badge {
      display: inline-block; padding: .15rem .55rem; border-radius: 99px;
      font-size: .7rem; font-weight: 700; text-transform: uppercase;
    }
    .badge-green  { background: #d1fae5; color: #065f46; }
    .badge-orange { background: #fef3c7; color: #92400e; }
    .badge-blue   { background: #dbeafe; color: #1e40af; }
    .badge-red    { background: #fee2e2; color: #991b1b; }
    .badge-gray   { background: #f1f5f9; color: var(--muted); }

    /* ── Chart container ──────────────────────────── */
    .chart-wrap { position: relative; height: 220px; }

    /* ── Empty / loading ──────────────────────────── */
    .empty { color: var(--muted); font-size: .85rem; padding: 1rem 0; text-align: center; }
    .loading-dots::after { content: '...'; animation: dots 1.2s infinite; }
    @keyframes dots { 0%,20%{content:'.'} 40%,60%{content:'..'} 80%,100%{content:'...'} }

    /* ── Collapsible ──────────────────────────────── */
    .collapse-btn {
      background: none; border: none; cursor: pointer; font-size: .8rem;
      color: var(--orange); font-weight: 700; padding: 0; margin-top: .5rem;
    }
    .collapsible { overflow: hidden; transition: max-height .3s ease; max-height: 0; }
    .collapsible.open { max-height: 9999px; }

    /* ── Scan log ─────────────────────────────────── */
    .scan-item { padding: .75rem 0; border-bottom: 1px solid var(--border); }
    .scan-item:last-child { border-bottom: none; }
    .scan-time { font-size: .75rem; color: var(--muted); }
    .scan-notes { font-size: .85rem; margin: .25rem 0; }
    .scan-meta { display: flex; gap: .75rem; font-size: .75rem; }

    /* ── Divider row ──────────────────────────────── */
    .section-gap { margin-bottom: 1.5rem; }

    /* ── Refresh indicator ────────────────────────── */
    #refresh-status { font-size: .75rem; color: var(--muted); }
    #refresh-status.ok   { color: var(--green); }
    #refresh-status.err  { color: var(--red); }

    /* ── Pinterest boards short label ────────────── */
    .board-short { max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    .pipeline-pin-card {
      margin: .42rem 0;
      padding: .48rem;
      border: 1px solid #e5e7eb;
      border-radius: 6px;
      background: #fff;
    }
    .pipeline-pin-head { display: flex; gap: .55rem; align-items: flex-start; }
    .pipeline-pin-thumb { flex: 0 0 auto; }
    .pipeline-pin-thumb img {
      width: 56px;
      height: 75px;
      object-fit: cover;
      border-radius: 6px;
      border: 1px solid #e5e7eb;
      display: block;
    }
    .pipeline-pin-main { min-width: 0; flex: 1; }
    .pipeline-pin-controls {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: .18rem;
      margin-bottom: .22rem;
    }
    .pipeline-pin-version {
      font-family: monospace;
      font-size: .66rem;
      font-weight: 800;
      color: var(--orange);
    }
    .pipeline-pin-title {
      display: block;
      color: var(--heading);
      font-size: .73rem;
      font-weight: 800;
      line-height: 1.25;
      text-decoration: none;
    }
    .pipeline-pin-title:hover { color: var(--orange); }
    .pipeline-pin-description {
      margin-top: .18rem;
      color: var(--text);
      font-size: .68rem;
      line-height: 1.35;
    }
    .pipeline-pin-details {
      margin-top: .36rem;
      color: var(--text);
      font-size: .68rem;
      line-height: 1.35;
    }
    .pipeline-pin-details summary {
      cursor: pointer;
      color: var(--orange);
      font-weight: 800;
    }
    .pipeline-pin-meta { margin-top: .3rem; }
    .pipeline-pin-meta div { margin-top: .18rem; }

    :global(.pipeline-pin-card) {
      margin: .42rem 0;
      padding: .48rem;
      max-width: 360px;
      box-sizing: border-box;
      overflow: hidden;
      border: 1px solid #e5e7eb;
      border-radius: 6px;
      background: #fff;
    }
    :global(.pipeline-pin-head) { display: flex; gap: .5rem; align-items: flex-start; }
    :global(.pipeline-pin-thumb) { flex: 0 0 48px; }
    :global(.pipeline-pin-thumb img) {
      width: 48px !important;
      height: 64px !important;
      max-width: 48px !important;
      object-fit: cover;
      border-radius: 6px;
      border: 1px solid #e5e7eb;
      display: block;
    }
    :global(.pipeline-pin-main) { min-width: 0; flex: 1; }
    :global(.pipeline-pin-controls) {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: .18rem;
      margin-bottom: .22rem;
    }
    :global(.pipeline-pin-version) {
      font-family: monospace;
      font-size: .66rem;
      font-weight: 800;
      color: var(--orange);
    }
    :global(.pipeline-pin-title) {
      display: block;
      color: var(--heading);
      font-size: .72rem;
      font-weight: 800;
      line-height: 1.25;
      text-decoration: none;
    }
    :global(.pipeline-pin-title:hover) { color: var(--orange); }
    :global(.pipeline-pin-description) {
      margin-top: .18rem;
      max-height: 3.8em;
      overflow: hidden;
      color: var(--text);
      font-size: .66rem;
      line-height: 1.3;
    }
    :global(.pipeline-pin-details) {
      margin-top: .34rem;
      color: var(--text);
      font-size: .66rem;
      line-height: 1.32;
    }
    :global(.pipeline-pin-details summary) {
      cursor: pointer;
      color: var(--orange);
      font-weight: 800;
    }
    :global(.pipeline-pin-meta) { margin-top: .3rem; }
    :global(.pipeline-pin-meta div) { margin-top: .18rem; }

    /* ── Clickable stat cards ─────────────────────────────────────────── */
    .stat-card.clickable { cursor: pointer; transition: transform .12s, box-shadow .12s; }
    .stat-card.clickable:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(0,0,0,.13); }
    .stat-card.clickable::after { content: '↗'; position: absolute; top: .5rem; right: .6rem; font-size: .7rem; color: var(--muted); opacity: .6; }
    .stat-card { position: relative; }

    /* ── Detail modal (slide-in panel) ───────────────────────────────── */
    .modal-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,.45);
      z-index: 500; opacity: 0; pointer-events: none;
      transition: opacity .2s;
    }
    .modal-overlay.open { opacity: 1; pointer-events: all; }
    .modal-panel {
      position: absolute; right: 0; top: 0; bottom: 0;
      width: min(640px, 96vw); background: var(--card);
      display: flex; flex-direction: column;
      transform: translateX(100%); transition: transform .25s ease;
      box-shadow: -6px 0 32px rgba(0,0,0,.18);
    }
    .modal-overlay.open .modal-panel { transform: translateX(0); }
    .modal-header {
      padding: 1rem 1.25rem; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
      flex-shrink: 0; gap: .75rem;
    }
    .modal-title { font-size: 1rem; font-weight: 800; }
    .modal-close {
      width: 30px; height: 30px; border-radius: 6px; border: none;
      background: var(--bg); cursor: pointer; font-size: 1rem; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center; color: var(--muted);
    }
    .modal-close:hover { background: var(--border); }
    .modal-search {
      padding: .35rem .75rem; border: 1.5px solid var(--border); border-radius: 6px;
      font-size: .82rem; outline: none; flex: 1; max-width: 220px;
    }
    .modal-search:focus { border-color: var(--orange); }
    .modal-body { padding: 1rem 1.25rem; overflow-y: auto; flex: 1; font-size: .82rem; }
    .modal-count { font-size: .75rem; color: var(--muted); margin-left: .5rem; font-weight: normal; }
  </style>
</head>
<body>

<!-- ═══════════════════════════════════ LOGIN ═══════════════════════════════════ -->
<div id="login-screen">
  <div class="login-card">
    <div class="login-logo">🍂</div>
    <div class="login-title">Daily Life Hacks</div>
    <div class="login-sub">Enter dashboard password to continue</div>
    <div style="position:relative">
      <input id="pw-input" class="login-input" type="password" placeholder="Password" autocomplete="off" style="padding-right:2.5rem;width:100%;box-sizing:border-box" />
      <button type="button" onclick="togglePwVisible()" title="Show/hide password"
        style="position:absolute;right:.6rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:1rem;color:var(--muted-color)">👁</button>
    </div>
    <button class="login-btn" id="login-btn">Enter Dashboard</button>
    <div class="login-error" id="login-error">Wrong password. Try again.</div>
  </div>
</div>

<!-- ═══════════════════════════════════ APP ══════════════════════════════════════ -->
<div id="app">

  <!-- Top bar -->
  <div class="topbar">
    <span class="topbar-logo">🍂 DLH Dashboard</span>
    <span id="env-badge" class="env-badge staging">STAGING — אין פרסום אמיתי</span>
    <span class="topbar-meta">
      Build: <span id="build-time">—</span> &nbsp;|&nbsp;
      <span id="refresh-status">Loading live data<span class="loading-dots"></span></span>
    </span>
    <div class="toggle-group">
      <button class="toggle-btn" id="btn-1" onclick="setPeriod(1)">24h</button>
      <button class="toggle-btn" id="btn-7" onclick="setPeriod(7)">7 days</button>
      <button class="toggle-btn active" id="btn-30" onclick="setPeriod(30)">30 days</button>
    </div>
    <button class="refresh-btn" id="refresh-btn" onclick="refreshData()" title="Refresh live data">↻</button>
    <button class="logout-btn" onclick="logout()">Logout</button>
  </div>

  <main>

    <!-- ── TOP STATS ──────────────────────────────────────────────────────── -->
    <div class="stats-row">
      <div class="stat-card clickable" onclick="openModal('articles')" title="Click to see all articles">
        <div class="stat-label">Articles</div>
        <div class="stat-value" id="s-articles">—</div>
        <div class="stat-sub" id="s-articles-sub">loading...</div>
      </div>
      <div class="stat-card green clickable" onclick="openModal('published')" title="Click to see published articles">
        <div class="stat-label">Published</div>
        <div class="stat-value" id="s-published">—</div>
        <div class="stat-sub" id="s-last-pub">last: —</div>
      </div>
      <div class="stat-card blue clickable" onclick="openModal('scheduled')" title="Click to see scheduled articles">
        <div class="stat-label">Scheduled</div>
        <div class="stat-value" id="s-scheduled">—</div>
        <div class="stat-sub" id="s-next-pub">next: —</div>
      </div>
      <div class="stat-card purple clickable" onclick="openModal('pins')" title="Click to see all pins">
        <div class="stat-label">Pins</div>
        <div class="stat-value" id="s-pins">—</div>
        <div class="stat-sub" id="s-pins-sub">—</div>
      </div>
      <div class="stat-card orange clickable" onclick="openModal('images')" title="Click to see images list">
        <div class="stat-label">Images</div>
        <div class="stat-value" id="s-images">—</div>
        <div class="stat-sub" id="s-images-sub">—</div>
      </div>
      <div class="stat-card green clickable" onclick="openModal('subscribers')" title="Click to see subscriber list">
        <div class="stat-label">Subscribers</div>
        <div class="stat-value" id="s-subs">—</div>
        <div class="stat-sub" id="s-subs-sub">loading...</div>
      </div>
      <div class="stat-card blue clickable" onclick="openModal('pageviews')" title="Click to see requests by country (note: different metric)">
        <div class="stat-label">Pageviews</div>
        <div class="stat-value" id="s-pv">—</div>
        <div class="stat-sub" id="s-pv-sub">loading...</div>
      </div>
      <div class="stat-card purple clickable" onclick="openModal('visitors')" title="Click to see requests by country (note: different metric)">
        <div class="stat-label">Visitors</div>
        <div class="stat-value" id="s-uv">—</div>
        <div class="stat-sub" id="s-uv-sub">loading...</div>
      </div>
    </div>

    <!-- ── PIPELINE CONTROL CENTER ──────────────────────────────────────── -->
    <div class="card section-gap" id="automation-health-card">
      <div class="automation-health-head">
        <div>
          <div class="card-title" style="margin-bottom:.25rem">Automation Health</div>
          <div class="automation-health-summary">
            <span id="automation-overall" class="automation-health-badge unknown">Loading</span>
            <span id="automation-generated">Checking GitHub Actions...</span>
          </div>
        </div>
        <button class="refresh-btn" id="automation-refresh-btn" onclick="fetchAutomationHealth()" title="Refresh automation health">↻</button>
      </div>
      <div id="automation-health-grid" class="automation-health-grid">
        <div class="empty">Loading workflow status...</div>
      </div>
    </div>

    <div class="card section-gap" id="pipeline-section">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.75rem;flex-wrap:wrap;gap:.5rem">
        <div class="card-title" style="margin-bottom:0">Pipeline Control Center</div>
        <div style="display:flex;gap:.5rem;flex-wrap:wrap">
          <select id="discover-limit" title="Maximum new topic candidates" style="padding:.3rem .5rem;border-radius:6px;border:1px solid var(--border);background:var(--card-bg);color:var(--text-color);font-size:.8rem">
            <option value="6">6 topics</option>
            <option value="12" selected>12 topics</option>
            <option value="20">20 topics</option>
          </select>
          <select id="discover-category" title="Topic category filter" style="padding:.3rem .5rem;border-radius:6px;border:1px solid var(--border);background:var(--card-bg);color:var(--text-color);font-size:.8rem">
            <option value="">Any category</option>
            <option value="recipes">Recipes</option>
            <option value="nutrition">Nutrition</option>
            <option value="tips">Tips</option>
          </select>
          <button class="btn btn-sm" onclick="triggerPipeline('discover')" id="btn-discover">Find Topics</button>
          <select id="produce-count" style="padding:.3rem .5rem;border-radius:6px;border:1px solid var(--border);background:var(--card-bg);color:var(--text-color);font-size:.8rem">
            <option value="1" selected>1 article</option>
            <option value="2">2 articles</option>
            <option value="3">3 articles</option>
          </select>
          <button class="btn btn-sm" onclick="triggerPipeline('produce')" id="btn-produce">Generate to Staging</button>
          <button class="btn btn-sm" onclick="triggerPipeline('publish')" id="btn-publish">Legacy Publish to Main</button>
        </div>
      </div>
      <div style="padding:.55rem .75rem;border-radius:6px;background:#f8fafc;border:1px solid var(--border);font-size:.78rem;color:var(--muted);margin-bottom:.75rem">
        Find Topics pulls GSC opportunity queries and Google Autocomplete seed expansions, then runs deterministic filters and an LLM semantic duplicate check against existing site and pipeline topics before adding a small review queue to <strong style="color:var(--text-color)">staging D1</strong>. Generate creates one full staging package: article, hero image, support image, and four pin images. Pinterest remains manual.
      </div>

      <!-- Pipeline stat cards -->
      <div class="stats-grid" style="margin-bottom:1rem">
        <div class="stat-card blue clickable" onclick="openModal('pipeline-topics')" title="Click to see topics">
          <div class="stat-label">Approved Topics</div>
          <div class="stat-value" id="pl-topics-approved">-</div>
          <div class="stat-sub" id="pl-topics-sub">0 pending, 0 rejected</div>
        </div>
        <div class="stat-card green">
          <div class="stat-label">In Production</div>
          <div class="stat-value" id="pl-in-production">-</div>
          <div class="stat-sub">writing / reviewing / images</div>
        </div>
        <div class="stat-card purple">
          <div class="stat-label">Ready for Review</div>
          <div class="stat-value" id="pl-ready">-</div>
          <div class="stat-sub">full staging assets ready</div>
        </div>
        <div class="stat-card orange">
          <div class="stat-label">Total Cost</div>
          <div class="stat-value" id="pl-cost">-</div>
          <div class="stat-sub" id="pl-cost-sub">USD across all articles</div>
        </div>
      </div>

      <!-- Manual topic input -->
      <div style="display:flex;gap:.5rem;margin-bottom:1rem;flex-wrap:wrap;align-items:center">
        <input type="text" id="manual-topic" placeholder="Add topic manually..." style="flex:1;min-width:200px;padding:.4rem .7rem;border-radius:6px;border:1px solid var(--border);background:var(--card-bg);color:var(--text-color);font-size:.85rem">
        <select id="manual-category" style="padding:.4rem .5rem;border-radius:6px;border:1px solid var(--border);background:var(--card-bg);color:var(--text-color);font-size:.85rem">
          <option value="recipes">Recipes</option>
          <option value="nutrition">Nutrition</option>
          <option value="tips">Tips</option>
        </select>
        <button class="btn btn-sm" onclick="addManualTopic()">+ Add Topic</button>
      </div>

      <!-- Pipeline trigger status -->
      <div id="pipeline-trigger-status" style="display:none;padding:.5rem .75rem;border-radius:6px;margin-bottom:.75rem;font-size:.8rem;border:1px solid transparent"></div>

      <!-- Filter tabs -->
      <div style="display:flex;gap:.35rem;margin-bottom:.55rem;flex-wrap:wrap">
        <button class="btn btn-sm active" onclick="filterPipeline('all', this)" id="pl-filter-all">All</button>
        <button class="btn btn-sm" onclick="filterPipeline('progress', this)">In Progress</button>
        <button class="btn btn-sm" onclick="filterPipeline('ready', this)">Ready</button>
        <button class="btn btn-sm" onclick="filterPipeline('failed', this)">Failed</button>
      </div>

      <div id="pipeline-pin-bulk-bar" style="display:flex;align-items:center;justify-content:space-between;gap:.75rem;flex-wrap:wrap;margin-bottom:.75rem;padding:.55rem .7rem;border:1px solid var(--border);border-radius:8px;background:#f8fafc">
        <div style="font-size:.78rem;color:var(--muted)">
          <strong style="color:var(--text-color)">Selected pins:</strong>
          <span id="pl-selected-pins-count">0</span>
          <span id="pl-selected-pins-help">Choose pins below, then publish them together.</span>
          <span id="pl-image-filter-note" style="margin-left:.45rem"></span>
        </div>
        <div style="display:flex;gap:.4rem;align-items:center;flex-wrap:wrap">
          <button class="btn btn-sm" onclick="clearPipelinePinSelection()" id="pl-clear-selected-pins" disabled>Clear</button>
          <button class="btn btn-sm" onclick="approveSelectedPipelinePins()" id="pl-publish-selected" disabled>Publish selected pins</button>
        </div>
      </div>

      <!-- Pipeline table -->
      <div style="overflow-x:auto">
        <table class="data-table" id="pipeline-table">
          <thead>
            <tr>
              <th>Slug</th>
              <th>Category</th>
              <th>Stage</th>
              <th>Words</th>
              <th>Pins</th>
              <th>Cost</th>
              <th>Updated</th>
            </tr>
          </thead>
          <tbody id="pipeline-tbody"></tbody>
        </table>
      </div>
      <div id="pipeline-empty" class="empty" style="display:none">No pipeline data yet. Click "Find Topics" to start.</div>
    </div>

    <!-- ── CLARITY ANALYTICS ────────────────────────────────────────────────── -->
    <!-- ── TRAFFIC CHART ──────────────────────────────────────────────────── -->
    <!-- ── ARTICLES + CONTENT PIPELINE ───────────────────────────────────── -->
    <div id="traffic-error" style="display:none"></div>

    <div class="grid-2">

      <!-- Articles by category -->
      <div class="card">
        <div class="card-title">Articles by Category</div>
        <div id="cat-bars">
          <div class="cat-row">
            <span class="cat-label">Nutrition</span>
            <div class="cat-bar-wrap"><div class="cat-bar" id="bar-nutrition" style="width:0%"></div></div>
            <span class="cat-count" id="cnt-nutrition">—</span>
          </div>
          <div class="cat-row">
            <span class="cat-label">Recipes</span>
            <div class="cat-bar-wrap"><div class="cat-bar" id="bar-recipes" style="width:0%;background:var(--green)"></div></div>
            <span class="cat-count" id="cnt-recipes">—</span>
          </div>
          <div class="cat-row">
            <span class="cat-label">Tips</span>
            <div class="cat-bar-wrap"><div class="cat-bar" id="bar-tips" style="width:0%;background:var(--purple)"></div></div>
            <span class="cat-count" id="cnt-tips">—</span>
          </div>
        </div>
        <div style="margin-top:1rem">
          <div class="card-title">Published vs Total</div>
          <div class="cat-row">
            <span class="cat-label">Nutrition</span>
            <div class="cat-bar-wrap"><div class="cat-bar" id="pbar-nutrition" style="width:0%"></div></div>
            <span class="cat-count" id="pcnt-nutrition">—</span>
          </div>
          <div class="cat-row">
            <span class="cat-label">Recipes</span>
            <div class="cat-bar-wrap"><div class="cat-bar" id="pbar-recipes" style="width:0%;background:var(--green)"></div></div>
            <span class="cat-count" id="pcnt-recipes">—</span>
          </div>
          <div class="cat-row">
            <span class="cat-label">Tips</span>
            <div class="cat-bar-wrap"><div class="cat-bar" id="pbar-tips" style="width:0%;background:var(--purple)"></div></div>
            <span class="cat-count" id="pcnt-tips">—</span>
          </div>
        </div>
      </div>

      <!-- Content pipeline -->
      <div class="card">
        <div class="card-title">Content Pipeline (Tracker)</div>
        <div id="pipeline-bars"></div>
        <div style="margin-top:1.25rem">
          <div class="card-title">Pins by Category</div>
          <div id="pins-cat-bars"></div>
        </div>
      </div>

    </div>

    <!-- ── IMAGES STATUS + PINS BOARDS ───────────────────────────────────── -->
    <div class="grid-2">

      <!-- Images status -->
      <div class="card">
        <div class="card-title">Images Status</div>
        <table class="data-table">
          <thead><tr><th>Type</th><th>Have</th><th>Missing</th></tr></thead>
          <tbody>
            <tr><td>Web images (main)</td><td id="img-have-web">—</td><td id="img-miss-web">—</td></tr>
            <tr><td>Pin images</td><td id="img-have-pin">—</td><td id="img-miss-pin">—</td></tr>
            <tr><td>Total web files</td><td id="img-total-web">—</td><td>—</td></tr>
            <tr><td>Total pin files</td><td id="img-total-pin">—</td><td>—</td></tr>
          </tbody>
        </table>
        <button class="collapse-btn" onclick="toggleCollapse('missing-web-list')">
          Show articles missing web image ▾
        </button>
        <div class="collapsible" id="missing-web-list">
          <table class="data-table" style="margin-top:.5rem">
            <thead><tr><th>Slug</th><th>Category</th><th>Status</th></tr></thead>
            <tbody id="missing-web-tbody"></tbody>
          </table>
        </div>
        <button class="collapse-btn" onclick="toggleCollapse('missing-pin-list')" style="margin-top:.75rem">
          Show articles missing pin images ▾
        </button>
        <div class="collapsible" id="missing-pin-list">
          <table class="data-table" style="margin-top:.5rem">
            <thead><tr><th>Slug</th><th>Category</th><th>Status</th></tr></thead>
            <tbody id="missing-pin-tbody"></tbody>
          </table>
        </div>
      </div>

      <!-- Pins breakdown -->
      <div class="card">
        <div class="card-title">Pinterest Boards</div>
        <div id="pins-board-list"></div>
        <div style="margin-top:1.25rem">
          <div class="card-title">Pins by Status</div>
          <div id="pins-status-list"></div>
        </div>
        <div style="margin-top:1.25rem">
          <div class="card-title">Pin Clicks from Site (D1) — last <span class="period-label">30</span> days</div>
          <div id="pinterest-hits-info"></div>
        </div>
      </div>

    </div>

    <!-- ── PINTEREST ANALYTICS ─────────────────────────────────────────────── -->
    <div class="card section-gap">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.75rem">
        <div>
          <div class="card-title" style="margin-bottom:0">Pinterest Analytics — Top Pins</div>
          <div id="pa-cache-note" style="font-size:.72rem;color:var(--muted);margin-top:.2rem"></div>
        </div>
        <div style="display:flex;gap:.5rem;align-items:center">
          <button id="pa-trigger-btn" onclick="triggerFetchAnalytics()"
            title="Run GitHub Actions to fetch fresh data from Pinterest API"
            style="font-size:.8rem;padding:.35rem .85rem;border-radius:6px;border:1px solid #E60023;background:#E60023;color:#fff;cursor:pointer;font-weight:600">
            ↻ Refresh from Pinterest
          </button>
          <button id="pa-load-btn" onclick="loadPinterestAnalytics()"
            title="Load cached analytics from D1"
            style="font-size:.8rem;padding:.35rem .85rem;border-radius:6px;border:1px solid var(--border);background:var(--card-bg);color:var(--text-color);cursor:pointer">
            Load Analytics
          </button>
        </div>
      </div>
      <div id="pa-loading"  class="empty" style="display:none">Fetching Pinterest analytics...</div>
      <div id="pa-error"    class="empty" style="display:none"></div>
      <div id="pa-content"  style="display:none">
        <!-- Account totals row -->
        <div class="stats-grid" style="margin-bottom:1.25rem">
          <div class="stat-card blue">
            <div class="stat-label">Impressions</div>
            <div class="stat-value" id="pa-total-imp">—</div>
            <div class="stat-sub">last 90 days</div>
          </div>
          <div class="stat-card orange">
            <div class="stat-label">Outbound Clicks</div>
            <div class="stat-value" id="pa-total-clicks">—</div>
            <div class="stat-sub">to site</div>
          </div>
          <div class="stat-card green">
            <div class="stat-label">Saves</div>
            <div class="stat-value" id="pa-total-saves">—</div>
            <div class="stat-sub">re-pins</div>
          </div>
          <div class="stat-card purple">
            <div class="stat-label">Pins Tracked</div>
            <div class="stat-value" id="pa-total-pins">—</div>
            <div class="stat-sub">top 50</div>
          </div>
        </div>
        <!-- Pins table -->
        <table class="data-table" id="pa-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Pin Title</th>
              <th>Created</th>
              <th id="pa-th-impressions" style="cursor:pointer" onclick="paSortBy('impressions')">Impressions ↓</th>
              <th id="pa-th-outbound_clicks" style="cursor:pointer" onclick="paSortBy('outbound_clicks')">Clicks ↕</th>
              <th id="pa-th-saves" style="cursor:pointer" onclick="paSortBy('saves')">Saves ↕</th>
            </tr>
          </thead>
          <tbody id="pa-tbody"></tbody>
        </table>
        <!-- Pagination -->
        <div style="display:flex;align-items:center;justify-content:space-between;margin-top:.75rem;font-size:.85rem">
          <button id="pa-prev" onclick="paPage(-1)"
            style="padding:.3rem .75rem;border-radius:6px;border:1px solid var(--border);background:var(--card-bg);color:var(--text-color);cursor:pointer">
            ← Prev
          </button>
          <span id="pa-page-info" style="color:var(--muted)"></span>
          <button id="pa-next" onclick="paPage(1)"
            style="padding:.3rem .75rem;border-radius:6px;border:1px solid var(--border);background:var(--card-bg);color:var(--text-color);cursor:pointer">
            Next →
          </button>
        </div>
      </div>
    </div>

    <!-- ── PINTEREST TRENDS ──────────────────────────────────────────────── -->
    <div class="card section-gap">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.75rem">
        <div>
          <div class="card-title" style="margin-bottom:0">Pinterest Trending Keywords</div>
          <div id="pt-cache-note" style="font-size:.72rem;color:var(--muted);margin-top:.2rem">US · Growing · Food &amp; Recipes</div>
        </div>
        <button id="pt-load-btn" onclick="loadTrends()"
          style="font-size:.8rem;padding:.35rem .85rem;border-radius:6px;border:1px solid var(--border);background:var(--card-bg);color:var(--text-color);cursor:pointer">
          ↻ Load Trends
        </button>
      </div>
