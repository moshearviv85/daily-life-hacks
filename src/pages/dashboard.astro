function setHeroImageStatus(slug, message, tone = 'pending') {
  const el = document.getElementById(`pipeline-hero-status-${slug}`);
  if (!el) return;
  const colors = { pending: '#92400e', success: '#166534', error: '#b91c1c' };
  el.style.display = '';
  el.style.color = colors[tone] || colors.pending;
  el.textContent = message;
}

function setHeroImageBusy(slug, busy) {
  const btn = document.getElementById(`pipeline-hero-btn-${slug}`);
  if (!btn) return;
  btn.disabled = busy;
  btn.style.opacity = busy ? '0.65' : '1';
  btn.style.cursor = busy ? 'wait' : 'pointer';
}

function delay(ms) {
  return new Promise(resolve => setTimeout(resolve, ms));
}

async function getHeroImageSignal(heroSrc) {
  const url = `${heroSrc}${heroSrc.includes('?') ? '&' : '?'}probe=${Date.now()}`;
  try {
    const res = await fetch(url, { method: 'HEAD', cache: 'no-store' });
    if (!res.ok) return '';
    return [
      res.headers.get('etag') || '',
      res.headers.get('last-modified') || '',
      res.headers.get('content-length') || '',
    ].join('|');
  } catch {
    return '';
  }
}

async function watchHeroImageReplacement(slug, heroSrc, initialSignal) {
  for (let attempt = 1; attempt <= 18; attempt += 1) {
    await delay(20000);
    const nextSignal = await getHeroImageSignal(heroSrc);
    const img = document.getElementById(`pipeline-hero-img-${slug}`);
    const version = String(Date.now());
    heroImageVersions.set(slug, version);
    if (img) {
      img.src = `${heroSrc}${heroSrc.includes('?') ? '&' : '?'}v=${version}`;
    }
    if (nextSignal && initialSignal && nextSignal !== initialSignal) {
      setHeroImageStatus(slug, 'New image is live. Thumbnail refreshed.', 'success');
      setHeroImageBusy(slug, false);
      fetchPipelineStatus();
      return;
    }
    const minutes = Math.ceil((attempt * 20) / 60);
    setHeroImageStatus(slug, `Still waiting for the new image... about ${minutes} min elapsed.`, 'pending');
  }

  setHeroImageStatus(slug, 'Still checking. The thumbnail was refreshed repeatedly without reloading the dashboard.', 'pending');
  setHeroImageBusy(slug, false);
}

async function regenerateHeroImage(slug, heroSrc) {
  if (!pw) {
    alert('Sign in to the dashboard before regenerating an image.');
    return;
  }
  const ok = confirm(`Regenerate the staging hero image?\n\n${slug}\n\nThis creates only a new hero image and updates alt text. It does not change article copy and does not regenerate pins.`);
  if (!ok) return;

  const statusEl = document.getElementById('pipeline-trigger-status');
  statusEl.style.display = '';
  statusEl.style.background = '#fff7ed';
  statusEl.style.borderColor = '#fed7aa';
  statusEl.style.color = '#92400e';
  statusEl.textContent = `Dispatching hero image regeneration for ${slug}...`;
  setHeroImageBusy(slug, true);
  setHeroImageStatus(slug, 'Dispatching workflow...', 'pending');

  const initialSignal = await getHeroImageSignal(heroSrc);

  try {
    const res = await fetch(`/api/pipeline-trigger?key=${encodeURIComponent(pw)}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'regenerate_hero', slug }),
    });
    const data = await res.json();
    if (!res.ok || !data.ok) throw new Error(data.error || data.gh_body || 'Unknown error');

    statusEl.style.background = '#f0fdf4';
    statusEl.style.borderColor = '#bbf7d0';
    statusEl.style.color = '#166534';
    statusEl.textContent = `Hero image workflow dispatched for ${slug}. Target: ${data.outputBranch || 'staging'}. This usually takes 2-4 minutes.`;
    setHeroImageStatus(slug, 'Workflow sent. Watching for the new image...', 'pending');
    watchHeroImageReplacement(slug, heroSrc, initialSignal);
  } catch (e) {
    statusEl.style.background = '#fef2f2';
    statusEl.style.borderColor = '#fecaca';
    statusEl.style.color = '#b91c1c';
    statusEl.textContent = `Failed: ${e.message}`;
    setHeroImageStatus(slug, `Failed: ${e.message}`, 'error');
    setHeroImageBusy(slug, false);
  }
}

function getSelectedPipelinePinsInterleaved() {
  const selected = Array.from(document.querySelectorAll('.pipeline-pin-select:checked'))
    .map((input) => ({
      slug: input.value,
      article: input.dataset.articleSlug || '',
      index: Number.parseInt(input.dataset.pinIndex || '0', 10) || 0,
    }));
  const buckets = new Map();
  for (const pin of selected) {
    if (!buckets.has(pin.article)) buckets.set(pin.article, []);
    buckets.get(pin.article).push(pin);
  }
  for (const bucket of buckets.values()) bucket.sort((a, b) => a.index - b.index);
  const out = [];
  while (buckets.size) {
    for (const [article, bucket] of Array.from(buckets.entries()).sort(([a], [b]) => a.localeCompare(b))) {
      const next = bucket.shift();
      if (next) out.push(next.slug);
      if (!bucket.length) buckets.delete(article);
    }
  }
  return out;
}

function updatePipelinePinSelectionSummary() {
  const selectedCount = document.querySelectorAll('.pipeline-pin-select:checked').length;
  const availableCount = document.querySelectorAll('.pipeline-pin-select').length;
  const countEl = document.getElementById('pl-selected-pins-count');
  const helpEl = document.getElementById('pl-selected-pins-help');
  const publishBtn = document.getElementById('pl-publish-selected');
  const clearBtn = document.getElementById('pl-clear-selected-pins');

  if (countEl) countEl.textContent = String(selectedCount);
  if (helpEl) {
    helpEl.textContent = availableCount
      ? ` of ${availableCount} visible publishable pin(s) selected.`
      : ' No visible pins are ready for publishing.';
  }

  if (publishBtn) {
    const action = IS_PRODUCTION_DASHBOARD ? 'Publish' : 'Queue';
    publishBtn.disabled = selectedCount === 0;
    publishBtn.textContent = selectedCount
      ? `${action} selected pins (${selectedCount})`
      : `${action} selected pins`;
    publishBtn.title = IS_PRODUCTION_DASHBOARD
      ? 'Add the selected pins to the production Pinterest publisher queue.'
      : 'Queue the selected pins in staging only.';
    publishBtn.style.opacity = selectedCount ? '1' : '0.55';
    publishBtn.style.cursor = selectedCount ? 'pointer' : 'not-allowed';
  }

  if (clearBtn) {
    clearBtn.disabled = selectedCount === 0;
    clearBtn.style.opacity = selectedCount ? '1' : '0.55';
    clearBtn.style.cursor = selectedCount ? 'pointer' : 'not-allowed';
  }
}

function clearPipelinePinSelection() {
  document.querySelectorAll('.pipeline-pin-select:checked').forEach((input) => {
    input.checked = false;
  });
  updatePipelinePinSelectionSummary();
}

async function approveSelectedPipelinePins() {
  const pinSlugs = getSelectedPipelinePinsInterleaved();
  if (!pinSlugs.length) {
    alert('Select at least one pin first.');
    return;
  }
  const ok = confirm(`${IS_PRODUCTION_DASHBOARD ? 'Publish' : 'Queue'} ${pinSlugs.length} selected pin(s)?\n\nPins will be interleaved by article to avoid publishing the same topic in a block.${IS_PRODUCTION_DASHBOARD ? '\n\nThis adds them to the automatic publisher queue; it does not post all of them instantly.' : ''}`);
  if (!ok) return;

  const publishBtn = document.getElementById('pl-publish-selected');
  if (publishBtn) {
    publishBtn.disabled = true;
    publishBtn.textContent = IS_PRODUCTION_DASHBOARD ? 'Publishing selected...' : 'Queueing selected...';
  }

  const statusEl = document.getElementById('pipeline-trigger-status');
  statusEl.style.display = '';
  statusEl.style.background = '#fff7ed';
  statusEl.style.borderColor = '#fed7aa';
  statusEl.style.color = '#92400e';

  const results = [];
  for (const [index, slug] of pinSlugs.entries()) {
    statusEl.textContent = `${IS_PRODUCTION_DASHBOARD ? 'Publishing' : 'Queueing'} selected pins ${index + 1}/${pinSlugs.length}: ${slug}`;
    const result = await approvePipelinePin(slug, {
      skipConfirm: true,
      quiet: true,
      skipRefresh: true,
      skipScroll: true,
    });
    results.push({ slug, ...result });
  }

  await Promise.all([loadPinsStatus(), fetchPipelineStatus()]);
  const failed = results.filter(result => !result.ok);
  statusEl.style.background = failed.length ? '#fef2f2' : '#f0fdf4';
  statusEl.style.borderColor = failed.length ? '#fecaca' : '#bbf7d0';
  statusEl.style.color = failed.length ? '#b91c1c' : '#166534';
  statusEl.textContent = failed.length
    ? `${failed.length}/${pinSlugs.length} selected pin(s) failed. First error: ${failed[0].error || failed[0].slug}`
    : `${pinSlugs.length} selected pin(s) added to the publisher queue.`;
  updatePipelinePinSelectionSummary();
}

async function promoteStagingToProduction(slug = '') {
  if (!pw) return;
  const ok = confirm(`${slug ? 'Publish this reviewed article to production?' : 'Promote staging to production now?'}\n\n${slug ? `Triggered from: ${slug}\n\n` : ''}This runs the promotion workflow, verifies the staging build, then fast-forwards main to staging. If staging contains more reviewed changes, those changes move too. It does not post to Pinterest.`);
  if (!ok) return;

  const statusEl = document.getElementById('pipeline-trigger-status');
  statusEl.style.display = '';
  statusEl.style.background = '#fff7ed';
  statusEl.style.borderColor = '#fed7aa';
  statusEl.style.color = '#92400e';
  statusEl.textContent = 'Dispatching staging promotion workflow...';

  try {
    const res = await fetch(`/api/pipeline-trigger?key=${encodeURIComponent(pw)}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'promote_staging' }),
    });
    const data = await res.json();
    if (!res.ok || !data.ok) {
      throw new Error(data.error || data.gh_body || 'Unknown error');
    }

    statusEl.style.background = '#f0fdf4';
    statusEl.style.borderColor = '#bbf7d0';
    statusEl.style.color = '#166534';
    statusEl.innerHTML = `Promotion workflow dispatched. Waiting for production deploy, then reload this dashboard before queueing pins.${pipelineActionsLink(data)}`;
    statusEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
  } catch (e) {
    statusEl.style.background = '#fef2f2';
    statusEl.style.borderColor = '#fecaca';
    statusEl.style.color = '#b91c1c';
    statusEl.textContent = `Failed: ${e.message}`;
  }
}

async function publishPipelineArticle(slug) {
  if (!pw) return;
  const statusEl = document.getElementById('pipeline-trigger-status');
  if (!IS_PRODUCTION_DASHBOARD) {
    const dashboardUrl = `https://www.daily-life-hacks.com/dashboard/`;
    statusEl.style.display = '';
    statusEl.style.background = '#fff7ed';
    statusEl.style.borderColor = '#fed7aa';
    statusEl.style.color = '#92400e';
    statusEl.innerHTML = `Publishing is locked on staging. Open the <a href="${dashboardUrl}" target="_blank" rel="noopener" style="color:inherit;text-decoration:underline;font-weight:800">production dashboard</a>, then use Publish Article for ${escapeHtml(slug)}.`;
    statusEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }
  await promoteStagingToProduction(slug);
}

async function approvePipelinePin(pinSlug, options = {}) {
  if (!pw) return;
  const ok = options.skipConfirm || confirm(IS_PRODUCTION_DASHBOARD
    ? `Queue this pin for automatic publishing?\n\n${pinSlug}\n\nIt will enter the next available PENDING slot. If the queue is empty, the first slot starts now. The publisher still respects the normal cooldown.`
    : `Queue this pin in staging?\n\n${pinSlug}\n\nA PENDING staging row will be created only. No GitHub Actions run and no Pinterest post will happen.`);
  if (!ok) return;

  const statusEl = document.getElementById('pipeline-trigger-status');
  if (!options.quiet) {
    statusEl.style.display = '';
    statusEl.style.background = '#fff7ed';
    statusEl.style.borderColor = '#fed7aa';
    statusEl.style.color = '#92400e';
    statusEl.textContent = IS_PRODUCTION_DASHBOARD
      ? 'Queueing pin for automatic publishing...'
      : 'Queueing pin in staging without publishing...';
  }

  try {
    const res = await fetch(`/api/pipeline-pin-approve?key=${encodeURIComponent(pw)}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ pin_slug: pinSlug, publish_now: false }),
    });
    const data = await res.json();
    if (!res.ok || !data.ok) {
      statusEl.style.background = '#fef2f2';
      statusEl.style.borderColor = '#fecaca';
      statusEl.style.color = '#b91c1c';
      statusEl.textContent = `שגיאה: ${data.error || res.statusText}`;
      return { ok: false, error: data.error || res.statusText, data };
    }
    statusEl.style.background = '#f0fdf4';
    statusEl.style.borderColor = '#bbf7d0';
    statusEl.style.color = '#166534';
    const statusText = data.status === 'POSTED'
      ? `הפין ${data.row_id} כבר פורסם.`
      : `הפין ${data.row_id} ${data.already_exists ? 'כבר נמצא' : 'נכנס'} במסילה כ-PENDING לתאריך ${data.scheduled_date} בשעה ${data.scheduled_time}.`;
    statusEl.textContent = statusText;
    if (!options.skipScroll) statusEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    if (!options.skipRefresh) {
      loadPinsStatus();
      fetchPipelineStatus();
    }
    if (data.triggered) startPinPostedPolling();
    return { ok: true, statusText, data };
  } catch (e) {
    statusEl.style.background = '#fef2f2';
    statusEl.style.borderColor = '#fecaca';
    statusEl.style.color = '#b91c1c';
    statusEl.textContent = `נכשל: ${e.message}`;
    return { ok: false, error: e.message };
  }
}

async function addManualTopic() {
  const input = document.getElementById('manual-topic');
  const cat = document.getElementById('manual-category').value;
  const topic = input.value.trim();
  if (!topic) return;

  try {
    const res = await fetch(`/api/pipeline-topics?key=${encodeURIComponent(pw)}&action=add`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ topic, category: cat })
    });
    const data = await res.json();
    if (res.ok && data.ok) {
      input.value = '';
      fetchPipelineStatus();
    } else {
      alert('Error: ' + (data.error || 'Unknown'));
    }
  } catch (e) {
    alert('Failed: ' + e.message);
  }
}
