window.reschedulePins = reschedulePins;

async function triggerPostNow() {
  const btn    = document.getElementById('pins-post-now-btn');
  const pollEl = document.getElementById('pins-poll-status');
  if (!IS_PRODUCTION_DASHBOARD) {
    pollEl.style.display = '';
    pollEl.style.background = '#fef2f2';
    pollEl.style.borderColor = '#fecaca';
    pollEl.style.color = '#b91c1c';
    pollEl.textContent = 'Post Now חסום בסטייג׳ינג. אפשר להכניס פינים לתור סטייג׳ינג, אבל אי אפשר להפעיל פרסום אמיתי.';
    return;
  }
  btn.disabled = true;
  btn.textContent = 'Running...';
  pollEl.style.display = '';
  pollEl.style.background = '#fff7ed';
  pollEl.style.borderColor = '#fed7aa';
  pollEl.style.color = '#92400e';
  pollEl.textContent = 'שולח פקודה ל-GitHub Actions...';
  try {
    const res  = await fetch(`/api/pins-trigger?key=${encodeURIComponent(pw)}`, { method: 'POST' });
    const text = await res.text();
    let data;
    try { data = JSON.parse(text); } catch(_) { data = { error: text.slice(0, 300) }; }
    if (res.ok && data.ok) {
      pollEl.textContent = '✓ GitHub Actions הופעל — ממתין לפרסום...';
      startPinPostedPolling();
    } else {
      pollEl.style.background = '#fef2f2';
      pollEl.style.borderColor = '#fecaca';
      pollEl.style.color = '#b91c1c';
      pollEl.textContent = `שגיאה (${data.status || res.status}): ${data.error || 'לא ידוע'}`;
