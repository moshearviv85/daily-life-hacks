    if (!res.ok) return [];
    const data = await res.json();
    return data.topics || [];
  } catch { return []; }
}

function escapeHtml(value) {
  return String(value ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function renderTopicStatus(status) {
  const colors = {
    approved: ['#dcfce7', '#166534'],
    pending: ['#fef3c7', '#92400e'],
    queued: ['#fef3c7', '#92400e'],
    rejected: ['#fee2e2', '#991b1b'],
    produced: ['#dbeafe', '#1e40af'],
  };
  const [bg, fg] = colors[status] || ['#f3f4f6', '#374151'];
  return `<span style="display:inline-block;padding:.12rem .4rem;border-radius:4px;font-size:.68rem;font-weight:700;background:${bg};color:${fg}">${escapeHtml(status || 'unknown')}</span>`;
}

function getTopicSourceMeta(source) {
  const sources = {
    llm_gap: {
      label: 'AI Gap',
      detail: 'Generated by the LLM content-gap workflow from existing site topics.',
      cls: 'badge-blue',
    },
    autocomplete: {
      label: 'Google Autocomplete',
      detail: 'Discovered from Google Autocomplete suggestions.',
      cls: 'badge-orange',
    },
    gsc: {
      label: 'Search Console',
      detail: 'Discovered from Google Search Console query data.',
      cls: 'badge-green',
    },
    pinterest: {
      label: 'Pinterest Trends',
      detail: 'Discovered from Pinterest trend or audience data.',
      cls: 'badge-red',
    },
    manual: {
      label: 'Manual Backlog',
      detail: 'Added manually or imported from a curated backlog.',
      cls: 'badge-gray',
    },
  };
  return sources[source] || {
    label: source || 'Unknown',
    detail: 'No source metadata was saved for this topic.',
    cls: 'badge-gray',
  };
}

function renderTopicSource(source) {
  const meta = getTopicSourceMeta(source);
  return `<span class="badge ${meta.cls}" title="${escapeHtml(meta.detail)}">${escapeHtml(meta.label)}</span>`;
}

function getTopicCreatedDate(topic) {
  if (!topic?.created_at) return null;
  const raw = String(topic.created_at);
  const normalized = raw.includes('T') ? raw : raw.replace(' ', 'T') + 'Z';
  const date = new Date(normalized);
  return Number.isNaN(date.getTime()) ? null : date;
}

function sortTopicsNewestFirst(topics) {
  return [...topics].sort((a, b) => {
    const bTime = getTopicCreatedDate(b)?.getTime() || 0;
    const aTime = getTopicCreatedDate(a)?.getTime() || 0;
    if (bTime !== aTime) return bTime - aTime;
    return (Number(b.id) || 0) - (Number(a.id) || 0);
  });
}

function formatTopicCreatedAtLabel(date) {
  return date.toLocaleString([], {
    month: 'short',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
}

function renderTopicCreatedAt(topic) {
  const date = getTopicCreatedDate(topic);
  if (!date) return '<span style="color:var(--muted)">-</span>';
  const ageMs = Date.now() - date.getTime();
  const isNew = ageMs >= 0 && ageMs < 48 * 60 * 60 * 1000;
  const label = formatTopicCreatedAtLabel(date);
  const utcTitle = `${topic.created_at} UTC`;
  return `<div title="${escapeHtml(utcTitle)}" style="white-space:nowrap">
    <div style="font-variant-numeric:tabular-nums">${escapeHtml(label)}</div>
    ${isNew ? '<span class="badge badge-blue" style="margin-top:.18rem">New</span>' : ''}
  </div>`;
}

function renderTopicSourceSummary(topics) {
  const counts = topics.reduce((acc, topic) => {
    const key = topic.source || 'unknown';
    acc[key] = (acc[key] || 0) + 1;
    return acc;
  }, {});
  const ordered = Object.entries(counts).sort((a, b) => b[1] - a[1]);
  const badges = ordered.map(([source, count]) => {
    const meta = getTopicSourceMeta(source);
    return `<span class="badge ${meta.cls}" title="${escapeHtml(meta.detail)}">${escapeHtml(meta.label)}: ${count}</span>`;
  }).join(' ');
  const newest = sortTopicsNewestFirst(topics)[0];
  const newestDate = newest ? getTopicCreatedDate(newest) : null;
  const newestLabel = newestDate ? formatTopicCreatedAtLabel(newestDate) : '-';
  return `<div style="display:flex;align-items:center;gap:.45rem;flex-wrap:wrap;font-size:.76rem;color:var(--muted)">
    <span>${topics.length} visible</span>
    <span>Newest first</span>
    <span>Newest: ${escapeHtml(newestLabel)}</span>
    ${badges}
  </div>`;
}

function topicMatchesSearch(topic, query) {
  if (!query) return true;
  const sourceMeta = getTopicSourceMeta(topic.source);
  const haystack = `${topic.topic || ''} ${topic.slug || ''} ${topic.category || ''} ${topic.source || ''} ${sourceMeta.label} ${topic.status || ''} ${topic.created_at || ''}`.toLowerCase();
  return haystack.includes(query);
}

function topicMatchesStatusFilter(topic) {
  if (topicStatusFilter === 'all') return true;
  if (topicStatusFilter === 'pending') return topic.status === 'pending' || topic.status === 'queued';
  return topic.status === topicStatusFilter;
}

function topicMatchesOriginFilter(topic) {
  return topicOriginFilter === 'all' || topic.source === topicOriginFilter;
}

function getSearchedPipelineTopics() {
  const search = document.getElementById('modal-search');
  const q = search ? search.value.trim().toLowerCase() : '';
  return modalRows.filter(topic => topicMatchesSearch(topic, q));
}

function getVisiblePipelineTopics() {
  return sortTopicsNewestFirst(getSearchedPipelineTopics())
    .filter(topic => topicMatchesStatusFilter(topic) && topicMatchesOriginFilter(topic));
}

function refreshPipelineTopicsModal() {
  if (modalSearchKey !== 'pipeline-topics') return;
  const body = document.getElementById('modal-body');
  body.innerHTML = renderPipelineTopicsModal(getSearchedPipelineTopics());
  updateTopicSelectionSummary();
}

function getTopicStatusCounts(topics) {
  return {
    pending: topics.filter(topic => topic.status === 'pending' || topic.status === 'queued').length,
    approved: topics.filter(topic => topic.status === 'approved').length,
    produced: topics.filter(topic => topic.status === 'produced').length,
    rejected: topics.filter(topic => topic.status === 'rejected').length,
    all: topics.length,
  };
}

function getTopicOriginCounts(topics) {
  return topics.reduce((acc, topic) => {
    const key = topic.source || 'unknown';
    acc[key] = (acc[key] || 0) + 1;
    return acc;
  }, { all: topics.length });
}

function renderTopicFilterButton(kind, value, label, count) {
  const active = kind === 'status' ? topicStatusFilter === value : topicOriginFilter === value;
  const fn = kind === 'status' ? 'setTopicStatusFilter' : 'setTopicOriginFilter';
  return `<button class="btn btn-sm" onclick="${fn}('${escapeHtml(value)}')" style="${active ? 'background:var(--orange);border-color:var(--orange);color:#fff' : ''}">
    ${escapeHtml(label)} <span style="opacity:.75">${Number(count) || 0}</span>
  </button>`;
}

function renderTopicFilterBar(topics) {
  const statusCounts = getTopicStatusCounts(topics);
  const originCounts = getTopicOriginCounts(topics.filter(topic => topicMatchesStatusFilter(topic)));
  const sourceKeys = ['all', 'llm_gap', 'autocomplete', 'gsc', 'pinterest', 'manual'];
  return `<div style="display:flex;flex-direction:column;gap:.45rem;min-width:min(100%,720px)">
    <div style="display:flex;align-items:center;gap:.35rem;flex-wrap:wrap">
      <span style="font-size:.72rem;color:var(--muted);font-weight:700">Status</span>
      ${renderTopicFilterButton('status', 'pending', 'Needs review', statusCounts.pending)}
      ${renderTopicFilterButton('status', 'approved', 'Approved', statusCounts.approved)}
      ${renderTopicFilterButton('status', 'produced', 'Produced', statusCounts.produced)}
      ${renderTopicFilterButton('status', 'rejected', 'Rejected', statusCounts.rejected)}
      ${renderTopicFilterButton('status', 'all', 'All', statusCounts.all)}
    </div>
    <div style="display:flex;align-items:center;gap:.35rem;flex-wrap:wrap">
      <span style="font-size:.72rem;color:var(--muted);font-weight:700">Origin</span>
      ${sourceKeys.map(source => {
        const meta = source === 'all'
          ? { label: 'All origins', detail: 'Show all topic origins.' }
          : getTopicSourceMeta(source);
        return renderTopicFilterButton('origin', source, meta.label, originCounts[source] || 0);
      }).join('')}
    </div>
  </div>`;
}

function setTopicStatusFilter(status) {
  topicStatusFilter = status;
  refreshPipelineTopicsModal();
}

function setTopicOriginFilter(origin) {
  topicOriginFilter = origin;
  refreshPipelineTopicsModal();
}

function renderPipelineTopicsModal(topics) {
  const sortedTopics = sortTopicsNewestFirst(topics);
  const filteredTopics = sortedTopics.filter(topic => topicMatchesStatusFilter(topic) && topicMatchesOriginFilter(topic));
  const approved = filteredTopics.filter(t => t.status === 'approved');
  const pending = filteredTopics.filter(t => t.status === 'pending' || t.status === 'queued');
  const rejected = filteredTopics.filter(t => t.status === 'rejected');
  const produced = filteredTopics.filter(t => t.status === 'produced');
  const other = filteredTopics.filter(t => !['approved', 'pending', 'queued', 'rejected', 'produced'].includes(t.status));
  const deletableVisible = filteredTopics.filter(t => t.status === 'pending' || t.status === 'queued').length;
  const deleteDisabled = topicOriginFilter === 'all' || deletableVisible === 0;
  const deleteLabel = topicOriginFilter === 'all'
    ? 'Choose origin to delete'
    : `Delete visible pending (${deletableVisible})`;

  const toolbar = `
    <div style="position:sticky;top:-1rem;z-index:2;background:var(--card-bg);border:1px solid var(--border);border-radius:8px;padding:.6rem .7rem;margin-bottom:.8rem;display:flex;align-items:center;justify-content:space-between;gap:.75rem;flex-wrap:wrap">
      ${renderTopicFilterBar(sortedTopics)}
      <div style="display:flex;align-items:center;gap:.45rem;flex-wrap:wrap">
        <button class="btn btn-sm" onclick="setTopicSelection(true)">Select visible</button>
        <button class="btn btn-sm" onclick="setTopicSelection(false)">Clear</button>
        <span id="topic-selection-summary" style="font-size:.75rem;color:var(--muted)">0 selected</span>
      </div>
      <div style="display:flex;align-items:center;gap:.45rem;flex-wrap:wrap">
        <button class="btn btn-sm" onclick="updateSelectedTopics('approve')">Approve</button>
        <button class="btn btn-sm" onclick="updateSelectedTopics('reject')" style="background:#ef4444;color:#fff;border-color:#ef4444">Reject</button>
        <button class="btn btn-sm" onclick="produceSelectedTopics()" style="background:#16a34a;color:#fff;border-color:#16a34a">Produce 1 Selected to Staging</button>
        <button class="btn btn-sm" onclick="deleteVisiblePendingTopics()" ${deleteDisabled ? 'disabled' : ''} title="Deletes only pending/queued topics in the current filtered view. Approved and produced topics are never deleted." style="background:#991b1b;color:#fff;border-color:#991b1b;${deleteDisabled ? 'opacity:.45;cursor:not-allowed' : ''}">${deleteLabel}</button>
        <button class="btn btn-sm" onclick="resetPipelineTopicBank()" ${sortedTopics.length ? '' : 'disabled'} title="Deletes every row from pipeline_topics only. Articles and pins are not deleted." style="background:#450a0a;color:#fff;border-color:#450a0a;${sortedTopics.length ? '' : 'opacity:.45;cursor:not-allowed'}">Clear topic bank (${sortedTopics.length})</button>
      </div>
      ${renderTopicSourceSummary(filteredTopics)}
    </div>`;

  const sections = [
    ['Pending', pending, 'var(--warning, #e6a700)'],
    ['Approved', approved, 'var(--success)'],
    ['Produced', produced, '#2563eb'],
    ['Rejected', rejected, 'var(--danger, #d32f2f)'],
    ['Other', other, 'var(--muted)'],
  ];

  const lists = sections
    .filter(([, rows]) => rows.length)
    .map(([label, rows, color], index) => `
      <h4 style="margin:${index === 0 ? '0' : '1rem'} 0 .5rem;color:${color}">${label} (${rows.length})</h4>
      ${renderTopicsList(rows)}
    `).join('');

  return toolbar + (lists || '<div class="empty">No topics match this filter.</div>');
}

function renderTopicsList(topics) {
  return `<table class="data-table" style="font-size:.85rem">
    <thead><tr><th style="width:34px"></th><th>Created</th><th>Topic</th><th>Category</th><th>Origin</th><th>Status</th><th>Score</th></tr></thead>
    <tbody>${topics.map((t, i) => `<tr>
      <td><input type="checkbox" class="topic-select" value="${Number(t.id)}" data-topic-slug="${escapeHtml(t.slug || '')}" onchange="updateTopicSelectionSummary()" /></td>
      <td>${renderTopicCreatedAt(t)}</td>
      <td>
        <strong>${escapeHtml(t.topic || t.slug || '-')}</strong>
        <div style="font-size:.68rem;color:var(--muted);font-family:monospace">${escapeHtml(t.slug || '')}</div>
        <div style="font-size:.68rem;color:var(--muted);margin-top:.12rem">#${i + 1} - ID ${Number(t.id) || '-'}</div>
        ${t.reject_reason ? `<div style="font-size:.7rem;color:var(--muted);margin-top:.12rem">${escapeHtml(t.reject_reason)}</div>` : ''}
      </td>
      <td>${escapeHtml(t.category || '-')}</td>
      <td>${renderTopicSource(t.source)}</td>
      <td>${renderTopicStatus(t.status)}</td>
      <td title="${escapeHtml(t.reject_reason || '')}" style="font-variant-numeric:tabular-nums;color:var(--muted)">${Number.isFinite(Number(t.dedup_score)) ? Number(t.dedup_score).toFixed(2) : '-'}</td>
    </tr>`).join('')}</tbody>
  </table>`;
}

function getSelectedTopicIds() {
  return Array.from(document.querySelectorAll('.topic-select:checked'))
    .map(input => Number.parseInt(input.value, 10))
    .filter(id => Number.isInteger(id) && id > 0);
}

function getSelectedTopicSlugs() {
  return Array.from(document.querySelectorAll('.topic-select:checked'))
    .map(input => input.dataset.topicSlug || '')
    .filter(Boolean);
}

function setTopicSelection(checked) {
  document.querySelectorAll('.topic-select').forEach(input => {
    input.checked = checked;
  });
  updateTopicSelectionSummary();
}

function updateTopicSelectionSummary() {
  const summary = document.getElementById('topic-selection-summary');
  if (!summary) return;
  const count = getSelectedTopicIds().length;
  summary.textContent = `${count} selected`;
}

async function postTopicStatus(action, ids, reason = '') {
  const res = await fetch(`/api/pipeline-topics?key=${encodeURIComponent(pw)}&action=${action}`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ ids, reason }),
  });
  const data = await res.json();
  if (!res.ok || !data.ok) {
    throw new Error(data.error || res.statusText);
  }
  return data;
}

async function deleteVisiblePendingTopics() {
  if (topicOriginFilter === 'all') {
    alert('Choose a specific Origin first, such as AI Gap or Google Autocomplete.');
    return;
  }

  const rows = getVisiblePipelineTopics().filter(topic => topic.status === 'pending' || topic.status === 'queued');
  const ids = rows.map(topic => Number(topic.id)).filter(id => Number.isInteger(id) && id > 0);
  if (!ids.length) {
    alert('No visible pending topics to delete.');
    return;
  }

  const origin = getTopicSourceMeta(topicOriginFilter);
  const ok = confirm(`Delete ${ids.length} visible pending topic(s) from ${origin.label}?\n\nOnly pending/queued topics will be deleted. Approved, produced, and rejected topics will be left alone.\n\nThis lets you rerun Find Topics with a clean queue for this origin.`);
  if (!ok) return;

  try {
    const data = await postTopicStatus('delete', ids);
    await fetchPipelineStatus();
    openModal('pipeline-topics');
    alert(`Deleted ${data.count || 0} pending topic(s).${data.skipped ? ` Skipped ${data.skipped} topic(s) that had already moved forward.` : ''}`);
  } catch (e) {
    alert(`Failed: ${e.message}`);
  }
}

async function resetPipelineTopicBank() {
  const total = modalRows.length;
  if (!total) {
    alert('No topics to clear.');
    return;
  }

  const ok = confirm(`Clear all ${total} topic(s) from the topic bank?\n\nThis deletes pending, approved, rejected, and produced rows from pipeline_topics only.\n\nIt does not delete generated articles, pins, images, or published site content.`);
  if (!ok) return;

  const confirmation = prompt('Type DELETE ALL TOPICS to confirm this reset.');
  if (confirmation !== 'DELETE ALL TOPICS') {
    alert('Reset cancelled.');
    return;
  }

  try {
    const res = await fetch(`/api/pipeline-topics?key=${encodeURIComponent(pw)}&action=reset`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ confirm: confirmation }),
    });
    const data = await res.json();
    if (!res.ok || !data.ok) {
      throw new Error(data.error || res.statusText);
    }

    await fetchPipelineStatus();
    openModal('pipeline-topics');
    alert(`Cleared ${data.count || 0} topic(s). Remaining: ${data.remaining || 0}.`);
  } catch (e) {
    alert(`Failed: ${e.message}`);
  }
}

async function updateSelectedTopics(action) {
  const ids = getSelectedTopicIds();
  if (!ids.length) {
    alert('Select at least one topic first.');
    return;
  }

  const reason = action === 'reject'
    ? (prompt('Reject reason?', 'manual rejection') || 'manual rejection')
    : '';

  try {
    await postTopicStatus(action, ids, reason);
    await fetchPipelineStatus();
    openModal('pipeline-topics');
  } catch (e) {
    alert(`Failed: ${e.message}`);
  }
}

function renderPipelineTable(filter) {
  const tbody = document.getElementById('pipeline-tbody');
  const empty = document.getElementById('pipeline-empty');
  if (!pipelineData || !pipelineData.articles?.length) {
    tbody.innerHTML = '';
    const imageFilterNote = document.getElementById('pl-image-filter-note');
    if (imageFilterNote) imageFilterNote.textContent = '';
    empty.textContent = 'No pipeline data yet. Click "Find Topics" to start.';
    empty.style.display = '';
    updatePipelinePinSelectionSummary();
    return;
  }
  empty.style.display = 'none';

  const displayStageFor = (article) => article.display_stage || article.review_state || article.stage;
  const builtArticleSlugs = new Set(BUILD.articleSlugs || []);
  const builtHeroSlugs = new Set(BUILD.images?.webSlugs || []);
  const builtPinSlugs = new Set(BUILD.images?.pinSlugs || []);
  const pinSlugsForArticle = (article) => Array.isArray(article.pins)
    ? article.pins.map((pin, idx) => pin.pin_slug || `${article.slug}_v${idx + 1}`).filter(Boolean)
    : [];
  const articleHasHeroAndPins = (article) => {
    const pinSlugs = pinSlugsForArticle(article);
    const pinCount = Number(article.pin_count || 0);
    const pinImagesDone = Number(article.pin_images_done || 0);
    const hasHero = builtHeroSlugs.has(article.slug) || Number(article.hero_image_done || 0) >= 1;
    const hasBuiltPins = pinSlugs.length > 0 && pinSlugs.every(slug => builtPinSlugs.has(slug));
    const hasPipelinePins = pinCount > 0 && pinImagesDone >= pinCount;
    return hasHero && (hasBuiltPins || hasPipelinePins);
  };
  const pinIsPosted = (pin) => String(pin.publish_status || '').toUpperCase() === 'POSTED';
  const articleHasUnpostedPins = (article) =>
    Array.isArray(article.pins) && article.pins.some(pin => !pinIsPosted(pin));

  let hiddenIncompleteAssets = 0;
  let hiddenPostedArticles = 0;
  let articles = pipelineData.articles;
  if (IS_PRODUCTION_DASHBOARD) {
    const before = articles.length;
    articles = articles.filter(articleHasHeroAndPins);
    hiddenIncompleteAssets = before - articles.length;
    const beforePostedFilter = articles.length;
    articles = articles.filter(articleHasUnpostedPins);
    hiddenPostedArticles = beforePostedFilter - articles.length;
  }

  const imageFilterNote = document.getElementById('pl-image-filter-note');
  if (imageFilterNote) {
    const hiddenNotes = [];
    if (hiddenIncompleteAssets > 0) hiddenNotes.push(`${hiddenIncompleteAssets} article(s) without hero + pin images hidden.`);
    if (hiddenPostedArticles > 0) hiddenNotes.push(`${hiddenPostedArticles} fully posted article(s) hidden.`);
    imageFilterNote.textContent = hiddenNotes.join(' ');
  }

  if (filter === 'progress') {
    articles = articles.filter(a => !['staging_review', 'published', 'failed', 'topic'].includes(displayStageFor(a)));
  } else if (filter === 'ready') {
    articles = articles.filter(a => displayStageFor(a) === 'staging_review');
  } else if (filter === 'failed') {
    articles = articles.filter(a => a.stage === 'failed');
  }

  if (!articles.length) {
    tbody.innerHTML = '';
    empty.textContent = IS_PRODUCTION_DASHBOARD && (hiddenIncompleteAssets > 0 || hiddenPostedArticles > 0)
      ? `No visible articles match this filter. ${hiddenIncompleteAssets} article(s) without complete hero + pin images and ${hiddenPostedArticles} fully posted article(s) are hidden.`
      : 'No pipeline data yet. Click "Find Topics" to start.';
    empty.style.display = '';
    updatePipelinePinSelectionSummary();
    return;
  }
  empty.style.display = 'none';

  const stageBadge = (stage) => {
    const colors = {
      topic: '#6b7280', approved: '#3b82f6', written: '#8b5cf6', reviewed: '#a855f7',
      hero_brief: '#f59e0b', pins_brief: '#f59e0b', hero_image: '#10b981',
      pin_images: '#10b981', deployed: '#06b6d4', staging_review: '#7c3aed', published: '#22c55e', failed: '#ef4444'
    };
    const c = colors[stage] || '#6b7280';
    return `<span style="display:inline-block;padding:.15rem .45rem;border-radius:4px;font-size:.75rem;font-weight:500;background:${c}20;color:${c};border:1px solid ${c}40">${escapeHtml(stage)}</span>`;
  };

  const pipelineAssetBase = 'https://staging.daily-life-hacks.pages.dev';
  const formatPipelinePinStatus = (status, productionReady) => {
    if (!status) return null;
    if (status === 'POSTED') {
      return {
        label: 'POSTED',
        title: 'This pipeline pin is already marked as posted.',
        bg: '#dcfce7',
        color: '#166534',
      };
    }
    const lane = IS_PRODUCTION_DASHBOARD
      ? (productionReady ? 'PIPELINE' : 'STAGING')
      : 'STAGING';
    return {
      label: `${lane} ${status}`,
      title: IS_PRODUCTION_DASHBOARD
        ? 'Pipeline metadata only. Check the Pinterest Auto-Poster panel for the real production queue.'
        : 'Staging pipeline status only. This is not a live Pinterest production queue.',
      bg: '#fef3c7',
      color: '#92400e',
    };
  };
  const renderPinLinks = (article) => {
    const allPinItems = Array.isArray(article.pins)
      ? article.pins.map((pin, idx) => ({ pin, idx }))
      : [];
    const pinItems = IS_PRODUCTION_DASHBOARD
      ? allPinItems.filter(({ pin }) => !pinIsPosted(pin))
      : allPinItems;
    const hiddenPostedPins = allPinItems.length - pinItems.length;
    const totalPins = article.pin_count || allPinItems.length || 0;
    const count = `${pinItems.length}/${totalPins}`;
    if (!pinItems.length) {
      return hiddenPostedPins > 0
        ? `<div>${count}</div><div style="font-size:.68rem;color:var(--muted);margin-top:.2rem">${hiddenPostedPins} already posted pin(s) hidden.</div>`
        : count;
    }
    const articleLiveOnProduction = builtArticleSlugs.has(article.slug);
    const links = pinItems.map(({ pin, idx }) => {
      const slug = pin.pin_slug || `${article.slug}_v${idx + 1}`;
      const href = `${pipelineAssetBase}/images/pins/${slug}.jpg`;
      const productionHref = `/images/pins/${slug}.jpg`;
      const label = `v${(pin.pin_index ?? idx) + 1}`;
      const publishStatus = pin.publish_status || '';
      const destination = `${pipelineAssetBase}/${article.slug}/`;
      const productionDestination = `/${article.slug}/`;
      const pinLiveOnProduction = builtPinSlugs.has(slug);
      const productionReady = !IS_PRODUCTION_DASHBOARD || (articleLiveOnProduction && pinLiveOnProduction);
      const description = pin.description_with_hashtags || pin.description || '';
      const formattedStatus = formatPipelinePinStatus(publishStatus, productionReady);
      const statusBadge = formattedStatus
        ? `<span title="${escapeHtml(formattedStatus.title)}"
            style="display:inline-block;margin:.15rem .2rem 0 0;padding:.1rem .3rem;border-radius:4px;font-size:.58rem;font-weight:700;background:${formattedStatus.bg};color:${formattedStatus.color}">${escapeHtml(formattedStatus.label)}</span>`
        : '';
      const promoteBadge = IS_PRODUCTION_DASHBOARD && !productionReady && !publishStatus
        ? `<span title="Promote staging to production before queueing this pin"
            style="display:inline-block;margin:.15rem 0 0 .2rem;padding:.1rem .3rem;border-radius:4px;font-size:.58rem;font-weight:700;background:#fee2e2;color:#991b1b">PROMOTE FIRST</span>`
        : '';
      const publishButton = !publishStatus && productionReady
        ? `<button onclick="approvePipelinePin('${slug}')"
            title="${IS_PRODUCTION_DASHBOARD ? 'Approve and queue this pin for real publishing' : 'Staging queue only'}"
            style="margin:.15rem 0 0 .2rem;border:1px solid #16a34a;background:#16a34a;color:#fff;border-radius:5px;padding:.12rem .35rem;font-size:.65rem;font-weight:700;cursor:pointer">${IS_PRODUCTION_DASHBOARD ? 'Publish' : 'Queue'}</button>`
        : '';
      const selectBox = !publishStatus && productionReady
        ? `<input type="checkbox" class="pipeline-pin-select" value="${escapeHtml(slug)}" data-article-slug="${escapeHtml(article.slug)}" data-pin-index="${pin.pin_index ?? idx}" onchange="updatePipelinePinSelectionSummary()" title="Select pin for batch publishing" style="vertical-align:middle;margin-right:.25rem">`
        : '';
      return `<div class="pipeline-pin-card">
        <div class="pipeline-pin-head">
          <a class="pipeline-pin-thumb" href="${href}" target="_blank" rel="noopener" title="${escapeHtml(slug)}">
            <img src="${href}" alt="${escapeHtml(pin.alt || pin.title || slug)}" loading="lazy" style="width:48px;height:64px;max-width:48px;object-fit:cover;border-radius:6px;border:1px solid #e5e7eb;display:block">
          </a>
          <div class="pipeline-pin-main">
            <div class="pipeline-pin-controls">
              ${selectBox}<span class="pipeline-pin-version">${label}</span>${statusBadge}${promoteBadge}${publishButton}
            </div>
            <a class="pipeline-pin-title" href="${href}" target="_blank" rel="noopener">${escapeHtml(pin.title || slug)}</a>
            <div class="pipeline-pin-description">${escapeHtml(description || '-')}</div>
          </div>
        </div>
        <details class="pipeline-pin-details">
          <summary>Details</summary>
          <div class="pipeline-pin-meta">
            <div><strong>Title:</strong> ${escapeHtml(pin.title || '-')}</div>
            <div><strong>Description:</strong> ${escapeHtml(description || '-')}</div>
            <div><strong>Board:</strong> ${escapeHtml(pin.board_name || '-')} <span style="font-family:monospace;color:var(--muted)">${escapeHtml(pin.board_id || '')}</span></div>
            <div><strong>Model:</strong> <span style="font-family:monospace;color:var(--muted)">${escapeHtml(pin.model_id || '-')}</span></div>
            <div><strong>Hashtags:</strong> ${escapeHtml(pin.hashtags || '-')}</div>
            <div><strong>Alt:</strong> ${escapeHtml(pin.alt || '-')}</div>
            <div><strong>Staging link:</strong> <a href="${destination}" target="_blank" rel="noopener" style="color:var(--orange)">${escapeHtml(destination)}</a></div>
            <div><strong>Production link:</strong> <a href="${productionDestination}" target="_blank" rel="noopener" style="color:${productionReady ? 'var(--orange)' : '#991b1b'}">${escapeHtml(productionDestination)}</a></div>
            <div><strong>Production image:</strong> <a href="${productionHref}" target="_blank" rel="noopener" style="color:${pinLiveOnProduction ? 'var(--orange)' : '#991b1b'}">${escapeHtml(pinLiveOnProduction ? productionHref : 'not live yet')}</a></div>
          </div>
        </details>
      </div>`;
    }).join('');
    const hiddenNote = hiddenPostedPins > 0
      ? `<div style="font-size:.68rem;color:var(--muted);margin-top:.25rem">${hiddenPostedPins} already posted pin(s) hidden.</div>`
      : '';
    return `<div>${count}</div>${hiddenNote}<div>${links}</div>`;
  };

  tbody.innerHTML = articles.map(a => {
    const stage = displayStageFor(a);
    const existsInBuild = builtArticleSlugs.has(a.slug);
    const articleAvailable = existsInBuild
      || ['written', 'reviewed', 'deployed', 'staging_review', 'published'].includes(stage)
      || Number(a.word_count || 0) > 0;
    const heroAvailable = builtHeroSlugs.has(a.slug)
      || Number(a.hero_image_done || 0) >= 1
      || (articleAvailable && ['deployed', 'staging_review', 'hero_brief', 'pins_brief', 'hero_image', 'pin_images', 'published'].includes(stage));
    const supportAvailable = Number(a.support_image_done || 0) >= 1 || stage === 'staging_review';
    const heroSrc = a.hero_image_url || `${pipelineAssetBase}/images/${a.slug}-main.jpg`;
    const supportSrc = a.support_image_url || `${pipelineAssetBase}/images/${a.slug}-ingredients.jpg`;
    const heroVersion = encodeURIComponent(heroImageVersions.get(a.slug) || a.updated_at || stage || 'current');
    const heroDisplaySrc = `${heroSrc}?v=${heroVersion}`;
    const supportDisplaySrc = `${supportSrc}?v=${heroVersion}`;
    const stagingHref = articleAvailable
      ? (a.staging_url || `https://staging.daily-life-hacks.pages.dev/${a.slug}/`)
      : "javascript:void(0)";
    const localHref = articleAvailable ? `/${a.slug}/` : "javascript:void(0)";
    const linkStyle = articleAvailable ? "color:var(--orange);text-decoration:none" : "color:var(--text);text-decoration:none;cursor:default";
    const subStyle = articleAvailable ? "color:var(--muted);text-decoration:none" : "color:var(--muted);text-decoration:none;cursor:default";
    const subLabel = articleAvailable ? "staging" : "not built on staging yet";
    const localLabel = articleAvailable ? "local/prod path" : "pipeline record only";
    const pinSlugs = Array.isArray(a.pins)
      ? a.pins.map((pin, idx) => pin.pin_slug || `${a.slug}_v${idx + 1}`)
      : [];
    const productionAssetsReady = existsInBuild
      && pinSlugs.length > 0
      && pinSlugs.every(slug => builtPinSlugs.has(slug));
    const productionLive = IS_PRODUCTION_DASHBOARD
      && (Number(a.production_live || 0) === 1 || stage === 'published');
    const publishAction = productionLive
      ? `<span title="This article is already marked live in production"
          style="display:inline-block;margin-top:.25rem;padding:.16rem .42rem;border-radius:5px;background:#dcfce7;color:#166534;font-size:.65rem;font-weight:800">Live on Production</span>`
      : articleAssetsReady(a)
        ? (IS_PRODUCTION_DASHBOARD && productionAssetsReady
        ? `<span title="This article and its pipeline pin images are already present on production"
            style="display:inline-block;margin-top:.25rem;padding:.16rem .42rem;border-radius:5px;background:#dcfce7;color:#166534;font-size:.65rem;font-weight:800">Live on Production</span>`
        : `<button id="pipeline-publish-btn-${a.slug}" onclick="publishPipelineArticle('${a.slug}')"
            title="${IS_PRODUCTION_DASHBOARD ? 'Publish this reviewed staging article to production. Pinterest pins are not posted.' : 'Publishing is locked on staging. Open the production dashboard to publish.'}"
            style="margin-top:.25rem;border:1px solid #2563eb;background:#2563eb;color:#fff;border-radius:5px;padding:.16rem .42rem;font-size:.65rem;font-weight:800;cursor:pointer">Publish Article</button>`)
        : '';
    const canApproveArticle = articleAvailable
      && ['reviewed', 'deployed'].includes(a.stage)
      && stage !== 'staging_review'
      && (!Array.isArray(a.pins) || a.pins.length === 0);
    const articleApproval = canApproveArticle
      ? `<button onclick="approvePipelineArticle('${a.slug}')"
          title="Approve this staging article and generate hero image plus pin assets"
          style="margin-top:.25rem;border:1px solid #16a34a;background:#16a34a;color:#fff;border-radius:5px;padding:.16rem .42rem;font-size:.65rem;font-weight:700;cursor:pointer">Approve Article</button>`
      : '';

    return `
    <tr>
      <td style="font-size:.8rem;font-family:monospace">
        <a href="${stagingHref}" target="_blank" rel="noopener"
          style="${linkStyle}">${a.slug}</a>
        <div style="font-family:system-ui,-apple-system,sans-serif;font-size:.68rem;margin-top:.15rem">
          <a href="${stagingHref}" target="_blank" rel="noopener"
            style="${subStyle}">${subLabel}</a>
          <span style="color:var(--muted)"> · </span>
          <a href="${localHref}" target="_blank" rel="noopener"
            style="${subStyle}">${localLabel}</a>
        </div>
        ${heroAvailable ? `<div data-pipeline-hero="${a.slug}"><a href="${heroDisplaySrc}" target="_blank" rel="noopener"><img id="pipeline-hero-img-${a.slug}" src="${heroDisplaySrc}" alt="${escapeHtml(a.slug)} hero" loading="lazy" onerror="var p=this.closest('[data-pipeline-hero]');if(p)p.remove();" style="display:block;width:120px;height:68px;object-fit:cover;border-radius:6px;border:1px solid #e5e7eb;margin-top:.4rem"></a>
        <button id="pipeline-hero-btn-${a.slug}" onclick="regenerateHeroImage('${a.slug}', '${heroSrc}')" title="Regenerate only the staging hero image"
          style="margin-top:.25rem;border:1px solid #f59e0b;background:#fff7ed;color:#92400e;border-radius:5px;padding:.14rem .38rem;font-size:.62rem;font-weight:700;cursor:pointer">Regenerate image</button>
        <div id="pipeline-hero-status-${a.slug}" style="display:none;margin-top:.22rem;max-width:150px;font-size:.62rem;line-height:1.25;color:#92400e"></div></div>` : ''}
        ${supportAvailable ? `<div data-pipeline-support="${a.slug}"><a href="${supportDisplaySrc}" target="_blank" rel="noopener"><img src="${supportDisplaySrc}" alt="${escapeHtml(a.slug)} support" loading="lazy" onerror="var p=this.closest('[data-pipeline-support]');if(p)p.remove();" style="display:block;width:120px;height:68px;object-fit:cover;border-radius:6px;border:1px solid #e5e7eb;margin-top:.35rem"></a>
        <div style="margin-top:.12rem;font-size:.6rem;line-height:1.2;color:var(--muted)">support image</div></div>` : ''}
        ${publishAction}
        ${articleApproval}
      </td>
      <td>${a.category}</td>
      <td>${stageBadge(stage)}${stage !== a.stage ? `<div style="margin-top:.18rem;font-size:.62rem;color:var(--muted)">raw: ${escapeHtml(a.stage || '-')}</div>` : ''}${a.error ? ` <span style="color:#ef4444;font-size:.75rem" title="${a.error}">!</span>` : ''}</td>
      <td>${a.word_count || '-'}</td>
      <td>${renderPinLinks(a)}</td>
      <td>$${(a.cost_usd || 0).toFixed(3)}</td>
      <td style="font-size:.75rem">${a.updated_at ? new Date(a.updated_at + 'Z').toLocaleDateString() : '-'}</td>
    </tr>
  `;
  }).join('');
  updatePipelinePinSelectionSummary();
}

function filterPipeline(filter, btn) {
  document.querySelectorAll('#pipeline-section .btn-sm').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  renderPipelineTable(filter);
}

async function triggerPipeline(action) {
  const statusEl = document.getElementById('pipeline-trigger-status');
  let discoverBeforeIds = null;
  if (action === 'publish' && !IS_PRODUCTION_DASHBOARD) {
    statusEl.style.display = '';
    statusEl.style.background = '#fef2f2';
    statusEl.style.borderColor = '#fecaca';
    statusEl.style.color = '#b91c1c';
    statusEl.textContent = 'Legacy Publish חסום בסטייג׳ינג כי הוא יכול לפרסם לפרודקשן. פרסום אמיתי יתבצע רק מפרודקשן.';
    return;
  }
  if (action === 'produce') {
    const count = parseInt(document.getElementById('produce-count').value);
    const ok = confirm(`Generate ${count} full staging article package(s) now?\n\nEach package includes article, hero image, support image, and four pin images. This uses staging D1 topics and AI provider credits.`);
    if (!ok) return;
  }
  if (action === 'publish') {
    const ok = confirm('Run the legacy publisher now?\n\nThis can publish ready legacy articles directly to main / production.');
    if (!ok) return;
  }
  if (action === 'discover') {
    const limit = parseInt(document.getElementById('discover-limit')?.value || '12', 10);
    const category = document.getElementById('discover-category')?.value || '';
    const categoryLabel = category ? ` in ${category}` : '';
    const ok = confirm(`Find up to ${limit} new topic candidate(s)${categoryLabel} now?\n\nSources: GSC opportunity queries and Google Autocomplete seed expansions.\nFinal gate: LLM semantic duplicate check against existing site and pipeline topics.\n\nThis writes pending topics into staging D1 for review. It does not generate articles or images.`);
    if (!ok) return;
    const existingTopics = await fetchPipelineTopics();
    discoverBeforeIds = new Set(existingTopics.map(topic => Number(topic.id)).filter(Number.isFinite));
  }

  statusEl.style.display = '';
  statusEl.style.background = '#fff7ed';
  statusEl.style.borderColor = '#fed7aa';
  statusEl.style.color = '#92400e';
  statusEl.textContent = `Triggering ${action}...`;

  const body = { action };
  if (action === 'discover') {
    body.limit = parseInt(document.getElementById('discover-limit')?.value || '12', 10);
    const category = document.getElementById('discover-category')?.value || '';
    if (category) body.category = category;
  }
  if (action === 'produce') {
    body.count = parseInt(document.getElementById('produce-count').value);
  }

  try {
    const res = await fetch(`/api/pipeline-trigger?key=${encodeURIComponent(pw)}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const data = await res.json();
    if (res.ok && data.ok) {
      statusEl.style.background = '#f0fdf4';
      statusEl.style.borderColor = '#bbf7d0';
      statusEl.style.color = '#166534';
      if (action === 'discover') {
        statusEl.innerHTML = `Find Topics workflow dispatched. Waiting for new staging topic candidates or a no-op discovery report...${pipelineActionsLink(data)}`;
        pollDiscoveryTopics(discoverBeforeIds || new Set(), data, statusEl);
        return;
      }
      statusEl.textContent = `${action} workflow dispatched successfully. Output: ${data.outputBranch || 'unknown'}. ${data.effect || ''}`;
      setTimeout(() => statusEl.style.display = 'none', 5000);
    } else {
      statusEl.style.background = '#fef2f2';
      statusEl.style.borderColor = '#fecaca';
      statusEl.style.color = '#b91c1c';
      statusEl.textContent = `Error: ${data.error || data.gh_body || 'Unknown error'}`;
    }
  } catch (e) {
    statusEl.style.background = '#fef2f2';
    statusEl.style.color = '#b91c1c';
    statusEl.textContent = `Failed: ${e.message}`;
  }
}

let produceSelectedTopicsInFlight = false;

function pipelineActionsLink(data, label = 'View GitHub Actions') {
  if (!data?.actions_url) return '';
  return ` <a href="${escapeHtml(data.actions_url)}" target="_blank" rel="noopener" style="color:inherit;text-decoration:underline;font-weight:700">${label}</a>`;
}

async function pollDiscoveryTopics(beforeIds, data, statusEl) {
  for (let attempt = 1; attempt <= 36; attempt++) {
    await new Promise(resolve => setTimeout(resolve, 10000));
    const topics = await fetchPipelineTopics();
    const newTopics = topics.filter(topic => !beforeIds.has(Number(topic.id)));
    if (newTopics.length > 0) {
      await fetchPipelineStatus();
      const pending = newTopics.filter(topic => topic.status === 'pending' || topic.status === 'queued').length;
      const approved = newTopics.filter(topic => topic.status === 'approved').length;
      statusEl.style.background = '#f0fdf4';
      statusEl.style.borderColor = '#bbf7d0';
      statusEl.style.color = '#166534';
      statusEl.innerHTML = `Found ${newTopics.length} new topic candidate(s): ${pending} pending, ${approved} approved. Review them in Pipeline Topics.${pipelineActionsLink(data)}`;
      return;
    }
    statusEl.style.background = '#fff7ed';
    statusEl.style.borderColor = '#fed7aa';
    statusEl.style.color = '#92400e';
    statusEl.innerHTML = `Find Topics is still running or produced no new candidates yet. If every candidate is a semantic duplicate, this will finish as a no-op. Refresh ${attempt}/36.${pipelineActionsLink(data)}`;
  }
  statusEl.style.background = '#fff7ed';
  statusEl.style.borderColor = '#fed7aa';
  statusEl.style.color = '#92400e';
  statusEl.innerHTML = `No new topic candidates appeared in the dashboard. This can be a valid no-op when the semantic gate rejects duplicates. Check the discovery report in GitHub Actions for the final run result.${pipelineActionsLink(data)}`;
}

async function pollPipelineForSlugs(slugs, data, statusEl) {
  if (!slugs.length) return;
  const wanted = new Set(slugs);
  for (let attempt = 1; attempt <= 72; attempt++) {
    await new Promise(resolve => setTimeout(resolve, 10000));
    await fetchPipelineStatus();
    const articles = pipelineData?.articles || [];
    const found = articles.filter(article => wanted.has(article.slug));
    const ready = found.filter(articleAssetsReady);
    if (ready.length === slugs.length) {
      statusEl.style.background = '#f0fdf4';
      statusEl.style.borderColor = '#bbf7d0';
      statusEl.style.color = '#166534';
      statusEl.innerHTML = `Full staging package ready for ${ready.length}/${slugs.length} article(s): article, hero, support image, and four pins. Review the row before promotion or Pinterest.${pipelineActionsLink(data)}`;
      return;
    }
    statusEl.style.background = '#fff7ed';
    statusEl.style.borderColor = '#fed7aa';
    statusEl.style.color = '#92400e';
    statusEl.innerHTML = `Pipeline still running or syncing. Found ${found.length}/${slugs.length} article record(s); full assets ready ${ready.length}/${slugs.length}. Refresh ${attempt}/72.${pipelineActionsLink(data)}`;
  }
  statusEl.style.background = '#fef2f2';
  statusEl.style.borderColor = '#fecaca';
  statusEl.style.color = '#b91c1c';
  statusEl.innerHTML = `Workflow was dispatched, but the selected article did not reach full staging-review after 12 minutes. Check the workflow log.${pipelineActionsLink(data)}`;
}

function getPipelineArticle(slug) {
  return (pipelineData?.articles || []).find(article => article.slug === slug);
}

function articleAssetsReady(article) {
  const pinCount = Number(article?.pin_count || 0);
  return article
    && (article.display_stage === 'staging_review' || article.review_state === 'staging_review' || Number(article.full_assets_ready || 0) >= 1)
    && Number(article.hero_image_done || 0) >= 1
    && Number(article.support_image_done || 0) >= 1
    && pinCount >= 4
    && Number(article.pin_images_done || 0) >= pinCount;
}

async function pollArticleAssets(slug, data, statusEl) {
  for (let attempt = 1; attempt <= 36; attempt++) {
    await new Promise(resolve => setTimeout(resolve, 10000));
    await fetchPipelineStatus();

    const article = getPipelineArticle(slug);
    const pinCount = Number(article?.pin_count || 0);
    const pinImagesDone = Number(article?.pin_images_done || 0);
    if (articleAssetsReady(article)) {
      statusEl.style.background = '#f0fdf4';
      statusEl.style.borderColor = '#bbf7d0';
      statusEl.style.color = '#166534';
      statusEl.innerHTML = `Assets ready for ${escapeHtml(slug)}. Hero, support image, and ${pinImagesDone}/4 pin images are visible in the dashboard.${pipelineActionsLink(data)}`;
      return;
    }

    statusEl.style.background = '#fff7ed';
    statusEl.style.borderColor = '#fed7aa';
    statusEl.style.color = '#92400e';
    statusEl.innerHTML = `Generating assets for ${escapeHtml(slug)}. Pin metadata: ${pinCount}/4. Pin images: ${pinImagesDone}/4. Refresh ${attempt}/36.${pipelineActionsLink(data)}`;
  }

  statusEl.style.background = '#fef2f2';
  statusEl.style.borderColor = '#fecaca';
  statusEl.style.color = '#b91c1c';
  statusEl.innerHTML = `Asset workflow was dispatched, but the dashboard still does not show all assets after 6 minutes. Check the workflow log.${pipelineActionsLink(data)}`;
}

async function produceSelectedTopics() {
  if (produceSelectedTopicsInFlight) return;
  const ids = getSelectedTopicIds();
  const selectedSlugs = getSelectedTopicSlugs();
  if (!ids.length) {
    alert('Select at least one topic first.');
    return;
  }
  if (ids.length > 1) {
    alert('Produce Selected is limited to 1 topic per run. Clear the selection and choose exactly one topic.');
    return;
  }

  const ok = confirm(`Generate this selected topic to staging?\n\nThe topic will be approved first if needed. This uses staging D1 topics and AI provider credits.`);
  if (!ok) return;

  produceSelectedTopicsInFlight = true;
  const statusEl = document.getElementById('pipeline-trigger-status');
  statusEl.style.display = '';
  statusEl.style.background = '#fff7ed';
  statusEl.style.borderColor = '#fed7aa';
  statusEl.style.color = '#92400e';
  statusEl.textContent = `Approving and dispatching ${ids.length} selected topic(s)...`;

  try {
    await postTopicStatus('approve', ids);

    const res = await fetch(`/api/pipeline-trigger?key=${encodeURIComponent(pw)}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'produce', count: 1, topic_ids: ids }),
    });
    const data = await res.json();
    if (!res.ok || !data.ok) {
      throw new Error(data.error || data.gh_body || 'Unknown error');
    }

    statusEl.style.background = '#f0fdf4';
    statusEl.style.borderColor = '#bbf7d0';
    statusEl.style.color = '#166534';
    statusEl.innerHTML = `Produce workflow dispatched for ${ids.length} selected topic(s). Output: ${data.outputBranch || 'staging'}. Waiting for full staging package sync...${pipelineActionsLink(data)}`;
    closeModal();
    pollPipelineForSlugs(selectedSlugs, data, statusEl);
  } catch (e) {
    statusEl.style.background = '#fef2f2';
    statusEl.style.borderColor = '#fecaca';
    statusEl.style.color = '#b91c1c';
    statusEl.textContent = `Failed: ${e.message}`;
  } finally {
    produceSelectedTopicsInFlight = false;
  }
}

