<script define:vars={{ BUILD }}>
// ═══════════════════════════════════════════════════════════════════════════
//  Client-side dashboard logic
// ═══════════════════════════════════════════════════════════════════════════

let currentPeriod = 30;
let pw = '';
let trafficChart = null;
let subsChart = null;
const IS_PRODUCTION_DASHBOARD = window.location.hostname === 'www.daily-life-hacks.com'
  || window.location.hostname === 'daily-life-hacks.com';
const DASHBOARD_QUEUE = IS_PRODUCTION_DASHBOARD ? 'production' : 'staging';

function initDashboardEnvironment() {
  const envBadge = document.getElementById('env-badge');
  if (envBadge) {
    envBadge.classList.toggle('production', IS_PRODUCTION_DASHBOARD);
    envBadge.classList.toggle('staging', !IS_PRODUCTION_DASHBOARD);
    envBadge.textContent = IS_PRODUCTION_DASHBOARD
      ? 'PRODUCTION — פעולות אמיתיות'
      : 'STAGING — אין פרסום אמיתי';
  }

  const publishBtn = document.getElementById('btn-publish');
  if (publishBtn && !IS_PRODUCTION_DASHBOARD) {
    publishBtn.disabled = true;
    publishBtn.title = 'חסום בסטייג׳ינג: Legacy Publish יכול לכתוב לפרודקשן.';
  }

  const articleTriggerBtn = document.getElementById('art-trigger-btn');
  if (articleTriggerBtn && !IS_PRODUCTION_DASHBOARD) {
    articleTriggerBtn.disabled = true;
    articleTriggerBtn.title = 'חסום בסטייג׳ינג: מפרסם כתבות לפרודקשן.';
  }

  const articleUploadBtn = document.getElementById('art-upload-btn');
  if (articleUploadBtn && !IS_PRODUCTION_DASHBOARD) {
    articleUploadBtn.disabled = true;
    articleUploadBtn.title = 'חסום בסטייג׳ינג עד בידוד DB מלא.';
  }
}

// ── Login ──────────────────────────────────────────────────────────────────
document.getElementById('pw-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') attemptLogin();
});
document.getElementById('login-btn').addEventListener('click', attemptLogin);

function togglePwVisible() {
  const input = document.getElementById('pw-input');
  input.type = input.type === 'password' ? 'text' : 'password';
}

function attemptLogin() {
  const val = document.getElementById('pw-input').value.trim();
  if (!val) return;
  pw = val;
  loadDashboard();
}

function logout() {
  sessionStorage.removeItem('dlh_pw');
  pw = '';
  document.getElementById('app').style.display = 'none';
  document.getElementById('login-screen').style.display = 'flex';
  document.getElementById('pw-input').value = '';
  document.getElementById('login-error').style.display = 'none';
}

// Check sessionStorage on load
window.addEventListener('DOMContentLoaded', () => {
  initDashboardEnvironment();
  const saved = sessionStorage.getItem('dlh_pw');
  if (saved) { pw = saved; loadDashboard(); }
});

// ── Load dashboard ─────────────────────────────────────────────────────────
async function loadDashboard() {
  document.getElementById('login-error').style.display = 'none';
  renderBuildData();

  // Verify the password before showing the app shell. This avoids the old
  // flash-then-login behavior when the runtime API returns 401.
  const ok = await fetchLive(currentPeriod);
  if (!ok) return;

  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('app').style.display = 'block';

  fetchAutomationHealth();
  fetchPipelineStatus();
  loadPinsStatus();
  loadArticles();
}

// ── Period toggle ──────────────────────────────────────────────────────────
function setPeriod(days) {
  currentPeriod = days;
  document.getElementById('btn-1').classList.toggle('active', days === 1);
  document.getElementById('btn-7').classList.toggle('active', days === 7);
  document.getElementById('btn-30').classList.toggle('active', days === 30);
  document.querySelectorAll('.period-label').forEach(el => el.textContent = days === 1 ? '24h' : days);
  fetchLive(days);
}

function refreshData() {
  const btn = document.getElementById('refresh-btn');
  btn.classList.add('spinning');
  Promise.all([fetchLive(currentPeriod), fetchPipelineStatus(), fetchAutomationHealth()]).finally(() => btn.classList.remove('spinning'));
}

// ── Load Chart.js dynamically (Astro strips CDN script tags) ─────────────
async function loadChartJs() {
  if (window.Chart) return;
  await new Promise((resolve, reject) => {
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js';
    s.onload = resolve;
    s.onerror = reject;
    document.head.appendChild(s);
  });
}

// ── Fetch live data ────────────────────────────────────────────────────────
async function fetchLive(days) {
  setRefreshStatus('loading');
  await loadChartJs();
  try {
    const res = await fetch(`/api/dashboard?key=${encodeURIComponent(pw)}&days=${days}&noClarity=1`);
    if (res.status === 401) {
      sessionStorage.removeItem('dlh_pw');
      document.getElementById('login-error').style.display = 'block';
      document.getElementById('app').style.display = 'none';
      document.getElementById('login-screen').style.display = 'flex';
      setRefreshStatus('error', 'Unauthorized');
      return false;
    }
    const data = await res.json();
    sessionStorage.setItem('dlh_pw', pw);
    renderLiveData(data, days);
    setRefreshStatus('ok', `Refreshed ${new Date().toLocaleTimeString()}`);
    return true;
  } catch (e) {
    setRefreshStatus('error', 'Network error: ' + e.message);
    return false;
  }
}

async function fetchAutomationHealth() {
  if (!pw) return false;
  const btn = document.getElementById('automation-refresh-btn');
  if (btn) btn.classList.add('spinning');
  try {
    const res = await fetch(`/api/workflow-health?key=${encodeURIComponent(pw)}&t=${Date.now()}`);
    const data = await res.json().catch(() => ({}));
    if (!res.ok || !data.ok) {
      renderAutomationHealthError(data.error || `Workflow health returned ${res.status}`);
      return false;
    }
    renderAutomationHealth(data);
    return true;
  } catch (e) {
    renderAutomationHealthError(e.message || String(e));
    return false;
  } finally {
    if (btn) btn.classList.remove('spinning');
  }
}

function renderAutomationHealthError(message) {
  const overall = el('automation-overall');
  if (overall) {
    overall.className = 'automation-health-badge danger';
    overall.textContent = 'Unavailable';
  }
  const generated = el('automation-generated');
  if (generated) generated.textContent = message || 'Could not read GitHub Actions.';
  const grid = el('automation-health-grid');
  if (grid) grid.innerHTML = `<div class="empty">GitHub Actions status is unavailable: ${escapeHtml(message || 'unknown error')}</div>`;
}

function renderAutomationHealth(data) {
  const overallStatus = data.overall?.status || 'unknown';
  const overall = el('automation-overall');
  if (overall) {
    overall.className = `automation-health-badge ${automationStatusClass(overallStatus)}`;
    overall.textContent = data.overall?.label || automationStatusLabel(overallStatus);
  }
  const generated = el('automation-generated');
  if (generated) {
    generated.textContent = data.generated_at ? `Updated ${formatAge(data.generated_at)}` : 'Updated now';
  }

  const workflows = Array.isArray(data.workflows) ? data.workflows : [];
  const grid = el('automation-health-grid');
  if (!grid) return;
  if (!workflows.length) {
    grid.innerHTML = '<div class="empty">No workflow data returned.</div>';
    return;
  }
  grid.innerHTML = workflows.map(renderAutomationWorkflowCard).join('');
}

function renderAutomationWorkflowCard(workflow) {
  const latest = workflow.latest || {};
  const recentProblem = workflow.recent_problem || null;
  const statusClass = automationStatusClass(workflow.status);
  const modeColor = workflow.mode === 'automatic' ? '#1d4ed8' : '#475569';
  const latestLine = latest.id
    ? `${escapeHtml(latest.event || '-')} · ${escapeHtml(latest.branch || '-')} · ${escapeHtml(latest.sha || '-')}`
    : 'No runs found';
  const conclusion = latest.status === 'completed'
    ? (latest.conclusion || 'completed')
    : (latest.status || 'unknown');
  const problem = renderAutomationProblem(workflow, recentProblem);
  const runUrl = latest.url || workflow.actions_url;

  return `<div class="automation-workflow-card ${statusClass}">
    <div class="automation-workflow-title">
      <span>${escapeHtml(workflow.name)}</span>
      <span class="automation-health-badge ${statusClass}" style="font-size:.62rem;padding:.14rem .38rem">${escapeHtml(automationStatusLabel(workflow.status))}</span>
    </div>
    <div class="automation-workflow-meta">
      <div><strong>Mode:</strong> <span style="color:${modeColor};font-weight:800">${escapeHtml(workflow.mode || '-')}</span></div>
      <div><strong>Trigger:</strong> ${escapeHtml(workflow.trigger || '-')}</div>
      <div><strong>Latest:</strong> ${escapeHtml(conclusion)} · ${escapeHtml(formatAge(latest.created_at || latest.updated_at))}</div>
      <div><strong>Run:</strong> ${latestLine}</div>
      <div><strong>Effect:</strong> ${escapeHtml(workflow.effect || '-')}</div>
    </div>
    ${problem}
    <div class="automation-workflow-actions">
      <a href="${escapeHtml(runUrl || '#')}" target="_blank" rel="noopener">Latest run</a>
      <a href="${escapeHtml(workflow.actions_url || '#')}" target="_blank" rel="noopener">Workflow</a>
    </div>
  </div>`;
}

function renderAutomationProblem(workflow, recentProblem) {
  const latest = workflow.latest || null;
  const detail = workflow.problem_detail || null;
  const problemRun = workflow.status === 'danger' ? latest : recentProblem;
  if (!problemRun) return '';
  const detailBits = [];
  if (detail?.job) detailBits.push(`job: ${detail.job}`);
  if (detail?.step) detailBits.push(`step: ${detail.step}`);
  if (detail?.error) detailBits.push(detail.error);
  const prefix = workflow.status === 'danger' ? 'Current issue' : 'Recent issue';
  return `<div class="automation-workflow-problem">
    <strong>${prefix}:</strong> ${escapeHtml(problemRun.conclusion || problemRun.status || 'problem')}
    · ${escapeHtml(formatAge(problemRun.created_at || problemRun.updated_at))}
    ${detailBits.length ? `<br>${escapeHtml(detailBits.join(' · '))}` : ''}
  </div>`;
}

function automationStatusClass(status) {
  if (['ok', 'warn', 'danger', 'running'].includes(status)) return status;
  return 'unknown';
}

function automationStatusLabel(status) {
  const labels = {
    ok: 'OK',
    warn: 'Attention',
    danger: 'Failing',
    running: 'Running',
    unknown: 'Unknown',
  };
  return labels[status] || 'Unknown';
}

function formatAge(value) {
  if (!value) return '-';
  const ms = Date.now() - new Date(value).getTime();
  if (!Number.isFinite(ms)) return '-';
  const min = Math.max(0, Math.round(ms / 60000));
  if (min < 1) return 'just now';
  if (min < 60) return `${min}m ago`;
  const hours = Math.round(min / 60);
  if (hours < 48) return `${hours}h ago`;
  const days = Math.round(hours / 24);
  return `${days}d ago`;
}

async function fetchClarity() {
  const btn = document.getElementById('clarity-refresh-btn');
  btn.disabled = true;
  btn.textContent = 'Loading...';
  el('clarity-loading').style.display = 'block';
  el('clarity-loading').textContent = 'Fetching from Clarity API...';
  el('clarity-content').style.display = 'none';
  el('clarity-error').style.display = 'none';
  try {
    const res = await fetch(`/api/dashboard?key=${encodeURIComponent(pw)}&days=1&clarityOnly=1`);
    const data = await res.json();
    if (data.clarity) {
      liveData = { ...liveData, clarity: data.clarity };
      renderClarityData(data.clarity);
    }
    btn.textContent = `↻ Refresh Clarity (last: ${new Date().toLocaleTimeString()})`;
  } catch (e) {
    el('clarity-loading').style.display = 'none';
    el('clarity-error').style.display = 'block';
    el('clarity-error').textContent = 'Error: ' + e.message;
    btn.textContent = '↻ Refresh Clarity';
  } finally {
    btn.disabled = false;
  }
}

function setRefreshStatus(state, msg) {
  const el = document.getElementById('refresh-status');
  el.className = state === 'ok' ? 'ok' : state === 'error' ? 'err' : '';
  if (state === 'loading') {
    el.innerHTML = 'Loading live data<span class="loading-dots"></span>';
  } else {
    el.textContent = msg || '';
  }
}

