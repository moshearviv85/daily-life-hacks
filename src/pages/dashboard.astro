window.filterSubs       = filterSubs;
window.copySubEmails    = copySubEmails;
window.openModal        = openModal;
window.fetchClarity     = fetchClarity;
window.togglePwVisible  = togglePwVisible;
window.closeModal       = closeModal;
window.handleModalClick = handleModalClick;
window.modalSearch      = modalSearch;
window.loadPinsStatus   = loadPinsStatus;
window.uploadPinsCSV    = uploadPinsCSV;

// ── Pinterest Auto-Poster ──────────────────────────────────────────────────

async function loadPinsStatus() {
  if (!pw) return;
  try {
    const res = await fetch(`/api/pins-status?key=${encodeURIComponent(pw)}`);
    if (res.status === 401) return; // not authenticated yet
    if (!res.ok) return;
    const d = await res.json();

    el('ps-total').textContent  = d.total ?? '—';
    el('ps-posted').textContent = d.posted ?? '—';
    el('ps-pending').textContent = d.pending ?? '—';

    // Upcoming
    if (d.upcoming && d.upcoming.length > 0) {
      el('ps-upcoming-empty').style.display = 'none';
      el('ps-upcoming-table').style.display = '';
      el('ps-upcoming-tbody').innerHTML = d.upcoming.map(p =>
        `<tr>
          <td style="white-space:nowrap">${p.scheduled_date}</td>
          <td style="font-size:.75rem">${p.pin_title}</td>
        </tr>`
      ).join('');
    } else {
      el('ps-upcoming-empty').style.display = '';
      el('ps-upcoming-table').style.display = 'none';
    }

    // Recent posted
    if (d.recent_posted && d.recent_posted.length > 0) {
      el('ps-recent-empty').style.display = 'none';
      el('ps-recent-table').style.display = '';
      el('ps-recent-tbody').innerHTML = d.recent_posted.map(p => {
        const pinLink = p.pin_id
          ? `<a href="https://www.pinterest.com/pin/${p.pin_id}/" target="_blank" style="color:#E60023;font-size:.72rem">${p.pin_id}</a>`
          : '—';
        const articleLink = p.link
          ? `<a href="${p.link}" target="_blank" style="font-size:.72rem;color:var(--orange)">↗</a>`
          : '—';
        return `<tr>
          <td style="white-space:nowrap;font-size:.72rem">${(p.published_date || '').slice(0,16)}</td>
          <td style="font-size:.75rem">${p.pin_title}</td>
          <td style="white-space:nowrap">${pinLink}</td>
          <td style="text-align:center">${articleLink}</td>
        </tr>`;
      }).join('');
    } else {
      el('ps-recent-empty').style.display = '';
      el('ps-recent-table').style.display = 'none';
    }
  } catch(e) {
    console.warn('pins-status error:', e);
  }
}

function setProgress(pct, label) {
  const wrap = document.getElementById('pins-progress-wrap');
  const bar  = document.getElementById('pins-progress-bar');
  const lbl  = document.getElementById('pins-progress-label');
  wrap.style.display = pct >= 0 ? '' : 'none';
  bar.style.width = pct + '%';
  lbl.textContent  = label || '';
}

function uploadPinsCSV() {
  const input    = document.getElementById('pins-csv-input');
  const statusEl = document.getElementById('pins-upload-status');
  const pollEl   = document.getElementById('pins-poll-status');
  const btn      = document.getElementById('pins-upload-btn');

  if (!input.files || !input.files[0]) {
    statusEl.style.display = '';
    statusEl.style.color = '#b91c1c';
    statusEl.textContent = 'Please select a CSV file first.';
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Uploading...';
  statusEl.style.display = 'none';
  pollEl.style.display   = 'none';
  setProgress(0, 'שולח קובץ...');

  const formData = new FormData();
  formData.append('file', input.files[0]);

  const xhr = new XMLHttpRequest();

  // Phase 1: file upload progress (0→50%)
  xhr.upload.onprogress = (e) => {
    if (e.lengthComputable) {
      const pct = Math.round((e.loaded / e.total) * 50);
      setProgress(pct, `שולח קובץ... ${pct * 2}%`);
    }
  };

  // Phase 1 done → animate 50→90% while server processes
  xhr.upload.onload = () => {
    setProgress(50, 'מעבד שורות ושומר ב-D1...');
    let pct = 50;
    const timer = setInterval(() => {
      pct = Math.min(90, pct + 2);
      setProgress(pct, `מעבד שורות ושומר ב-D1... ${Math.round((pct - 50) / 40 * 100)}%`);
    }, 400);
    xhr._processingTimer = timer;
  };

  xhr.onload = () => {
    clearInterval(xhr._processingTimer);
    setProgress(100, 'הושלם!');
    setTimeout(() => setProgress(-1, ''), 2000);

    btn.disabled = false;
    btn.textContent = 'Upload';

    let data;
    try { data = JSON.parse(xhr.responseText); } catch(e) { data = {}; }

    statusEl.style.display = '';
    if (xhr.status >= 200 && xhr.status < 300) {
      statusEl.style.color = '#16a34a';
      const triggerStatus = data.triggered ? ' | GitHub Actions: ✓ הופעל' : ' | GitHub Actions: ✗ לא הופעל (לחץ Post Now)';
      statusEl.textContent = `הועלו ${data.inserted} פינים חדשים, עודכנו ${data.updated} (סה"כ ${data.total} שורות).${triggerStatus}`;
      loadPinsStatus();
      input.value = '';
      if (data.triggered) {
        startPinPostedPolling();
      }
    } else {
      statusEl.style.color = '#b91c1c';
      statusEl.textContent = `Error: ${data.error || xhr.statusText}`;
    }
  };

  xhr.onerror = () => {
    clearInterval(xhr._processingTimer);
    setProgress(-1, '');
    btn.disabled = false;
    btn.textContent = 'Upload';
    statusEl.style.display = '';
    statusEl.style.color = '#b91c1c';
    statusEl.textContent = 'Upload failed — check network.';
  };

  xhr.open('POST', `/api/pins-upload?key=${encodeURIComponent(pw)}`);
  xhr.send(formData);
}

let _pollTimer = null;
let _pollLogs  = [];

function appendPollLog(msg) {
  const now = new Date().toLocaleTimeString('he-IL', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
  _pollLogs.push(`[${now}] ${msg}`);
  const pollEl = document.getElementById('pins-poll-status');
  pollEl.innerHTML = _pollLogs.map(l =>
    `<div style="font-family:monospace;font-size:.72rem;line-height:1.6">${l}</div>`
  ).join('');
  pollEl.scrollTop = pollEl.scrollHeight;
}

async function startPinPostedPolling() {
  const pollEl = document.getElementById('pins-poll-status');
  pollEl.style.display = '';
  pollEl.style.maxHeight = '140px';
  pollEl.style.overflowY = 'auto';
  _pollLogs = [];

  // Snapshot current posted count + recent pin IDs
  let prevPosted = 0;
  let prevPinIds = new Set();
  try {
    const s = await fetch(`/api/pins-status?key=${encodeURIComponent(pw)}`).then(r => r.json());
    prevPosted = s.posted || 0;
    (s.recent_posted || []).forEach(p => { if (p.pin_id) prevPinIds.add(p.pin_id); });
  } catch(_) {}

  appendPollLog(`GitHub Actions הופעל — ${prevPosted} פינים פורסמו עד כה`);
  appendPollLog('ממתין לאישור פרסום מ-Pinterest...');

  let attempts = 0;
  const MAX = 24; // 6 minutes max
  clearInterval(_pollTimer);

  function tick() {
    attempts++;
    appendPollLog(`בדיקה ${attempts}/${MAX}...`);

    fetch(`/api/pins-status?key=${encodeURIComponent(pw)}`)
      .then(r => r.json())
      .then(s => {
        if (s.posted > prevPosted) {
          clearInterval(_pollTimer);
          // Find the new pin
          const newPin = (s.recent_posted || []).find(p => p.pin_id && !prevPinIds.has(p.pin_id));
          if (newPin) {
            appendPollLog(`✓ פורסם! Pin ID: ${newPin.pin_id}`);
            appendPollLog(`  כותרת: ${newPin.pin_title}`);
            if (newPin.link) appendPollLog(`  כתבה: ${newPin.link}`);
            appendPollLog(`  Pinterest: https://www.pinterest.com/pin/${newPin.pin_id}/`);
          } else {
            appendPollLog(`✓ פורסם! (סה"כ ${s.posted} פינים)`);
          }
          pollEl.style.background = '#f0fdf4';
          pollEl.style.borderColor = '#bbf7d0';
          pollEl.style.color = '#166534';
          loadPinsStatus();
        } else if (attempts >= MAX) {
          clearInterval(_pollTimer);
          appendPollLog('⚠ לא התקבל אישור תוך 6 דקות.');
          appendPollLog('בדוק GitHub Actions: github.com/moshearviv85/daily-life-hacks/actions');
        } else {
          appendPollLog(`  עדיין ממתין... (${s.posted} פורסמו, ${s.pending} ממתינים)`);
        }
      })
      .catch(e => appendPollLog(`  שגיאת רשת: ${e.message}`));
  }

  _pollTimer = setInterval(tick, 15000);
  setTimeout(tick, 5000); // first check after 5 seconds
}

async function clearPendingPins() {
  if (!pw) return;
  if (!confirm('למחוק את כל הפינים הממתינים (PENDING)?')) return;
  const statusEl = document.getElementById('pins-upload-status');
  statusEl.style.display = '';
  statusEl.style.color = '#92400e';
  statusEl.textContent = 'מוחק...';
  try {
    const res = await fetch(`/api/pins-clear?key=${encodeURIComponent(pw)}`, { method: 'POST' });
    const data = await res.json();
    if (res.ok) {
      statusEl.style.color = '#16a34a';
      statusEl.textContent = `נמחקו ${data.deleted} פינים ממתינים.`;
      loadPinsStatus();
    } else {
      statusEl.style.color = '#b91c1c';
      statusEl.textContent = `Error: ${data.error || res.statusText}`;
    }
  } catch(e) {
    statusEl.style.color = '#b91c1c';
    statusEl.textContent = `Failed: ${e.message}`;
  }
}
window.clearPendingPins = clearPendingPins;

async function triggerPostNow() {
  const btn    = document.getElementById('pins-post-now-btn');
  const pollEl = document.getElementById('pins-poll-status');
  btn.disabled = true;
  btn.textContent = 'מפעיל...';
  pollEl.style.display = '';
  pollEl.style.background = '#fff7ed';
  pollEl.style.borderColor = '#fed7aa';
  pollEl.style.color = '#92400e';
  pollEl.textContent = 'שולח פקודה ל-GitHub Actions...';
  try {
    const res  = await fetch(`/api/pins-trigger?key=${encodeURIComponent(pw)}`, { method: 'POST' });
    const text = await res.text();
    let data;
    try { data = JSON.parse(text); } catch(_) { data = { error: text.slice(0, 300) }; }
    if (res.ok && data.ok) {
      pollEl.textContent = '✓ GitHub Actions הופעל — ממתין לפרסום...';
      startPinPostedPolling();
    } else {
      pollEl.style.background = '#fef2f2';
      pollEl.style.borderColor = '#fecaca';
      pollEl.style.color = '#b91c1c';
      pollEl.textContent = `שגיאה (${data.status || res.status}): ${data.error || 'לא ידוע'}`;
    }
  } catch(e) {
    pollEl.style.background = '#fef2f2';
    pollEl.style.color = '#b91c1c';
    pollEl.textContent = `Failed: ${e.message}`;
  } finally {
    btn.disabled = false;
    btn.textContent = '▶ Post Now';
  }
}
window.triggerPostNow = triggerPostNow;
</script>

