---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { formatReleaseDate, isReleased } from "../content/release";
import routerMapping from "../../pipeline-data/router-mapping.json";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  const paths: { params: { slug: string }; props: { article: CollectionEntry<"articles"> } }[] = [];

  for (const article of articles) {
    // Base slug (canonical page)
    paths.push({ params: { slug: article.id }, props: { article } });

    // Variant slugs (Pinterest/SEO routing) that should render the same base content.
    const mappingForArticle = (routerMapping as Record<string, Record<string, { url_slug?: string }>>)[
      article.id
    ];
    if (!mappingForArticle) continue;

    for (const variant of Object.values(mappingForArticle)) {
      const slug = variant?.url_slug;
      if (!slug || slug === article.id) continue;
      paths.push({ params: { slug }, props: { article } });
    }
  }

  return paths;
}

interface Props {
  article: CollectionEntry<"articles">;
}

const { article } = Astro.props;
const { Content } = await render(article);
const releaseDate = article.data.publishAt ?? article.data.date;
/** True once publishAt (or date) is in the past; drives index/noindex at build time. */
const released = isReleased(article);
/** Future-dated publishAt only: show gate + noindex until released (next deploy after date removes noindex). */
const pendingRelease = Boolean(article.data.publishAt) && !released;
const releaseIso = article.data.publishAt?.toISOString();
const formattedReleaseDate = article.data.publishAt
  ? formatReleaseDate(article.data.publishAt)
  : null;
const publishedDate = releaseDate.toISOString();

const isRecipe =
  article.data.category === "recipes" &&
  article.data.ingredients &&
  article.data.steps;

const siteUrl = "https://www.daily-life-hacks.com";
const articleUrl = `${siteUrl}/${article.id}`;
const imageUrl = article.data.image.startsWith("http")
  ? article.data.image
  : `${siteUrl}${article.data.image}`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    {
      "@type": "ListItem",
      position: 2,
      name:
        article.data.category === "recipes"
          ? "Recipes"
          : article.data.category === "tips"
            ? "Tips"
            : "Nutrition",
      item: `${siteUrl}/${article.data.category}`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: article.data.title,
      item: articleUrl,
    },
  ],
};

const jsonLd = isRecipe
  ? {
      "@context": "https://schema.org",
      "@type": "Recipe",
      name: article.data.title,
      description: article.data.excerpt,
      image: [imageUrl],
      datePublished: publishedDate,
      dateModified: publishedDate,
      prepTime: article.data.prepTime
        ? `PT${article.data.prepTime.replace(/\s*minutes?\s*/i, "M").replace(/\s*hours?\s*/i, "H")}`
        : undefined,
      cookTime: article.data.cookTime
        ? `PT${article.data.cookTime.replace(/\s*minutes?\s*/i, "M").replace(/\s*hours?\s*/i, "H")}`
        : undefined,
      totalTime: article.data.totalTime
        ? `PT${article.data.totalTime.replace(/\s*minutes?\s*/i, "M").replace(/\s*hours?\s*/i, "H")}`
        : undefined,
      recipeYield: article.data.servings
        ? `${article.data.servings} servings`
        : undefined,
      recipeCategory: "Healthy",
      recipeCuisine: "American",
      nutrition: article.data.calories
        ? {
            "@type": "NutritionInformation",
            calories: `${article.data.calories} calories`,
          }
        : undefined,
      recipeIngredient: article.data.ingredients,
      recipeInstructions: article.data.steps?.map(
        (step: string, i: number) => ({
          "@type": "HowToStep",
          position: i + 1,
          text: step,
        }),
      ),
      author: {
        "@type": "Organization",
        name: "Daily Life Hacks",
        url: "https://www.daily-life-hacks.com",
      },
      publisher: {
        "@type": "Organization",
        name: "Daily Life Hacks",
        url: "https://www.daily-life-hacks.com",
      },
    }
  : {
      "@context": "https://schema.org",
      "@type": "Article",
      headline: article.data.title,
      description: article.data.excerpt,
      image: [imageUrl],
      datePublished: publishedDate,
      dateModified: publishedDate,
      author: {
        "@type": "Organization",
        name: "Daily Life Hacks",
        url: siteUrl,
      },
      publisher: {
        "@type": "Organization",
        name: "Daily Life Hacks",
        url: siteUrl,
      },
    };

const allSchemas: any[] = [jsonLd, breadcrumbSchema];

if (article.data.faq && article.data.faq.length > 0) {
  allSchemas.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: article.data.faq.map((item: any) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  });
}

const robotsMeta = released ? undefined : "noindex, follow";
---

<BaseLayout
  title={article.data.title}
  description={article.data.excerpt}
  image={article.data.image}
  canonicalURL={articleUrl}
  jsonLd={released ? allSchemas : undefined}
  robots={robotsMeta}
>
  <Header />
  <main
    class="max-w-3xl mx-auto px-4 py-10"
    data-base-slug={article.id}
    data-release-root={pendingRelease ? "true" : "false"}
    data-release-at={pendingRelease ? releaseIso : undefined}
  >
    <!-- Mobile Back Button & Breadcrumb -->
    <nav class="mb-6 flex flex-col gap-4 relative z-10">
      <!-- Visual Back Button (Mobile Only) -->
      <button
        onclick="history.back()"
        class="md:hidden flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-all w-fit"
        style="background-color: var(--input-bg); color: var(--heading-color); border: 1px solid var(--border-color);"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back
      </button>

      <div
        class="text-sm flex items-center gap-1 flex-wrap"
        style="color: var(--muted-color);"
      >
        <a href="/" class="hover:text-[#F29B30] transition-colors">Home</a>
        <span>/</span>
        <a
          href={`/${article.data.category}`}
          class="hover:text-[#F29B30] capitalize transition-colors"
          >{article.data.category}</a
        >
        <span>/</span>
        <span
          class="truncate max-w-[200px] md:max-w-none"
          style="color: var(--text-color);">{article.data.title}</span
        >
      </div>
    </nav>

    {
      pendingRelease && (
        <section
          id="release-notice"
          class="mb-8 rounded-2xl border p-5"
          style="background-color: var(--card-bg); border-color: var(--border-color);"
        >
          <p class="text-xs font-bold uppercase tracking-widest mb-2" style="color: #F29B30;">
            Scheduled Release
          </p>
          <h2 class="text-2xl font-bold mb-2" style="color: var(--heading-color);">
            This post unlocks on {formattedReleaseDate}
          </h2>
          <p class="text-sm leading-relaxed" style="color: var(--muted-color);">
            The page is already prepared. It will become visible automatically on the release date.
          </p>
        </section>
      )
    }

    <div id="release-content" style={pendingRelease ? "display: none;" : undefined}>

    <!-- Featured Image — top of article -->
    <div class="relative mb-8 group rounded-2xl overflow-hidden shadow-md">
      <Image
        src={article.data.image}
        alt={article.data.imageAlt}
        width={768}
        height={432}
        fetchpriority="high"
        loading="eager"
        decoding="sync"
        inferSize={true}
        data-pin-description={`${article.data.title} - ${article.data.excerpt} | Daily Life Hacks`}
        data-pin-url={new URL(
          Astro.url.pathname,
          Astro.site || Astro.url.origin,
        ).href}
        data-pin-media={new URL(
          article.data.image,
          Astro.site || Astro.url.origin,
        ).href}
        class="w-full aspect-video object-cover"
      />
    </div>

    <!-- Article Header -->
    <header class="mb-8">
      <span
        class="inline-block px-3 py-1 text-xs font-bold rounded uppercase tracking-widest mb-4 text-white"
        style="background-color: #F29B30;"
      >
        {article.data.category}
      </span>
      <h1
        class="text-3xl md:text-4xl font-bold leading-tight mb-4"
        style="color: var(--heading-color);"
      >
        {article.data.title}
      </h1>
      <p class="text-lg leading-relaxed" style="color: var(--muted-color);">
        {article.data.excerpt}
      </p>
      <p
        class="text-sm mt-3 flex items-center gap-2"
        style="color: var(--label-color);"
      >
        {
          article.data.author && (
            <>
              <span class="font-medium text-[var(--text-color)]">
                {article.data.author}
              </span>
              <span>•</span>
            </>
          )
        }
        <span>
          {
            article.data.date.toLocaleDateString("en-US", {
              month: "long",
              day: "numeric",
              year: "numeric",
            })
          }
        </span>
      </p>
    </header>

    <!-- Rating Preview -->
    <section
      id="rating-widget"
      class="mb-8 rounded-xl border p-4"
      style="background-color: var(--card-bg); border-color: var(--border-color);"
      aria-label="Article rating"
      data-slug={article.id}
      data-article-url={articleUrl}
      data-article-title={article.data.title}
      data-schema-type={isRecipe ? "Recipe" : "Article"}
    >
      <div class="flex flex-col gap-3">
        <div class="flex items-center gap-2">
          <div class="flex items-center gap-1" role="group" aria-label="Rate this article">
            {Array.from({ length: 5 }).map((_, i) => (
              <button
                type="button"
                class="rating-star p-0.5"
                data-value={String(i + 1)}
                aria-label={`Rate ${i + 1} ${i === 0 ? "star" : "stars"}`}
              >
                <span class="relative block h-5 w-5">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="absolute inset-0 h-5 w-5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="var(--border-color)"
                    stroke-width="1.8"
                  >
                    <path d="m12 3.5 2.78 5.63 6.22.9-4.5 4.38 1.06 6.19L12 17.8 6.44 20.6l1.06-6.19L3 10.03l6.22-.9L12 3.5z" />
                  </svg>
                  <span class="rating-fill absolute inset-0 overflow-hidden" style="width: 0%;">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-5 w-5"
                      viewBox="0 0 24 24"
                      fill="#F29B30"
                    >
                      <path d="m12 3.5 2.78 5.63 6.22.9-4.5 4.38 1.06 6.19L12 17.8 6.44 20.6l1.06-6.19L3 10.03l6.22-.9L12 3.5z" />
                    </svg>
                  </span>
                </span>
              </button>
            ))}
          </div>
          <span id="rating-average" class="text-sm font-semibold" style="color: var(--heading-color);"></span>
          <span
            id="rating-count"
            class="text-xs font-semibold"
            style="color: var(--heading-color); white-space: nowrap;"
          ></span>
        </div>
        <p
          id="rating-copy"
          class="text-sm font-medium leading-relaxed"
          style="color: var(--muted-color); display: none;"
        >
          Yeah, this is a little awkward. No ratings yet. People probably rushed to make this and forgot to come back. Do us a solid, drop a quick rating, and help the next hungry person skip the guesswork.
        </p>
      </div>
    </section>

    <!-- Recipe Card -->
    {
      isRecipe && (
        <div class="mb-10 border-2 border-[#F29B30] rounded-2xl overflow-hidden bg-[var(--card-bg)] shadow-sm">
          {/* Top Bar */}
          <div class="bg-[#F29B30] p-4 text-white grid grid-cols-2 md:grid-cols-3 gap-4 text-sm font-medium">
            <div class="flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <>
                  <circle cx="12" cy="12" r="10" />
                  <polyline points="12 6 12 12 16 14" />
                </>
              </svg>
              <span>Prep: {article.data.prepTime}</span>
            </div>
            <div class="flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <>
                  <path d="M14 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0Z" />
                  <path d="M10 2h4" />
                  <path d="m19 11-2-2-1.5 1.5" />
                  <path d="M6.5 7.5 5 9l2 2" />
                </>
              </svg>
              <span>Cook: {article.data.cookTime}</span>
            </div>
            <div class="flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <>
                  <circle cx="12" cy="12" r="10" />
                  <polyline points="12 6 12 12" />
                </>
              </svg>
              <span>Total: {article.data.totalTime}</span>
            </div>
            <div class="flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <>
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                  <circle cx="9" cy="7" r="4" />
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                  <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                </>
              </svg>
              <span>Serves: {article.data.servings}</span>
            </div>
            <div class="flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.1.2-2.2.5-3.3.3-1.1 1-2.2 3-2.2z" />
              </svg>
              <span>{article.data.calories} kcal</span>
            </div>
            <div class="flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <>
                  <path d="M12 20a8 8 0 1 0 0-16 8 8 0 0 0 0 16Z" />
                  <path d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" />
                  <path d="M12 2v2" />
                  <path d="M12 22v-2" />
                  <path d="m17 17-1.4-1.4" />
                  <path d="m17 7-1.4 1.4" />
                  <path d="m7 17 1.4-1.4" />
                  <path d="m7 7 1.4 1.4" />
                </>
              </svg>
              <span>{article.data.difficulty}</span>
            </div>
          </div>

          <div class="p-6 md:p-8 grid md:grid-cols-2 gap-8">
            {/* Ingredients */}
            <div>
              <h3 class="text-xl font-bold mb-4 text-[var(--heading-color)] flex items-center gap-2">
                <span class="text-[#F29B30]">●</span> Ingredients
              </h3>
              <ul class="space-y-2">
                {article.data.ingredients?.map((ingredient: string) => (
                  <li class="flex items-start gap-2 text-[var(--text-color)]">
                    <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[#F29B30] flex-shrink-0" />
                    <span>{ingredient}</span>
                  </li>
                ))}
              </ul>
            </div>

            {/* Instructions */}
            <div>
              <h3 class="text-xl font-bold mb-4 text-[var(--heading-color)] flex items-center gap-2">
                <span class="text-[#F29B30]">●</span> Instructions
              </h3>
              <ol class="space-y-4">
                {article.data.steps?.map((step: string, index: number) => (
                  <li class="flex gap-3 text-[var(--text-color)]">
                    <span class="flex-shrink-0 w-6 h-6 rounded-full bg-[#F29B30] text-white flex items-center justify-center text-sm font-bold">
                      {index + 1}
                    </span>
                    <span>{step}</span>
                  </li>
                ))}
              </ol>
            </div>
          </div>
        </div>
      )
    }

    <!-- Article Content -->
    <div class="article-content">
      <Content />
    </div>

    <!-- Tags -->
    {
      article.data.tags.length > 0 && (
        <div class="mt-10 flex flex-wrap gap-2">
          {article.data.tags.map((tag: string) => (
            <span
              class="px-3 py-1 text-sm rounded-full"
              style="background-color: var(--input-bg); color: var(--muted-color);"
            >
              #{tag}
            </span>
          ))}
        </div>
      )
    }

    <!-- FAQ Section -->
    {
      article.data.faq && article.data.faq.length > 0 && (
        <section class="mt-12 mb-8 border-t border-[var(--border-color)] pt-8">
          <h2 class="text-2xl font-bold mb-6 text-[var(--heading-color)] flex items-center gap-2">
            <span class="text-[#F29B30]">●</span> Frequently Asked Questions
          </h2>
          <div class="space-y-4">
            {article.data.faq.map((item: any) => (
              <details class="group rounded-xl border border-[var(--border-color)] bg-[var(--card-bg)] overflow-hidden">
                <summary class="flex justify-between items-center font-medium cursor-pointer list-none p-5 text-[var(--heading-color)] hover:bg-[var(--input-bg)] transition-colors">
                  <span>{item.question}</span>
                  <span class="transition group-open:rotate-180 text-gray-500">
                    <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                  </span>
                </summary>
                <div class="p-5 pt-0 text-[var(--text-color)] leading-relaxed">
                  {item.answer}
                </div>
              </details>
            ))}
          </div>
        </section>
      )
    }

    <!-- Disclaimer -->
    <div
      class="mt-10 p-5 rounded-xl text-sm leading-relaxed"
      style="background-color: var(--input-bg); border: 1px solid var(--border-color); color: var(--muted-color);"
    >
      <strong style="color: var(--heading-color);">Disclaimer:</strong> The information
      in this article is for educational purposes only and does not constitute professional
      medical or nutritional advice. Always consult a qualified healthcare provider
      before making dietary changes.
    </div>
    </div>
  </main>
  <Footer />

  <script is:inline>
    function setupReleaseGate() {
      const main = document.querySelector("main[data-release-root='true']");
      const releaseContent = document.getElementById("release-content");
      const releaseNotice = document.getElementById("release-notice");
      const releaseAt = main?.getAttribute("data-release-at");

      if (!main || !releaseContent || !releaseAt) return;

      // Preview mode: ?preview=PASSWORD bypasses the date gate
      const previewParam = new URLSearchParams(window.location.search).get("preview");
      if (previewParam === "moshiko1985!") {
        releaseContent.style.display = "";
        if (releaseNotice) {
          releaseNotice.innerHTML = '<p style="font-size:.8rem;color:#F29B30;font-weight:600">🔓 Preview mode — not yet published</p>';
          releaseNotice.style.padding = ".4rem .75rem";
        }
        return;
      }

      if (Date.now() >= new Date(releaseAt).getTime()) {
        releaseContent.style.display = "";
        releaseNotice?.classList.add("hidden");
      } else {
        releaseContent.style.display = "none";
        releaseNotice?.classList.remove("hidden");
      }
    }

    function setupRatingWidget() {
      const widget = document.getElementById("rating-widget");
      if (!widget) return;

      const slug = widget.getAttribute("data-slug");
      if (!slug) return;

      const stars = Array.from(widget.querySelectorAll(".rating-star"));
      const copy = document.getElementById("rating-copy");
      const average = document.getElementById("rating-average");
      const countLabel = document.getElementById("rating-count");
      const identityKey = "dlh_rating_user_key";
      let committedDisplay = 0;
      let userKey = "";

      const paintStars = (value) => {
        const v = Number(value) || 0;
        stars.forEach((star, index) => {
          const portion = Math.max(0, Math.min(1, v - index));
          const fill = star.querySelector(".rating-fill");
          if (fill) fill.style.width = `${portion * 100}%`;
        });
      };

      const getOrCreateUserKey = () => {
        try {
          const existing = localStorage.getItem(identityKey);
          if (existing) return existing;

          const generated = typeof crypto !== "undefined" && crypto.randomUUID
            ? crypto.randomUUID()
            : `${Date.now()}_${Math.random().toString(36).slice(2)}`;
          localStorage.setItem(identityKey, generated);
          return generated;
        } catch {
          return `anon_${Date.now()}`;
        }
      };

      const MIN_RATING_COUNT_FOR_JSONLD = 5;
      const JSONLD_SCRIPT_ID = "dlh-aggregate-rating-jsonld";

      const syncAggregateRatingJsonLd = (snapshot) => {
        const existing = document.getElementById(JSONLD_SCRIPT_ID);
        if (existing) existing.remove();

        const count = Number(snapshot?.count ?? 0);
        const avg = Number(snapshot?.average ?? 0);
        const pageUrl = widget.getAttribute("data-article-url") || "";
        const title = widget.getAttribute("data-article-title") || "";
        const schemaType = widget.getAttribute("data-schema-type") || "Article";

        if (
          count < MIN_RATING_COUNT_FOR_JSONLD ||
          !pageUrl ||
          !title ||
          !Number.isFinite(avg)
        ) {
          return;
        }

        const node = {
          "@context": "https://schema.org",
          "@type": schemaType,
          url: pageUrl,
          name: title,
          aggregateRating: {
            "@type": "AggregateRating",
            ratingValue: Math.round(avg * 100) / 100,
            ratingCount: count,
            bestRating: 5,
            worstRating: 1,
          },
        };

        const script = document.createElement("script");
        script.id = JSONLD_SCRIPT_ID;
        script.type = "application/ld+json";
        script.textContent = JSON.stringify(node);
        document.head.appendChild(script);
      };

      const renderSnapshot = (snapshot) => {
        const count = Number(snapshot?.count ?? 0);
        const avg = Number(snapshot?.average ?? 0);
        const userRating = Number(snapshot?.userRating ?? 0);
        const hasRatings = count > 0;

        if (!hasRatings) {
          committedDisplay = 0;
          paintStars(0);
          if (average) average.textContent = "";
          if (countLabel) countLabel.textContent = "";
          const orphan = document.getElementById(JSONLD_SCRIPT_ID);
          if (orphan) orphan.remove();
          if (copy) {
            copy.style.display = "";
            copy.textContent =
              "Yeah, this is a little awkward. No ratings yet. People probably rushed to make this and forgot to come back. Do us a solid, drop a quick rating, and help the next hungry person skip the guesswork.";
          }
          return;
        }

        const roundedAvg = Math.round(avg * 2) / 2;
        committedDisplay = userRating > 0 ? userRating : roundedAvg;
        paintStars(committedDisplay);
        if (average) average.textContent = `${roundedAvg.toFixed(1)} / 5`;
        if (countLabel) {
          countLabel.textContent = `from ${count} rating${count === 1 ? "" : "s"}`;
        }

        if (copy) {
          copy.style.display = "none";
        }

        syncAggregateRatingJsonLd(snapshot);
      };

      const loadSnapshot = async () => {
        try {
          const res = await fetch(
            `/api/rating?slug=${encodeURIComponent(slug)}&user_key=${encodeURIComponent(userKey)}`,
          );
          if (!res.ok) throw new Error("Failed loading rating");
          const payload = await res.json();
          renderSnapshot(payload);
        } catch {
          renderSnapshot({ count: 0, average: 0, userRating: 0 });
          if (copy) {
            copy.style.display = "";
            copy.textContent =
              "We could not load ratings right now. You can still browse, and we will try again on refresh.";
          }
        }
      };

      const submitRating = async (value) => {
        try {
          const res = await fetch("/api/rating", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              slug,
              user_key: userKey,
              rating: value,
            }),
          });
          if (!res.ok) throw new Error("Failed saving rating");
          const payload = await res.json();
          renderSnapshot(payload);
        } catch {
          if (copy) {
            copy.style.display = "";
            copy.textContent =
              "Your vote did not save this time. Please try once more.";
          }
        }
      };

      stars.forEach((star) => {
        const preview = () => {
          const value = Number(star.getAttribute("data-value"));
          if (!Number.isFinite(value) || value < 1 || value > 5) return;
          paintStars(value);
        };

        star.addEventListener("mouseenter", preview);
        star.addEventListener("focus", preview);

        star.addEventListener("mouseleave", () => {
          paintStars(committedDisplay);
        });

        star.addEventListener("blur", () => {
          paintStars(committedDisplay);
        });

        star.addEventListener("click", () => {
          const value = Number(star.getAttribute("data-value"));
          if (!Number.isFinite(value) || value < 1 || value > 5) return;
          submitRating(value);
        });
      });

      widget.addEventListener("mouseleave", () => {
        paintStars(committedDisplay);
      });

      userKey = getOrCreateUserKey();
      loadSnapshot();
    }

    function setupMidArticleImage() {
      const content = document.querySelector(".article-content");
      const main = document.querySelector("main[data-base-slug]");
      if (!content || !main) return;

      const slug = main.getAttribute("data-base-slug");
      if (!slug) return;

      const paragraphs = Array.from(content.querySelectorAll("p, ul, ol, blockquote, h2, h3"));
      if (paragraphs.length < 4) return;

      const insertAfter = paragraphs[Math.floor(paragraphs.length / 3)];
      if (!insertAfter) return;

      const wrapper = document.createElement("div");
      wrapper.style.cssText = "margin:2rem 0;border-radius:16px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.08)";

      const img = document.createElement("img");
      img.alt = "Ingredients";
      img.loading = "lazy";
      img.style.cssText = "width:100%;display:block;max-height:520px;object-fit:cover";
      img.onerror = () => { wrapper.remove(); };
      img.src = `/images/${slug}-ingredients.jpg`;
      wrapper.appendChild(img);
      insertAfter.after(wrapper);
    }

    document.addEventListener("astro:page-load", setupReleaseGate);
    document.addEventListener("astro:page-load", setupRatingWidget);
    document.addEventListener("astro:page-load", setupMidArticleImage);
  </script>
</BaseLayout>
