---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Contact Us | Daily Life Hacks";
const description = "Get in touch with the Daily Life Hacks team.";
---

<BaseLayout title={title} description={description}>
    <Header />
    <div class="max-w-4xl mx-auto px-4 py-12">
        <h1 class="text-4xl font-bold mb-8 text-[var(--heading-color)]">
            Contact Us
        </h1>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
            <div class="md:pt-6">
                <p
                    class="text-lg mb-6 space-y-2"
                    style="color: var(--text-color)"
                >
                    <span class="block">Have a question about a recipe?</span>
                    <span class="block">Want to partner with us?</span>
                    <span class="block">Or just want to say hi?</span>
                    <span class="block">We'd love to hear from you!</span>
                </p>

                <div class="space-y-4">
                    <div>
                        <h3 class="font-bold text-lg">Email</h3>
                        <a
                            href="mailto:hello@daily-life-hacks.com"
                            class="hover:underline"
                            style="color: var(--text-color);"
                            >hello@daily-life-hacks.com</a
                        >
                    </div>

                    <div>
                        <h3 class="font-bold text-lg">Social Media</h3>
                        <p>Follow us for daily inspiration:</p>
                        <div class="flex justify-start pt-2">
                            <a
                                href="https://www.pinterest.com/DavidMiller615/"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 text-sm font-medium transition-colors duration-200 px-6 py-2 rounded-full border"
                                style="color: var(--muted-color); border-color: var(--border-color);"
                                onmouseover="this.style.color='#E60023'; this.style.borderColor='#E60023'; this.style.backgroundColor='rgba(230,0,35,0.05)';"
                                onmouseout="this.style.color='var(--muted-color)'; this.style.borderColor='var(--border-color)'; this.style.backgroundColor='transparent';"
                            >
                                <svg
                                    class="h-5 w-5"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                    aria-hidden="true"
                                >
                                    <path
                                        d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"
                                    ></path>
                                </svg>
                                Follow on Pinterest
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div
                class="p-6 rounded-xl border"
                style="background-color: var(--card-bg); border-color: var(--border-color);"
            >
                <h2 class="text-2xl font-bold mb-4">Send us a message</h2>
                <form class="space-y-4">
                    <div>
                        <label
                            for="name"
                            class="block text-sm font-medium mb-1"
                            style="color: var(--label-color)">Name</label
                        >
                        <input
                            type="text"
                            id="name"
                            name="name"
                            class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none transition-colors"
                            style="background-color: var(--input-bg); border-color: var(--border-color); color: var(--text-color);"
                            placeholder="Your name"
                        />
                    </div>

                    <div>
                        <label
                            for="email"
                            class="block text-sm font-medium mb-1"
                            style="color: var(--label-color)">Email</label
                        >
                        <input
                            type="email"
                            id="email"
                            name="email"
                            class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none transition-colors"
                            style="background-color: var(--input-bg); border-color: var(--border-color); color: var(--text-color);"
                            placeholder="your@email.com"
                        />
                    </div>

                    <div>
                        <label
                            for="message"
                            class="block text-sm font-medium mb-1"
                            style="color: var(--label-color)">Message</label
                        >
                        <textarea
                            id="message"
                            name="message"
                            rows="4"
                            class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none transition-colors"
                            style="background-color: var(--input-bg); border-color: var(--border-color); color: var(--text-color);"
                            placeholder="How can we help?"></textarea>
                    </div>

                    <button
                        type="submit"
                        class="w-full bg-[#F29B30] text-white font-bold py-3 px-6 rounded-lg hover:bg-orange-600 transition-colors"
                    >
                        Send Message
                    </button>
                </form>
            </div>
        </div>
    </div>
    <Footer />
</BaseLayout>
