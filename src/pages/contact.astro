---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title = "Contact Us | Daily Life Hacks";
const description = "Get in touch with the Daily Life Hacks team.";
---

<BaseLayout title={title} description={description} robots="noindex, follow">
    <Header />
    <div class="max-w-4xl mx-auto px-4 py-12">
        <h1 class="text-4xl font-bold mb-8 text-[var(--heading-color)]">
            Contact Us
        </h1>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
            <div class="md:pt-6">
                <p
                    class="text-lg mb-6 space-y-2"
                    style="color: var(--text-color)"
                >
                    <span class="block">Have a question about a recipe?</span>
                    <span class="block">Want to partner with us?</span>
                    <span class="block">Or just want to say hi?</span>
                    <span class="block">We'd love to hear from you!</span>
                </p>

                <div class="space-y-4">
                    <div>
                        <h3 class="font-bold text-lg">Email</h3>
                        <a
                            href="mailto:hello@daily-life-hacks.com"
                            class="hover:underline"
                            style="color: var(--text-color);"
                            >hello@daily-life-hacks.com</a
                        >
                    </div>
                </div>
            </div>

            <div
                class="p-6 rounded-xl border"
                style="background-color: var(--card-bg); border-color: var(--border-color);"
            >
                <h2 class="text-2xl font-bold mb-4">Email us directly</h2>
                <p class="mb-6 leading-relaxed" style="color: var(--text-color);">
                    Email is the most reliable way to reach us. The button below
                    opens a new message in your email app.
                </p>
                <a
                    href="mailto:hello@daily-life-hacks.com?subject=Daily%20Life%20Hacks%20message"
                    class="inline-flex w-full items-center justify-center rounded-lg bg-[#F29B30] px-6 py-3 font-bold text-white transition-colors hover:bg-orange-600 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#F29B30]"
                >
                    Email Daily Life Hacks
                </a>
            </div>
        </div>
    </div>
    <Footer />
</BaseLayout>
