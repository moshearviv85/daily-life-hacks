---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const source = Astro.url.searchParams.get("source") || "newsletter";
const category = Astro.url.searchParams.get("category") || "";
const segment = Astro.url.searchParams.get("segment") || "";

const title = "You're In";
const description = "You're on the Daily Life Hacks newsletter list.";

const nextLink =
  category === "recipes"
    ? "/recipes"
    : category === "nutrition"
      ? "/nutrition"
      : category === "tips"
        ? "/tips"
        : "/";

const nextLabel =
  category === "recipes"
    ? "Browse Recipes"
    : category === "nutrition"
      ? "Browse Nutrition Guides"
      : category === "tips"
        ? "Browse Kitchen Tips"
        : "Back to Homepage";

const interestLabel = segment ? segment.replace(/-/g, " ") : "";
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="max-w-3xl mx-auto px-4 py-16">
    <section
      class="rounded-3xl p-8 md:p-12 text-center"
      style="background-color: var(--card-bg); border: 1px solid var(--border-color);"
    >
      <div
        class="inline-flex items-center justify-center w-14 h-14 rounded-full text-white mb-5"
        style="background-color: #F29B30;"
      >
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>

      <p class="text-sm font-bold uppercase tracking-[0.2em] mb-3" style="color: #F29B30;">
        You're In
      </p>
      <h1 class="text-4xl md:text-5xl font-bold mb-4" style="color: var(--heading-color);">
        You're officially on the list
      </h1>
      <p class="text-lg mb-6" style="color: var(--muted-color);">
        Thanks for signing up through the {source}. We'll send simple recipes, practical
        nutrition ideas, and smart kitchen tips that are actually useful in real life.
      </p>

      {
        segment && (
          <p class="text-sm mb-6" style="color: var(--muted-color);">
            We saved your interest in <strong style="color: var(--heading-color);">{interestLabel}</strong>
            so future emails can feel a little more relevant and a lot less random.
          </p>
        )
      }

      <div
        class="grid gap-3 md:grid-cols-3 text-left mb-8"
      >
        <div class="rounded-2xl p-4" style="background-color: var(--input-bg); border: 1px solid var(--border-color);">
          <p class="text-sm font-bold mb-2" style="color: var(--heading-color);">Easy ideas</p>
          <p class="text-sm" style="color: var(--muted-color);">
            The kind of recipes and kitchen wins you can actually use on a busy week.
          </p>
        </div>
        <div class="rounded-2xl p-4" style="background-color: var(--input-bg); border: 1px solid var(--border-color);">
          <p class="text-sm font-bold mb-2" style="color: var(--heading-color);">No fluff</p>
          <p class="text-sm" style="color: var(--muted-color);">
            Clear, practical content without turning every meal into a complicated project.
          </p>
        </div>
        <div class="rounded-2xl p-4" style="background-color: var(--input-bg); border: 1px solid var(--border-color);">
          <p class="text-sm font-bold mb-2" style="color: var(--heading-color);">Good place to start</p>
          <p class="text-sm" style="color: var(--muted-color);">
            While you're here, jump into the section that matches what brought you in.
          </p>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={nextLink}
          class="inline-flex items-center justify-center rounded-xl px-6 py-3 font-bold text-white"
          style="background-color: #F29B30;"
        >
          {nextLabel}
        </a>
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-xl px-6 py-3 font-bold"
          style="color: var(--heading-color); background-color: var(--input-bg); border: 1px solid var(--border-color);"
        >
          Keep Reading
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
