---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import FreshToday from '../components/FreshToday.astro';
import OptImage from '../components/OptImage.astro';

import Newsletter from '../components/Newsletter.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { isReleased, getReleaseTimestamp } from '../content/release';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': 'https://www.daily-life-hacks.com/#organization',
  name: 'Daily Life Hacks',
  url: 'https://www.daily-life-hacks.com',
  description: 'Audited grocery cost research, practical recipes, and interactive food tools built from USDA data and real shelf prices.',
  logo: 'https://www.daily-life-hacks.com/logo.png',
  sameAs: [
    'https://www.pinterest.com/DavidMiller615/'
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'Customer Support',
    url: 'https://www.daily-life-hacks.com/contact/'
  }
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Daily Life Hacks',
  url: 'https://www.daily-life-hacks.com',
  description: 'Grocery cost studies, practical recipes, and interactive food tools with public data and documented methodology.',
  publisher: {
    '@type': 'Organization',
    '@id': 'https://www.daily-life-hacks.com/#organization',
    name: 'Daily Life Hacks',
    logo: {
      '@type': 'ImageObject',
      url: 'https://www.daily-life-hacks.com/logo.png',
    },
  },
};

const allArticles = await getCollection('articles');
type Article = CollectionEntry<'articles'>;
const releasedArticles = allArticles.filter((article: Article) => isReleased(article));
const sorted = releasedArticles.sort(
  (a: Article, b: Article) => getReleaseTimestamp(b) - getReleaseTimestamp(a),
);
const releaseFeedRows = allArticles
  .map((article: Article) => ({
    slug: article.id,
    title: article.data.title,
    excerpt: article.data.excerpt,
    image: article.data.image,
    imageAlt: article.data.imageAlt,
    category: article.data.category,
    date: article.data.date.toISOString(),
    publishAt: article.data.publishAt?.toISOString(),
    releaseTime: getReleaseTimestamp(article),
  }));

// Fresh Today renders three cards. Shipping all 207 article summaries to the
// browser made the homepage parse a large JSON payload it never displayed.
// Keep two released and two upcoming entries per category so scheduled posts
// can still appear between daily deploys without carrying the whole archive.
const feedBuildTime = Date.now();
const releaseFeed = (["nutrition", "recipes", "tips"] as const)
  .flatMap((category) => {
    const categoryRows = releaseFeedRows.filter((row) => row.category === category);
    const released = categoryRows
      .filter((row) => row.releaseTime <= feedBuildTime)
      .sort((a, b) => b.releaseTime - a.releaseTime)
      .slice(0, 2);
    const upcoming = categoryRows
      .filter((row) => row.releaseTime > feedBuildTime)
      .sort((a, b) => a.releaseTime - b.releaseTime)
      .slice(0, 2);
    return [...released, ...upcoming];
  })
  .map(({ releaseTime, ...article }) => article);

const featured  = sorted.find((a: Article) => a.data.featured) ?? sorted[0];
// Take all articles except the featured one, show 5 in Must Read sidebar
const mustReads = sorted.filter((a: Article) => a.id !== featured?.id).slice(0, 5);

// Grid: exclude featured + sidebar articles to avoid duplicates
const sidebarIds = new Set([featured?.id, ...mustReads.map((a: Article) => a.id)]);
const remaining = sorted.filter((a: Article) => !sidebarIds.has(a.id));

// 1) Filter into specific categories
const nutritionArticles = remaining.filter((a: Article) => a.data.category === 'nutrition');
const recipesArticles = remaining.filter((a: Article) => a.data.category === 'recipes');
const tipsArticles = remaining.filter((a: Article) => a.data.category === 'tips');

// 2) Shuffle function (seeded by request/build time)
const shuffle = <T,>(array: T[]): T[] => [...array].sort(() => Math.random() - 0.5);

// 3) Select 4 random articles from each
const selectedNutrition = shuffle(nutritionArticles).slice(0, 4);
const selectedRecipes = shuffle(recipesArticles).slice(0, 4);
const selectedTips = shuffle(tipsArticles).slice(0, 4);

// 4) Combine and shuffle the final 12 articles
const moreToRead = shuffle([...selectedNutrition, ...selectedRecipes, ...selectedTips]);

const badgeColor = (cat: string) => '#F29B30';
---

<BaseLayout
  title="Daily Life Hacks | Grocery Cost Studies, Recipes and Food Tools"
  description="Audited grocery cost studies, practical recipes, and interactive food tools built from real prices and USDA nutrition data."
  jsonLd={[organizationSchema, websiteSchema]}
>
  <Header />
  <main class="pb-8">

    <!-- SEO: Main H1 Heading -->
    <div class="sr-only">
      <h1>Grocery Cost Studies, Practical Recipes, and Food Tools</h1>
    </div>

    <!-- Mobile-only Category Quick Nav (Sticky-like) -->
    <nav class="lg:hidden flex justify-center gap-3 py-4 px-4 sticky top-[60px] z-40 bg-white/90 dark:bg-slate-900/90 backdrop-blur-md border-b border-orange-100 dark:border-orange-900/20 mb-2 overflow-x-auto whitespace-nowrap">
      <a href="/nutrition/" class="px-4 py-2 rounded-full text-sm font-bold shadow-sm transition-all active:scale-95 bg-[#F29B30] text-white">Nutrition</a>
      <a href="/recipes/" class="px-4 py-2 rounded-full text-sm font-bold shadow-sm transition-all active:scale-95 border-2 border-[#F29B30] text-[#F29B30] bg-white dark:bg-slate-900">Recipes</a>
      <a href="/tools/" class="px-4 py-2 rounded-full text-sm font-bold shadow-sm transition-all active:scale-95 border-2 border-[#F29B30] text-[#F29B30] bg-white dark:bg-slate-900">Tools</a>
      <a href="/tips/" class="px-4 py-2 rounded-full text-sm font-bold shadow-sm transition-all active:scale-95 border-2 border-[#F29B30] text-[#F29B30] bg-white dark:bg-slate-900">Tips</a>
    </nav>

    <!-- Hero: Featured article + Must Read sidebar -->
    <HeroSection featured={featured} mustReads={mustReads} />

    <FreshToday articles={releaseFeed} />

    <!-- Data studies + calculator showcase -->
    <section class="w-full max-w-6xl mx-auto px-4 py-8">
      <div class="flex items-center gap-3 mb-2">
        <h2 class="text-xl font-bold uppercase tracking-wide shrink-0" style="color: var(--heading-color);">We Did the Math</h2>
        <div class="flex-1 h-px" style="background-color: var(--border-color);"></div>
        <div class="w-10 h-0.5 shrink-0" style="background-color: #F29B30;"></div>
      </div>
      <p class="text-sm mb-4" style="color: var(--muted-color);">USDA nutrition numbers, real grocery prices, and one very long spreadsheet, so you can see exactly what your dollar buys.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <!-- Fiber per Dollar study -->
        <a
          href="/fiber-per-dollar-cheapest-high-fiber-foods/"
          class="group overflow-hidden rounded-xl transition-shadow duration-300 hover:shadow-lg flex flex-col"
          style="background-color: var(--card-bg); border: 1px solid var(--border-color);"
        >
          <div class="overflow-hidden relative aspect-video shrink-0">
            <OptImage
              src="/images/fiber-per-dollar-cheapest-high-fiber-foods-main.jpg"
              alt="Fiber per dollar data study comparing cheap high fiber foods"
              width={400}
              height={225}
              sizes="(max-width: 768px) 100vw, 400px"
              class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
              decoding="async"
              data-pin-nopin="true"
            />
            <span class="absolute bottom-2 left-2 px-2 py-0.5 text-[10px] font-bold rounded uppercase tracking-wider text-white leading-none z-10" style="background-color: #F29B30;">Data Study</span>
          </div>
          <div class="p-4 flex-1 flex flex-col gap-1.5">
            <h3 class="font-semibold leading-tight group-hover:text-[#F29B30] transition-colors duration-200" style="color: var(--heading-color);">Fiber per Dollar: 53 Foods Ranked</h3>
            <p class="text-sm leading-snug" style="color: var(--muted-color);">53 foods ranked by how much fiber a dollar buys. Spoiler: the winners live in the dry goods aisle.</p>
          </div>
        </a>
        <!-- Protein per Dollar study -->
        <a
          href="/protein-per-dollar-cheapest-protein-sources/"
          class="group overflow-hidden rounded-xl transition-shadow duration-300 hover:shadow-lg flex flex-col"
          style="background-color: var(--card-bg); border: 1px solid var(--border-color);"
        >
          <div class="overflow-hidden relative aspect-video shrink-0">
            <OptImage
              src="/images/protein-per-dollar-cheapest-protein-sources-main.jpg"
              alt="Protein per dollar data study comparing cheap protein sources"
              width={400}
              height={225}
              sizes="(max-width: 768px) 100vw, 400px"
              class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
              decoding="async"
              data-pin-nopin="true"
            />
            <span class="absolute bottom-2 left-2 px-2 py-0.5 text-[10px] font-bold rounded uppercase tracking-wider text-white leading-none z-10" style="background-color: #F29B30;">Data Study</span>
          </div>
          <div class="p-4 flex-1 flex flex-col gap-1.5">
            <h3 class="font-semibold leading-tight group-hover:text-[#F29B30] transition-colors duration-200" style="color: var(--heading-color);">Protein per Dollar: 49 Sources Ranked</h3>
            <p class="text-sm leading-snug" style="color: var(--muted-color);">49 protein sources compared by cost per gram. The fancy stuff near the deli counter does not do well.</p>
          </div>
        </a>
        <!-- Audited weekly food planner -->
        <a
          href="/tools/grocery-budget-calculator/"
          class="group overflow-hidden rounded-xl transition-shadow duration-300 hover:shadow-lg flex flex-col"
          style="background-color: var(--card-bg); border: 1px solid var(--border-color);"
        >
          <div class="overflow-hidden relative aspect-video shrink-0 flex flex-col items-center justify-center gap-1" style="background-color: rgba(242, 155, 48, 0.08);">
            <span class="text-5xl font-extrabold tracking-tight group-hover:scale-105 transition-transform duration-500" style="color: #F29B30;">7 days</span>
            <span class="text-[11px] font-bold uppercase tracking-widest" style="color: var(--muted-color);">10 priced menus</span>
            <span class="absolute bottom-2 left-2 px-2 py-0.5 text-[10px] font-bold rounded uppercase tracking-wider text-white leading-none z-10" style="background-color: #F29B30;">Free Tool</span>
          </div>
          <div class="p-4 flex-1 flex flex-col gap-1.5">
            <h3 class="font-semibold leading-tight group-hover:text-[#F29B30] transition-colors duration-200" style="color: var(--heading-color);">Plan the Week Before the Cart Gets Ideas</h3>
            <p class="text-sm leading-snug" style="color: var(--muted-color);">Pick fiber or protein, choose your menu days, and get scaled food quantities and cost. No rebuilding our spreadsheet one bean at a time.</p>
          </div>
        </a>
      </div>
      <div class="mt-5 text-center">
        <a href="/research/" class="inline-flex items-center justify-center px-5 py-2.5 rounded-lg font-bold transition-all hover:-translate-y-0.5" style="color:#F29B30;border:1px solid rgba(242,155,48,0.45);background:rgba(242,155,48,0.06);">See every study and download the data →</a>
      </div>
    </section>

    <!-- 4×4 Grid: More to Read -->
    <section class="w-full max-w-6xl mx-auto px-4 py-8">
      <div class="flex items-center gap-3 mb-4">
        <h2 class="text-xl font-bold uppercase tracking-wide shrink-0" style="color: var(--heading-color);">More to Read</h2>
        <div class="flex-1 h-px" style="background-color: var(--border-color);"></div>
        <div class="w-10 h-0.5 shrink-0" style="background-color: #F29B30;"></div>
      </div>
      <!-- Adaptive grid: 1 col mobile, 2 columns from 640px (tablet), 4 columns desktop -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {moreToRead.map((article: Article) => (
          <a
            href={`/${article.id}/`}
            class="group overflow-hidden rounded-xl transition-shadow duration-300 hover:shadow-lg flex flex-row sm:flex-col sm:aspect-[4/3] w-full"
            style="background-color: var(--card-bg); border: 1px solid var(--border-color);"
          >
            <!-- Image Area: Proportional increase of 15% to image, shrink text -->
            <div class="overflow-hidden relative w-[45%] aspect-video sm:w-full sm:h-auto sm:aspect-auto sm:flex-[7.7] shrink-0">
              <OptImage
                src={article.data.image}
                alt={article.data.imageAlt}
                width={320}
                height={180}
                sizes="(max-width: 768px) 100vw, 320px"
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
                data-pin-nopin="true"
              />
              <!-- Category badge overlaid on image -->
              <span
                class="absolute bottom-2 left-2 px-2 py-0.5 text-[10px] font-bold rounded uppercase tracking-wider text-white leading-none z-10"
                style={`background-color: ${badgeColor(article.data.category)};`}
              >
                {article.data.category}
              </span>
            </div>
            <!-- Text area: Shrink to 2.3 flex (total 10) -->
            <div class="p-2 sm:p-1.5 flex-1 flex flex-col justify-center sm:flex-[2.3] min-w-0">
              <h3
                class="font-semibold leading-tight group-hover:text-[#F29B30] transition-colors duration-200 text-left sm:text-center text-[0.9rem] sm:text-[0.88rem] line-clamp-none sm:line-clamp-3 w-full"
                style="color: var(--heading-color);"
              >
                {article.data.title}
              </h3>
            </div>
          </a>
        ))}
      </div>
    </section>

  </main>

  <!-- Newsletter just above footer -->
  <section id="newsletter">
    <Newsletter />
  </section>

  <Footer />
</BaseLayout>
