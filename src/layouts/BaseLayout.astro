---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import NewsletterPopup from "../components/NewsletterPopup.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  jsonLd?: object | object[];
}

const {
  title,
  description = "Daily Life Hacks - Practical nutrition tips and recipes for a healthier, happier life.",
  image = "/logo.png",
  canonicalURL = (() => {
    const base = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
    base.pathname = base.pathname.replace(/-v\d+\/?$/, '');
    if (base.pathname !== '/') base.pathname = base.pathname.replace(/\/$/, '');
    return base.href;
  })(),
  jsonLd,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Daily Life Hacks</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <ClientRouter />

    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Daily Life Hacks" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Pinterest -->
    <meta name="pinterest-rich-pin" content="true" />
    <meta name="p:domain_verify" content="0aee36e1e94111369fd7fdf18cb18c48"/>

    <!-- Prevent white flash in dark mode -->
    <script is:inline>
      const getTheme = () => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        return "light"; // default
      };

      const setTheme = () => {
        const theme = getTheme();
        if (theme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      };

      // Set on initial load
      setTheme();

      // Set on navigation
      document.addEventListener("astro:after-swap", setTheme);
    </script>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- JSON-LD Schema -->
    {
      jsonLd && Array.isArray(jsonLd)
        ? jsonLd.map((schema) => (
            <script
              is:inline
              type="application/ld+json"
              set:html={JSON.stringify(schema)}
            />
          ))
        : jsonLd && (
            <script
              is:inline
              type="application/ld+json"
              set:html={JSON.stringify(jsonLd)}
            />
          )
    }

    <!-- Robots -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
  </head>
  <body
    class="min-h-screen"
    style="background-color: var(--page-bg); color: var(--text-color);"
  >
    <slot />
    <NewsletterPopup />

    <!-- Pinterest Save Button SDK -->
    <script is:inline>
      function loadPinterestSDK() {
        // Clear old Pinterest tracking elements
        document.querySelectorAll("[data-pin-log]").forEach(function (el) {
          el.remove();
        });

        var old = document.getElementById("pinterest-sdk");
        if (old) old.remove();

        // Reset the globals to force full re-initialization
        window.PinUtils = null;
        window.PIN_XXXX = null;
        for (var key in window) {
          if (key.startsWith("PIN_")) {
            window[key] = null;
          }
        }

        var s = document.createElement("script");
        s.id = "pinterest-sdk";
        s.async = true;
        s.src = "https://assets.pinterest.com/js/pinit.js";
        s.setAttribute("data-pin-hover", "true");
        s.setAttribute("data-pin-tall", "true");
        s.setAttribute("data-pin-round", "true");
        document.body.appendChild(s);
      }

      document.addEventListener("astro:page-load", function () {
        // Small timeout allows DOM to settle before Pinterest scans it
        setTimeout(loadPinterestSDK, 150);
      });
    </script>

    <!-- Page view tracking (client-side) -->
    <script is:inline>
      function sendPageView() {
        try {
          var path =
            typeof window !== "undefined" && window.location
              ? window.location.pathname
              : "";
          if (!path) return;

          // Prevent spamming duplicates on the same path in one tab/session.
          var key = "pv_sent:" + path;
          try {
            if (sessionStorage.getItem(key) === "1") return;
            sessionStorage.setItem(key, "1");
          } catch (e) {}

          fetch("/api/event", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              event_type: "page_view",
              page: path,
              source: "website",
            }),
            keepalive: true,
          }).catch(function () {});
        } catch (e) {}
      }

      // Send immediately when this script runs.
      sendPageView();

      // Also send on initial page load and on Astro navigations.
      window.addEventListener("load", sendPageView);
      document.addEventListener("astro:page-load", sendPageView);
      document.addEventListener("astro:after-swap", sendPageView);
    </script>
  </body>
</html>
