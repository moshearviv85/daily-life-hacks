# Copy to n8n/.env and fill values. Then run: node n8n/scripts/deploy.mjs

# n8n (Settings → API → Create API key with scopes: workflow:* and credential:*)
N8N_BASE_URL=http://127.0.0.1:5678
N8N_API_KEY=

# Google Sheet: spreadsheet ID from the URL
GOOGLE_SPREADSHEET_ID=
# Tab: use ONE of these — gid from URL (?gid= or #gid=) OR tab name
# GOOGLE_SHEET_GID=1376264142
# GOOGLE_SHEET_TAB=PinterestQueue

# Pinterest access token (pina_... or Bearer token without the word Bearer)
PINTEREST_ACCESS_TOKEN=

# --- Google auth (pick ONE method) ---
# A) OAuth credential already in n8n UI — set name to match exactly
GOOGLE_OAUTH_CREDENTIAL_NAME=Google Sheets OAuth2

# B) Service account JSON file path (share the sheet with the SA email)
# GOOGLE_SERVICE_ACCOUNT_FILE=C:\path\to\service-account.json
